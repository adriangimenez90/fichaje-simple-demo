			const date = String(formData.get('date') || todayIso());
			const time = String(formData.get('time') || currentTime());
			const reason = String(formData.get('reason') || '').trim();

			if (!reason) {
				showToast('El motivo es obligatorio para guardar el ajuste.');
				return;
			}

			let entry = findEntry(employee.id, date);
			if (!entry) {
				entry = {
					id: uniqueId('entry'),
					employeeId: employee.id,
					date,
					breaks: [],
					status: 'incidencia',
				};
				timeEntries.push(entry);
			}
			entry.status = 'incidencia';
			entry.notes = `${type} a las ${time}: ${reason}`;

			incidents.push({
				id: uniqueId('incident'),
				employeeId: employee.id,
				date,
				type,
				detail: `${time} · ${reason}`,
				status: 'pendiente',
				createdAt: new Date().toISOString(),
			});
			addAudit('Ajuste manual', `${employee.name}: ${type} el ${formatDate(date)} a las ${time}.`);
			saveAll();
			showToast('Ajuste guardado y enviado a incidencias.');
