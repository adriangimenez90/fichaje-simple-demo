			if (filter === 'pendiente') return emptyState('No tienes solicitudes pendientes.');
			if (filter === 'aprobada-futura') return emptyState('No tienes vacaciones aprobadas futuras.');
			if (filter === 'disfrutada') return emptyState('No tienes vacaciones disfrutadas.');
			if (filter === 'denegada') return emptyState('No tienes solicitudes denegadas.');
			if (filter === 'cancelada') return emptyState('No tienes solicitudes canceladas.');
			return emptyState('Aún no has solicitado vacaciones.');
		}

		function filterEmployeeVacationRequests(requests: VacationRequest[], filter: EmployeeVacationFilter) {
			if (filter === 'all') return requests;
			if (filter === 'aprobada-futura') return requests.filter(isFutureApprovedVacation);
			if (filter === 'disfrutada') return requests.filter(isEnjoyedVacation);
			return requests.filter((request) => request.status === filter);
		}

		function isFutureApprovedVacation(request: VacationRequest) {
			return request.status === 'aprobada' && request.from > todayIso();
		}

		function isEnjoyedVacation(request: VacationRequest) {
			return request.status === 'aprobada' && request.from <= todayIso();
		}

		function vacationRequestDays(request: VacationRequest) {
			return businessDaysBetween(request.from, request.to);
		}

