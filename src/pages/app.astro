		function renderAdminDashboard() {
			const today = todayIso();
			const statuses = EMPLOYEES.map((employee) => ({
				employee,
				entry: findEntry(employee.id, today),
			}));
			const workingNow = statuses.filter(({ employee, entry }) => adminTodayStatus(employee, entry).key === 'trabajando').length;
			const inPause = statuses.filter(({ employee, entry }) => adminTodayStatus(employee, entry).key === 'pausa').length;
			const missing = statuses.filter(({ employee, entry }) => adminTodayStatus(employee, entry).key === 'sin-fichar').length;
			const vacationToday = statuses.filter(({ employee, entry }) => adminTodayStatus(employee, entry).key === 'vacaciones').length;
			const filteredStatuses = adminTodayFilter === 'all'
				? statuses
				: statuses.filter(({ employee, entry }) => adminTodayStatus(employee, entry).key === adminTodayFilter);
			const filterLabel = adminTodayFilterLabel(adminTodayFilter);

			return `
				${sectionTitle('Inicio', 'Qué pasa hoy en Empresa Demo')}
				<div class="grid grid-4 admin-status-strip">
					${adminDashboardMetric('Trabajando', String(workingNow), 'trabajando', '', '', 'trabajando')}
					${adminDashboardMetric('En descanso', String(inPause), 'pausa', '', '', 'pausa')}
					${adminDashboardMetric('Sin fichar', String(missing), missing ? 'pendiente' : 'correcto', '', '', 'sin-fichar')}
					${adminDashboardMetric('De vacaciones hoy', String(vacationToday), 'vacaciones', '', '', 'vacaciones')}
				</div>
				<section class="panel top-gap admin-primary-list">
