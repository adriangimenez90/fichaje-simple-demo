			const weeklyRange = weekRangeFromInput(weekInputValue(todayIso()));
			const monthlyRange = monthRangeFromInput(todayIso().slice(0, 7));
			const weeklyRows = buildExpectedHoursReport('week', weeklyRange.from, weeklyRange.to, 'all');
			const monthlyRows = buildExpectedHoursReport('month', monthlyRange.from, monthlyRange.to, 'all');

			return `
				<section class="panel top-gap export-reports-panel">
					<div class="panel-heading">
						<div>
							<h2>Reportes de horas</h2>
							<p class="helper-text">Horas esperadas calculadas con días laborables y festivos configurados en la demo.</p>
						</div>
					</div>
					<div class="reports-grid export-reports-grid">
						${exportReportPreview(
							'Reporte semanal de horas',
							'Semana laboral en curso. Esperado: días laborables x 8 horas.',
							['Empleado', 'Departamento', 'Periodo', 'Horas fichadas', 'Horas esperadas', 'Diferencia', 'Incidencias'],
							weeklyRows,
						)}
						${exportReportPreview(
