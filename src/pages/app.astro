		function responsibleConflictLine(request: VacationRequest) {
			const employee = employeeById(request.employeeId);
			const scope = employee ? departmentEmployees(employee.department) : EMPLOYEES;
			const details = vacationConflictDetails(request, scope);
			if (!details.length) return '<small>Sin solapes del departamento</small>';
			const preview = details.slice(0, 2).map((item) => (
				`${employeeName(item.request.employeeId)} ${formatDayHeader(item.from)}-${formatDayHeader(item.to)} · ${item.request.status === 'aprobada' ? 'Aprobada' : 'Pendiente'}`
			));
			const extra = details.length > preview.length ? ` · +${details.length - preview.length} más` : '';
			return `<small>${preview.map(escapeHtml).join('<br>')}${extra}</small>`;
		}

		function renderResponsibleConflictDetails(request: VacationRequest, scopeEmployees: Employee[]) {
			const details = vacationConflictDetails(request, scopeEmployees);
			if (!details.length) {
				return `<p class="helper-text top-gap">No hay solapes en el departamento.</p>`;
			}

			return `
				<div class="responsible-conflict-list top-gap">
					${details.map((item) => `
						<div class="responsible-conflict-item">
							<strong>${employeeName(item.request.employeeId)}</strong>
							<span>${formatDate(item.from)} - ${formatDate(item.to)}</span>
							${pill(item.request.status === 'aprobada' ? 'Aprobada' : 'Pendiente', item.request.status)}
						</div>
					`).join('')}
				</div>
			`;
		}

		function vacationConflictDetails(request: VacationRequest, scopeEmployees = EMPLOYEES) {
			const scopeIds = new Set(scopeEmployees.map((employee) => employee.id));
			return vacations
				.filter(
					(item) =>
						item.id !== request.id &&
						item.employeeId !== request.employeeId &&
						scopeIds.has(item.employeeId) &&
						isActiveVacationRequest(item) &&
						businessRangesOverlap(request.from, request.to, item.from, item.to),
				)
				.map((item) => ({
					request: item,
					from: maxDate(request.from, item.from),
					to: minDate(request.to, item.to),
				}))
				.sort((a, b) => a.from.localeCompare(b.from));
		}

