		function canCancelEmployeeVacation(request: VacationRequest) {
			if (request.status === 'pendiente') return true;
			return isFutureApprovedVacation(request);
		}

		function vacationReminderMailto(request: VacationRequest) {
			const employee = employeeName(request.employeeId);
			const subject = encodeURIComponent('Recordatorio de vacaciones pendientes');
			const body = encodeURIComponent(
				`Hola,\n\n${employee} tiene una solicitud de vacaciones pendiente de revisión.\n\nFechas: ${formatDate(request.from)} - ${formatDate(request.to)}\nDías laborables solicitados: ${vacationRequestDays(request)}\n\n¿Podéis revisarla cuando sea posible?\n\nGracias.`,
			);
			return `mailto:responsable.vacaciones@empresa-demo.es?subject=${subject}&body=${body}`;
		}

		function renderVacationAdminDetail(request: VacationRequest, scopeEmployees = EMPLOYEES) {
			const rangeDays = dateRange(request.from, request.to);
			const scopeIds = new Set(scopeEmployees.map((employee) => employee.id));
			const approvedConflictEmployees = new Set(
				vacations
					.filter(
						(item) =>
							item.id !== request.id &&
							item.employeeId !== request.employeeId &&
							scopeIds.has(item.employeeId) &&
							item.status === 'aprobada' &&
							businessRangesOverlap(request.from, request.to, item.from, item.to),
					)
					.map((item) => item.employeeId),
			);
			const pendingConflictEmployees = new Set(
				vacations
					.filter(
						(item) =>
							item.id !== request.id &&
							item.employeeId !== request.employeeId &&
							scopeIds.has(item.employeeId) &&
							item.status === 'pendiente' &&
							businessRangesOverlap(request.from, request.to, item.from, item.to),
					)
					.map((item) => item.employeeId),
			);
			const comparisonRows = scopeEmployees.map((employee) => `
				<tr>
					<th class="sticky-col">
						<strong>${employee.name}</strong>
						<span>${employee.department}</span>
					</th>
					${rangeDays.map((date) => renderVacationComparisonCell(employee.id, date, request)).join('')}
