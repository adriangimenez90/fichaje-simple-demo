			const formData = new FormData(form);
			teamCalendarDepartment = String(formData.get('department') || 'all');
			const nextMode = String(formData.get('mode') || 'month');
			teamCalendarMode = nextMode === 'planning' ? 'planning' : 'month';
			selectedTeamCalendarDay = '';
			renderPage();
		}

		function resolveVacation(status: VacationStatus, id = '') {
			if (id) selectedVacationId = id;
			const request = vacations.find((item) => item.id === selectedVacationId);
			if (!request || request.status !== 'pendiente') return;

			if (status === 'denegada') {
				const selectedMarker = document.querySelector<HTMLElement>('[data-selected-vacation-id]');
				if (id && selectedMarker && id !== selectedMarker.dataset.selectedVacationId) {
					renderPage();
					showToast('Selecciona la solicitud e indica el motivo para denegar.');
					return;
				}
				const reason = document.querySelector<HTMLTextAreaElement>('#denial-reason')?.value.trim() || '';
				if (!reason) {
					showToast('El motivo es obligatorio para denegar una solicitud.');
					return;
				}
				request.denialReason = reason;
			}

			request.status = status;
			request.decidedAt = new Date().toISOString();
			const isVacation = resolveAbsenceTypeId(request) === DEFAULT_ABSENCE_TYPE_ID;
			const typeName = absenceTypeName(request);
			addAudit(
				status === 'aprobada'
					? (isVacation ? 'Vacaciones aprobadas' : 'Ausencia aprobada')
					: (isVacation ? 'Vacaciones denegadas' : 'Ausencia denegada'),
				`${employeeName(request.employeeId)} · ${typeName} · ${responsibleRequestDateLabel(request)}`,
			);
			saveAll();
			showToast(`${status === 'aprobada' ? 'Solicitud aprobada.' : 'Solicitud denegada.'} La solicitud se ha actualizado en la demo.`);
			renderPage();
		}

		function changeAdminVacationMonth(offset: number) {
			adminVacationCursor = new Date(adminVacationCursor.getFullYear(), adminVacationCursor.getMonth() + offset, 1);
			selectedAdminVacationDay = '';
			renderPage();
		}

		function selectAdminVacationDay(date: string) {
			selectedAdminVacationDay = date;
			renderPage();
		}

		function changeCalendarMonth(offset: number) {
			calendarCursor = new Date(calendarCursor.getFullYear(), calendarCursor.getMonth() + offset, 1);
			selectedCalendarDay = '';
			calendarAdjustmentDate = '';
			renderPage();
		}

		function selectCalendarDay(date: string) {
			selectedCalendarDay = date;
			calendarAdjustmentDate = '';
			renderPage();
		}

		function openCalendarAdjustment(date: string) {
			const employee = currentEmployee();
			const entry = findEntry(employee.id, date);

			if (!entry && date > todayIso()) {
				showToast('No se pueden crear registros futuros en la demo.');
				return;
			}

			selectedCalendarDay = date;
			calendarAdjustmentDate = date;
			renderPage();
		}

		function closeCalendarAdjustment() {
			calendarAdjustmentDate = '';
			renderPage();
		}

		function changeTeamCalendarMonth(offset: number) {
			teamCalendarCursor = new Date(teamCalendarCursor.getFullYear(), teamCalendarCursor.getMonth() + offset, 1);
			selectedTeamCalendarDay = '';
			renderPage();
		}

		function selectTeamCalendarDay(date: string) {
			selectedTeamCalendarDay = date;
			renderPage();
		}

		function exportTimesheets() {
			const totalDays = diffDays(timeFilters.from, timeFilters.to) + 1;
			if (timeFilters.employeeId === 'all' && totalDays > 31) {
				showToast('Para todos los empleados el máximo es 31 días. Solicita una exportación avanzada.');
				return;
			}
			if (timeFilters.employeeId !== 'all' && totalDays > 92) {
				showToast('Para un empleado concreto el máximo es 3 meses. Solicita una exportación avanzada.');
				return;
			}

			const rows = filteredTimeEntries().map((entry) => ({
				Fecha: formatDate(entry.date),
				Empleado: employeeName(entry.employeeId),
				Entrada: entry.start || '',
				Descansos: formatBreaks(entry),
				Salida: entry.end || '',
				'Tiempo trabajado': formatMinutes(workedMinutes(entry)),
				Estado: entry.status,
			}));

			downloadCsv('fichajes-demo.csv', rows);
			addAudit('Exportación CSV', `Fichajes exportados (${rows.length} registros).`);
			saveAll();
			showToast('CSV de fichajes descargado.');
		}

		function exportTimesheetsFromExportForm() {
			const form = document.querySelector<HTMLFormElement>('#export-timesheet-form');
			if (!form) return;

			const formData = new FormData(form);
			const employeeId = String(formData.get('employeeId') || 'all');
			const from = String(formData.get('from') || startOfMonthIso(new Date()));
			const to = String(formData.get('to') || todayIso());
			const totalDays = diffDays(from, to) + 1;

			if (employeeId === 'all' && totalDays > 31) {
				showToast('Para todos los empleados el máximo es 31 días.');
				return;
			}
			if (employeeId !== 'all' && totalDays > 92) {
				showToast('Para un empleado concreto el máximo es 3 meses.');
				return;
			}

			const rows = timeEntries
				.filter((entry) => employeeId === 'all' || entry.employeeId === employeeId)
				.filter((entry) => dateInRange(entry.date, from, to))
				.map((entry) => ({
					Fecha: formatDate(entry.date),
					Empleado: employeeName(entry.employeeId),
					Entrada: entry.start || '',
					Descansos: formatBreaks(entry),
					Salida: entry.end || '',
					'Tiempo trabajado': formatMinutes(workedMinutes(entry)),
					Estado: entry.status,
				}));

			downloadCsv('fichajes-demo.csv', rows);
			addAudit('Exportación CSV', `Fichajes exportados (${rows.length} registros).`);
			saveAll();
			showToast('CSV de fichajes descargado.');
		}

		function exportHoursReportFromForm() {
			const form = document.querySelector<HTMLFormElement>('#export-hours-report-form');
			if (!form) return;

			const formData = new FormData(form);
			const scope = String(formData.get('scope') || 'week') === 'month' ? 'month' : 'week';
			const employeeId = String(formData.get('employeeId') || 'all');
			const range = scope === 'week'
				? weekRangeFromInput(String(formData.get('week') || weekInputValue(todayIso())))
				: monthRangeFromInput(String(formData.get('month') || todayIso().slice(0, 7)));
			const rows: Record<string, string | number>[] = buildExpectedHoursReport(scope, range.from, range.to, employeeId).map((row) => ({
				Empleado: String(row[0]),
				Departamento: String(row[1]),
				Periodo: String(row[2]),
				'Horas fichadas': String(row[3]),
				'Horas esperadas': String(row[4]),
				Diferencia: String(row[5]),
				Incidencias: String(row[6]),
			}));

			downloadCsv(scope === 'week' ? 'reporte-semanal-demo.csv' : 'reporte-mensual-demo.csv', rows);
			addAudit('Exportación CSV', `Reporte ${scope === 'week' ? 'semanal' : 'mensual'} exportado (${formatDate(range.from)} - ${formatDate(range.to)}).`);
			saveAll();
			showToast('Reporte CSV descargado.');
		}

		function updateExportReportPeriodFields() {
			const form = document.querySelector<HTMLFormElement>('#export-hours-report-form');
			if (!form) return;

			const scope = String(new FormData(form).get('scope') || 'week');
			form.querySelectorAll<HTMLElement>('[data-period-field]').forEach((field) => {
				const visible = field.dataset.periodField === scope;
				field.classList.toggle('hidden', !visible);
			});
		}

		function exportGeneric() {
			const form = document.querySelector<HTMLFormElement>('#export-form');
			if (!form) return;

			const formData = new FormData(form);
			const type = String(formData.get('type') || 'fichajes');
			const employeeId = String(formData.get('employeeId') || 'all');
			const from = String(formData.get('from') || '1900-01-01');
			const to = String(formData.get('to') || '2999-12-31');
			let rows: Record<string, string | number>[] = [];

			if (type === 'fichajes') {
				rows = timeEntries
					.filter((entry) => dateInRange(entry.date, from, to))
					.filter((entry) => employeeId === 'all' || entry.employeeId === employeeId)
					.map((entry) => ({
						Fecha: formatDate(entry.date),
						Empleado: employeeName(entry.employeeId),
						Entrada: entry.start || '',
						Salida: entry.end || '',
						Estado: entry.status,
					}));
			}

			if (type === 'vacaciones') {
				rows = vacations
					.filter((request) => dateInRange(request.from, from, to))
					.filter((request) => employeeId === 'all' || request.employeeId === employeeId)
					.map((request) => ({
						Desde: formatDate(request.from),
						Hasta: formatDate(request.to),
						Empleado: employeeName(request.employeeId),
						'Días laborables': request.days,
						Estado: request.status,
					}));
			}

			if (type === 'incidencias') {
				rows = incidents
					.filter((incident) => dateInRange(incident.date, from, to))
					.filter((incident) => employeeId === 'all' || incident.employeeId === employeeId)
					.map((incident) => ({
						Fecha: formatDate(incident.date),
						Empleado: employeeName(incident.employeeId),
						Tipo: incident.type,
						Estado: incident.status,
						Detalle: incident.detail,
					}));
			}

			if (type === 'auditoria') {
				rows = auditLog
					.filter((entry) => dateInRange(entry.at.slice(0, 10), from, to))
					.map((entry) => ({
						Fecha: formatDateTime(entry.at),
						Usuario: entry.user,
						Acción: entry.action,
						Detalle: entry.detail,
					}));
			}

			downloadCsv(`${type}-demo.csv`, rows);
			addAudit('Exportación CSV', `${type} exportado (${rows.length} registros).`);
			saveAll();
			showToast('CSV descargado.');
		}

		function loadDemoData() {
			const defaults = createDemoData();
			applyDemoData(loadDemoDataFromStorage(defaults));
		}

		function applyDemoData(data: DemoData) {
			timeEntries = data.timeEntries;
			vacations = data.vacations;
			incidents = data.incidents;
			holidays = data.holidays;
			scheduledReports = data.scheduledReports;
			users = data.users;
			auditLog = data.auditLog;
		}

		function currentDemoData(): DemoData {
			return {
				timeEntries,
				vacations,
				incidents,
				holidays,
				scheduledReports,
				users,
				auditLog,
			};
		}

		function resetDemoData() {
			const defaults = createDemoData();
			applyDemoData(defaults);
			addAudit('Datos demo 2026 restablecidos', 'Se borraron los cambios locales y se restauró el dataset anual ficticio.');
			saveAll();
			renderPage();
		}

		function saveAll() {
			saveDemoDataToStorage(currentDemoData());
		}

		function addAudit(action: string, detail: string) {
			auditLog.unshift({
				id: uniqueId('audit'),
				at: new Date().toISOString(),
				user: session?.name || 'Usuario demo',
				action,
				detail,
			});
		}

		function getViews() {
			if (session.role === 'admin_global') return ADMIN_VIEWS;
			if (session.role === 'validador_vacaciones') return VALIDATOR_VIEWS;
			return EMPLOYEE_VIEWS;
		}

		function navigationGroups(views: { id: string; label: string; hint: string }[]) {
			if (session.role === 'admin_global') {
				return [{ label: '', items: views }];
			}

			if (session.role === 'validador_vacaciones') {
				return [{ label: 'Ausencias', items: views }];
			}

			return [{ label: '', items: views }];
		}

		function defaultViewForRole(role: Role) {
			if (role === 'admin_global') return 'dashboard';
			if (role === 'validador_vacaciones') return 'solicitudes';
			return 'fichar';
		}

		function roleLabel(role: Role) {
			if (role === 'admin_global') return 'Administrador';
			if (role === 'validador_vacaciones') return 'Responsable de ausencias';
			return 'Usuario normal';
		}

		function roleHint(role: Role) {
			if (role === 'admin_global') return 'Gestión diaria de empleados, fichajes, vacaciones y exportaciones';
			if (role === 'validador_vacaciones') return 'Revisión de vacaciones, permisos, calendario del equipo y festivos';
			return 'Fichaje personal, vacaciones y calendario';
		}

		function currentEmployee() {
			const employee = EMPLOYEES.find((item) => item.id === session.employeeId);
			return employee || EMPLOYEES[0];
		}

		function employeeById(id: string) {
			return EMPLOYEES.find((employee) => employee.id === id);
		}

		function employeeName(id: string) {
			return EMPLOYEES.find((employee) => employee.id === id)?.name || id;
		}

		function departmentEmployees(department: string) {
			return EMPLOYEES.filter((employee) => employee.department === department);
		}

		function departmentList() {
			return Array.from(new Set(EMPLOYEES.map((employee) => employee.department))).sort((a, b) => a.localeCompare(b));
		}

		function todayEntry(employeeId: string) {
			return findEntry(employeeId, todayIso());
		}

		function findEntry(employeeId: string, date: string) {
			return timeEntries.find((entry) => entry.employeeId === employeeId && entry.date === date);
		}

		function currentWorkStatus(entry?: TimeEntry) {
			if (!entry?.start) return { label: 'Sin iniciar', key: 'sin-fichaje' };
			if (entry.end) return { label: 'Jornada finalizada', key: 'correcto' };
			if (activeBreak(entry)) return { label: 'En descanso', key: 'pausa' };
			return { label: 'Trabajando', key: 'trabajando' };
		}

		function adminTodayStatus(employee: Employee, entry?: TimeEntry) {
			if (approvedVacationForDate(employee.id, todayIso())) {
				return { label: 'De vacaciones', key: 'vacaciones' };
			}

			const status = currentWorkStatus(entry);
			if (status.key === 'sin-fichaje') return { label: 'Sin fichar', key: 'sin-fichar' };
			return status;
		}

		function approvedVacationForDate(employeeId: string, date: string) {
			return (
				isBusinessDay(date) &&
				vacations.some(
					(request) =>
						request.employeeId === employeeId &&
						request.status === 'aprobada' &&
						isDateWithin(date, request.from, request.to),
				)
			);
		}

		function punchActionLabel(entry?: TimeEntry) {
			if (!entry?.start) return 'Iniciar jornada';
			if (entry.end) return 'Jornada finalizada';
			if (activeBreak(entry)) return 'Finalizar descanso';
			return 'Iniciar descanso';
		}

		function punchHelpText(entry?: TimeEntry) {
			if (!entry?.start) return 'Comienza la jornada de hoy';
			if (entry.end) return 'Todo listo por hoy';
			if (activeBreak(entry)) return 'Vuelve a trabajar';
			return 'Detiene el tiempo de trabajo';
		}

		function checkoutHelpText(entry?: TimeEntry) {
			if (!entry?.start) return 'Primero inicia la jornada';
			if (entry.end) return 'Salida registrada';
			if (activeBreak(entry)) return 'Finaliza el descanso antes';
			return 'Cierra la jornada de hoy';
		}

		function statusForDay(employeeId: string, date: string) {
			const vacation = vacations.find(
				(request) =>
					request.employeeId === employeeId &&
					isActiveVacationRequest(request) &&
					isBusinessDay(date) &&
					isDateWithin(date, request.from, request.to),
			);
			const entry = findEntry(employeeId, date);

			if (holidays.some((holiday) => holiday.date === date)) return 'festivo';
			if (vacation?.status === 'aprobada') return 'vacaciones';
			if (vacation?.status === 'pendiente') return 'pendiente';
			if (entry) return entry.status;
			if (isWeekend(date)) return 'fin de semana';
			return 'sin fichaje';
		}

		function calendarStatusLabel(status: string) {
			if (status === 'correcto') return 'Correcto';
			if (status === 'incidencia') return 'Incidencia';
			if (status === 'pendiente') return 'Pendiente';
			if (status === 'vacaciones') return 'Vacaciones';
			if (status === 'festivo') return 'Festivo';
			if (status === 'fin de semana') return 'Finde';
			if (status === 'sin fichaje') return 'Sin fichaje';
			return STATUS_LABELS[status] || status;
		}

		function renderBreakList(entry?: TimeEntry) {
			if (!entry?.breaks.length) return emptyState('Aún no hay descansos registrados hoy.');

			return `
				<div class="break-list">
					${entry.breaks.map((item) => `
						<div class="break-item break-${item.kind || 'manual'}">
							<span>${breakLabel(item)}</span>
							<strong>${item.start} - ${item.end || 'abierta'}</strong>
							<small>${item.end ? formatMinutes(elapsedMinutes(item.start, item.end)) : 'En curso'}</small>
						</div>
					`).join('')}
				</div>
			`;
		}

		function showManualFormMessage(form: HTMLFormElement, message: string) {
			const messageElement = form.querySelector<HTMLElement>('[data-manual-message]');
			if (!messageElement) {
				showToast(message);
				return;
			}

			messageElement.textContent = message;
			messageElement.hidden = false;
		}

		function refreshEntryIncident(entry: TimeEntry) {
			const issue = entryIssueDetail(entry);
			const existing = incidents.find(
				(incident) =>
					incident.employeeId === entry.employeeId &&
					incident.date === entry.date &&
					incident.type === 'Revisión de fichaje' &&
					incident.status === 'pendiente',
			);

			if (issue) {
				if (existing) {
					existing.detail = issue;
					return;
				}

				incidents.push({
					id: uniqueId('incident-manual'),
					employeeId: entry.employeeId,
					date: entry.date,
					type: 'Revisión de fichaje',
					detail: issue,
					status: 'pendiente',
					createdAt: new Date().toISOString(),
				});
				return;
			}

			if (existing) {
				existing.status = 'revisada';
				existing.reviewedAt = new Date().toISOString();
			}
		}

		function entryIssueDetail(entry: TimeEntry) {
			if (!entry.start) return 'No consta entrada registrada.';
			if (entry.breaks.some((pause) => !pause.end) && entry.end) return 'Hay una pausa sin hora de fin.';
			if (!entry.end && entry.date < todayIso()) return 'Jornada sin salida registrada.';
			if (activeBreak(entry) && entry.date < todayIso()) return 'Descanso sin finalizar.';
			return '';
		}

		function workedMinutesThisWeek(employeeId: string) {
			const from = startOfCurrentWorkWeekIso();
			const to = endOfCurrentWorkWeekIso();

			return timeEntries
				.filter((entry) => entry.employeeId === employeeId && dateInRange(entry.date, from, to) && !isWeekend(entry.date))
				.reduce((sum, entry) => sum + workedMinutes(entry), 0);
		}

		function startOfCurrentWorkWeekIso() {
			const date = new Date(`${todayIso()}T12:00:00`);
			const day = date.getDay();
			const mondayOffset = day === 0 ? -6 : 1 - day;
			date.setDate(date.getDate() + mondayOffset);
			return isoFromDate(date);
		}

		function endOfCurrentWorkWeekIso() {
			const date = new Date(`${startOfCurrentWorkWeekIso()}T12:00:00`);
			date.setDate(date.getDate() + 4);
			return isoFromDate(date);
		}

		function vacationBalance(employeeId: string) {
			const employee = EMPLOYEES.find((item) => item.id === employeeId) || EMPLOYEES[0];

			return calculateVacationBalance(
				employee,
				vacations,
				holidays,
				todayIso(),
				ABSENCE_TYPES,
			);
		}

		function filteredTimeEntries() {
			return timeEntries
				.filter((entry) => timeFilters.employeeId === 'all' || entry.employeeId === timeFilters.employeeId)
				.filter((entry) => dateInRange(entry.date, timeFilters.from, timeFilters.to))
				.filter((entry) => timeFilters.status === 'all' || entry.status === timeFilters.status)
				.sort((a, b) => b.date.localeCompare(a.date));
		}

		function showToast(message: string) {
			if (!toast) return;
			if (toastTimer) window.clearTimeout(toastTimer);
			toast.textContent = message;
			toast.classList.remove('hidden');
			toastTimer = window.setTimeout(() => toast.classList.add('hidden'), 4200);
		}

		function updateLiveClock() {
			document.querySelectorAll<HTMLElement>('.live-clock').forEach((element) => {
				element.textContent = currentTimeWithSeconds();
			});
		}

		function businessDaysBetween(from: string, to: string) {
			return calculateBusinessDaysBetween(from, to, holidays);
		}

		function isBusinessDay(date: string) {
			return checkBusinessDay(date, holidays);
		}

		function businessRangesOverlap(fromA: string, toA: string, fromB: string, toB: string) {
			return checkBusinessRangesOverlap(
				fromA,
				toA,
				fromB,
				toB,
				holidays,
			);
		}

		function isActiveVacationRequest(request: VacationRequest) {
			return checkActiveVacationRequest(request);
		}

		function countVacationDaysInRange(employeeId: string, from: string, to: string) {
			return calculateVacationDaysInRange(
				employeeId,
				from,
				to,
				vacations,
				holidays,
			);
		}

		function uniqueId(prefix: string) {
			return `${prefix}-${Math.random().toString(36).slice(2, 9)}-${Date.now().toString(36)}`;
		}
	</script>
</Layout>
