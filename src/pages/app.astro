		function renderReportsContent() {
			const weeklyRows = buildHoursReport(7);
			const monthlyRows = buildHoursReport(30);
			const missingRows = buildMissingPunchReport();
			const pendingIncidentRows = incidents
				.filter((incident) => incident.status === 'pendiente')
				.slice(0, 8)
				.map((incident) => [
					employeeName(incident.employeeId),
					formatDate(incident.date),
					escapeHtml(incident.type),
					escapeHtml(incident.detail),
					pill('Pendiente', 'pendiente'),
				]);
			const vacationRows = vacations
				.filter((request) => request.status === 'aprobada' || request.status === 'pendiente')
				.sort((a, b) => a.from.localeCompare(b.from))
				.slice(0, 8)
				.map((request) => [
					employeeName(request.employeeId),
					`${formatDate(request.from)} - ${formatDate(request.to)}`,
					String(request.days),
					pill(request.status),
					escapeHtml(request.comment || 'Sin comentario'),
				]);
			const pendingIncidentsCount = incidents.filter((incident) => incident.status === 'pendiente').length;
			const missingTodayCount = buildMissingPunchReport().length;
			const pendingVacationCount = vacations.filter((request) => request.status === 'pendiente').length;

			return `
				<div class="report-overview">
					${metricCard('Incidencias pendientes', String(pendingIncidentsCount), pendingIncidentsCount ? 'incidencia' : 'correcto', 'Requieren revisión administrativa')}
					${metricCard('Sin fichaje hoy', String(missingTodayCount), missingTodayCount ? 'pendiente' : 'correcto', 'Personas sin entrada registrada')}
					${metricCard('Vacaciones pendientes', String(pendingVacationCount), pendingVacationCount ? 'pendiente' : 'correcto', 'Solicitudes esperando decisión')}
					${metricCard('Informes programados', String(scheduledReports.length), 'trabajando', 'Envío automático simulado')}
				</div>
				<section class="panel">
					<div class="panel-heading">
						<div>
							<h2>Informes rápidos</h2>
							<p class="helper-text">Estas tablas son una previsualización con datos ficticios guardados en el navegador.</p>
						</div>
					</div>
					<div class="reports-grid">
						${reportPreview(
							'Reporte semanal de horas',
							'Últimos 7 días naturales.',
							['Empleado', 'Días con fichaje', 'Días sin fichaje', 'Horas registradas', 'Incidencias', 'Vacaciones', 'Estado'],
							weeklyRows,
						)}
						${reportPreview(
							'Reporte mensual de horas',
							'Últimos 30 días naturales.',
							['Empleado', 'Días con fichaje', 'Días sin fichaje', 'Horas registradas', 'Incidencias', 'Vacaciones', 'Estado'],
							monthlyRows,
						)}
						${reportPreview(
							'Empleados sin fichaje',
							'Personas sin entrada registrada hoy.',
							['Empleado', 'Fecha', 'Departamento', 'Estado', 'Acción sugerida'],
							missingRows,
						)}
						${reportPreview(
							'Incidencias pendientes',
							'Ajustes y anomalías pendientes de revisar.',
							['Empleado', 'Fecha', 'Tipo', 'Detalle', 'Estado'],
							pendingIncidentRows,
						)}
						${reportPreview(
							'Vacaciones aprobadas/pendientes',
							'Próximas solicitudes con impacto en planificación.',
							['Empleado', 'Rango', 'Días', 'Estado', 'Comentario'],
							vacationRows,
						)}
					</div>
				</section>
				<section class="panel top-gap">
					<div class="panel-heading">
						<div>
							<h2>Programar informe</h2>
							<p class="helper-text">En producción estos informes se enviarían automáticamente por email.</p>
						</div>
					</div>
					<form id="report-schedule-form" class="form-grid report-schedule-form">
						<label class="field">
							<span>Tipo de informe</span>
							<select name="reportType">
								<option value="Resumen semanal">Resumen semanal</option>
								<option value="Resumen mensual">Resumen mensual</option>
								<option value="Incidencias pendientes">Incidencias pendientes</option>
								<option value="Fichajes incompletos">Fichajes incompletos</option>
							</select>
						</label>
						<label class="field">
							<span>Frecuencia</span>
							<select name="frequency">
								<option value="Semanal">Semanal</option>
								<option value="Mensual">Mensual</option>
							</select>
						</label>
						<label class="field">
							<span>Día de envío</span>
							<select name="sendDay">
								<option value="Lunes">Lunes</option>
								<option value="Martes">Martes</option>
								<option value="Miércoles">Miércoles</option>
								<option value="Jueves">Jueves</option>
								<option value="Viernes">Viernes</option>
								<option value="Día 1">Día 1</option>
								<option value="Día 5">Día 5</option>
								<option value="Día 10">Día 10</option>
							</select>
						</label>
						<label class="field">
							<span>Destinatario email</span>
							<input type="email" name="recipient" value="responsable.vacaciones@empresa-demo.es" required />
						</label>
						<label class="field">
							<span>Formato</span>
							<select name="format">
								<option value="CSV">CSV</option>
								<option value="PDF">PDF</option>
								<option value="CSV + PDF">CSV + PDF</option>
							</select>
						</label>
						<button class="button button-primary" type="submit">Guardar programación</button>
					</form>
				</section>
				<section class="panel top-gap">
					<h2>Informes programados</h2>
					${renderScheduledReportsTable()}
				</section>
			`;
		}

