		function buildExpectedHoursReport(scope: 'week' | 'month', from: string, to: string, employeeId = 'all') {
			const employees = EMPLOYEES.filter((employee) => employeeId === 'all' || employee.id === employeeId);
			const period = scope === 'week'
				? `Semana ${formatDate(from)} - ${formatDate(to)}`
				: monthLabel(from.slice(0, 7));

			return employees.map((employee) => {
				const entries = timeEntries.filter(
					(entry) => entry.employeeId === employee.id && dateInRange(entry.date, from, to),
				);
				const worked = entries.reduce((sum, entry) => sum + workedMinutes(entry), 0);
				const laborDays = businessDaysBetween(from, to);
				const vacationDays = countVacationDaysInRange(employee.id, from, to);
				const expectedDays = Math.max(laborDays - vacationDays, 0);
				const expected = expectedDays * 8 * 60;
				const employeeIncidents = incidents.filter(
					(incident) => incident.employeeId === employee.id && dateInRange(incident.date, from, to),
				).length;
				return [
					employee.name,
					employee.department,
					period,
					formatMinutes(worked),
					formatMinutes(expected),
					formatSignedMinutes(worked - expected),
					String(employeeIncidents),
				];

			});
		}

		function formatSignedMinutes(minutes: number) {
			const sign = minutes > 0 ? '+' : minutes < 0 ? '-' : '';
			return `${sign}${formatMinutes(Math.abs(minutes))}`;
		}

		function monthKey(date: string) {
			return date.slice(0, 7);
		}

		function monthLabel(month: string) {
			const [year, monthIndex] = month.split('-').map(Number);
			return new Date(year, monthIndex - 1, 1).toLocaleDateString('es-ES', {
				month: 'long',
				year: 'numeric',
			});
		}

		function monthRangeFromInput(month: string) {
			const safeMonth = /^\d{4}-\d{2}$/.test(month) ? month : todayIso().slice(0, 7);
			const [year, monthIndex] = safeMonth.split('-').map(Number);
			return {
				from: `${safeMonth}-01`,
				to: isoFromDate(new Date(year, monthIndex, 0)),
			};
		}

		function weekInputValue(date: string) {
			const target = new Date(`${date}T12:00:00`);
			const day = target.getDay() || 7;
			target.setDate(target.getDate() + 4 - day);
			const yearStart = new Date(target.getFullYear(), 0, 1);
			const week = Math.ceil((((target.getTime() - yearStart.getTime()) / 86400000) + 1) / 7);
			return `${target.getFullYear()}-W${String(week).padStart(2, '0')}`;
		}

		function weekRangeFromInput(weekValue: string) {
			const safeWeek = /^\d{4}-W\d{2}$/.test(weekValue) ? weekValue : weekInputValue(todayIso());
			const [yearText, weekText] = safeWeek.split('-W');
			const year = Number(yearText);
			const week = Number(weekText);
			const fourthJan = new Date(year, 0, 4);
			const weekOneOffset = (fourthJan.getDay() + 6) % 7;
			const monday = new Date(fourthJan);
			monday.setDate(fourthJan.getDate() - weekOneOffset + (week - 1) * 7);
			const from = isoFromDate(monday);
			return {
				from,
				to: addDaysIso(from, 6),
			};
		}

