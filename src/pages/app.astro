		function exportTimesheets() {
			const totalDays = diffDays(timeFilters.from, timeFilters.to) + 1;
			if (timeFilters.employeeId === 'all' && totalDays > 31) {
				showToast('Para todos los empleados el máximo es 31 días. Solicita una exportación avanzada.');
				return;
			}
			if (timeFilters.employeeId !== 'all' && totalDays > 92) {
				showToast('Para un empleado concreto el máximo es 3 meses. Solicita una exportación avanzada.');
				return;
			}

			const rows = filteredTimeEntries().map((entry) => ({
				Fecha: formatDate(entry.date),
				Empleado: employeeName(entry.employeeId),
				Entrada: entry.start || '',
				Descansos: formatBreaks(entry),
				Salida: entry.end || '',
				'Tiempo trabajado': formatMinutes(workedMinutes(entry)),
				Estado: entry.status,
			}));

			downloadCsv('fichajes-demo.csv', rows);
			addAudit('Exportación CSV', `Fichajes exportados (${rows.length} registros).`);
			saveAll();
			showToast('CSV de fichajes descargado.');
		}

		function exportTimesheetsFromExportForm() {
			const form = document.querySelector<HTMLFormElement>('#export-timesheet-form');
			if (!form) return;

			const formData = new FormData(form);
			const employeeId = String(formData.get('employeeId') || 'all');
			const from = String(formData.get('from') || startOfMonthIso(new Date()));
			const to = String(formData.get('to') || todayIso());
			const totalDays = diffDays(from, to) + 1;

			if (employeeId === 'all' && totalDays > 31) {
				showToast('Para todos los empleados el máximo es 31 días.');
				return;
			}
			if (employeeId !== 'all' && totalDays > 92) {
				showToast('Para un empleado concreto el máximo es 3 meses.');
				return;
			}

			const rows = timeEntries
				.filter((entry) => employeeId === 'all' || entry.employeeId === employeeId)
				.filter((entry) => dateInRange(entry.date, from, to))
				.map((entry) => ({
					Fecha: formatDate(entry.date),
					Empleado: employeeName(entry.employeeId),
					Entrada: entry.start || '',
					Descansos: formatBreaks(entry),
					Salida: entry.end || '',
					'Tiempo trabajado': formatMinutes(workedMinutes(entry)),
					Estado: entry.status,
				}));

			downloadCsv('fichajes-demo.csv', rows);
			addAudit('Exportación CSV', `Fichajes exportados (${rows.length} registros).`);
			saveAll();
			showToast('CSV de fichajes descargado.');
		}

		function exportHoursReportFromForm() {
			const form = document.querySelector<HTMLFormElement>('#export-hours-report-form');
			if (!form) return;

			const formData = new FormData(form);
			const scope = String(formData.get('scope') || 'week') === 'month' ? 'month' : 'week';
			const employeeId = String(formData.get('employeeId') || 'all');
			const range = scope === 'week'
				? weekRangeFromInput(String(formData.get('week') || weekInputValue(todayIso())))
				: monthRangeFromInput(String(formData.get('month') || todayIso().slice(0, 7)));
			const rows: Record<string, string | number>[] = buildExpectedHoursReport(scope, range.from, range.to, employeeId).map((row) => ({
				Empleado: String(row[0]),
				Departamento: String(row[1]),
				Periodo: String(row[2]),
				'Horas fichadas': String(row[3]),
				'Horas esperadas': String(row[4]),
				Diferencia: String(row[5]),
				Incidencias: String(row[6]),
			}));

			downloadCsv(scope === 'week' ? 'reporte-semanal-demo.csv' : 'reporte-mensual-demo.csv', rows);
			addAudit('Exportación CSV', `Reporte ${scope === 'week' ? 'semanal' : 'mensual'} exportado (${formatDate(range.from)} - ${formatDate(range.to)}).`);
			saveAll();
			showToast('Reporte CSV descargado.');
		}

		function updateExportReportPeriodFields() {
			const form = document.querySelector<HTMLFormElement>('#export-hours-report-form');
			if (!form) return;

			const scope = String(new FormData(form).get('scope') || 'week');
			form.querySelectorAll<HTMLElement>('[data-period-field]').forEach((field) => {
				const visible = field.dataset.periodField === scope;
				field.classList.toggle('hidden', !visible);
			});
		}

		function exportGeneric() {
			const form = document.querySelector<HTMLFormElement>('#export-form');
			if (!form) return;

			const formData = new FormData(form);
			const type = String(formData.get('type') || 'fichajes');
			const employeeId = String(formData.get('employeeId') || 'all');
			const from = String(formData.get('from') || '1900-01-01');
			const to = String(formData.get('to') || '2999-12-31');
			let rows: Record<string, string | number>[] = [];

			if (type === 'fichajes') {
				rows = timeEntries
					.filter((entry) => dateInRange(entry.date, from, to))
					.filter((entry) => employeeId === 'all' || entry.employeeId === employeeId)
					.map((entry) => ({
						Fecha: formatDate(entry.date),
						Empleado: employeeName(entry.employeeId),
						Entrada: entry.start || '',
						Salida: entry.end || '',
						Estado: entry.status,
					}));
			}

			if (type === 'vacaciones') {
				rows = vacations
					.filter((request) => dateInRange(request.from, from, to))
					.filter((request) => employeeId === 'all' || request.employeeId === employeeId)
					.map((request) => ({
						Desde: formatDate(request.from),
						Hasta: formatDate(request.to),
						Empleado: employeeName(request.employeeId),
						'Días laborables': request.days,
						Estado: request.status,
					}));
			}

			if (type === 'incidencias') {
				rows = incidents
					.filter((incident) => dateInRange(incident.date, from, to))
					.filter((incident) => employeeId === 'all' || incident.employeeId === employeeId)
					.map((incident) => ({
						Fecha: formatDate(incident.date),
						Empleado: employeeName(incident.employeeId),
						Tipo: incident.type,
						Estado: incident.status,
						Detalle: incident.detail,
					}));
			}

			if (type === 'auditoria') {
				rows = auditLog
					.filter((entry) => dateInRange(entry.at.slice(0, 10), from, to))
					.map((entry) => ({
						Fecha: formatDateTime(entry.at),
						Usuario: entry.user,
						Acción: entry.action,
						Detalle: entry.detail,
					}));
			}

			downloadCsv(`${type}-demo.csv`, rows);
			addAudit('Exportación CSV', `${type} exportado (${rows.length} registros).`);
			saveAll();
			showToast('CSV descargado.');
		}

		function loadDemoData() {
			const defaults = createDefaults();
			if (localStorage.getItem(KEYS.demoVersion) !== DEMO_VERSION) {
				timeEntries = defaults.timeEntries;
				vacations = defaults.vacations;
				incidents = defaults.incidents;
				holidays = defaults.holidays;
				scheduledReports = defaults.scheduledReports;
				users = defaults.users;
				auditLog = defaults.auditLog;
				saveAll();
				return;
			}

			timeEntries = readCollection(KEYS.timeEntries, defaults.timeEntries);
			vacations = readCollection(KEYS.vacations, defaults.vacations);
			incidents = readCollection(KEYS.incidents, defaults.incidents);
			holidays = readCollection(KEYS.holidays, defaults.holidays);
			scheduledReports = readCollection(KEYS.scheduledReports, defaults.scheduledReports);
			users = readCollection(KEYS.users, defaults.users);
			auditLog = readCollection(KEYS.audit, defaults.auditLog);
			saveAll();
		}

