		function renderCalendar() {
			const employee = currentEmployee();
			const year = calendarCursor.getFullYear();
			const month = calendarCursor.getMonth();
			const monthKey = isoFromDate(new Date(year, month, 1)).slice(0, 7);
			const monthEntries = timeEntries.filter((entry) => entry.employeeId === employee.id && entry.date.startsWith(monthKey));
			const monthWorked = monthEntries.reduce((sum, entry) => sum + workedMinutes(entry), 0);
			const monthIncidents = monthEntries.filter((entry) => entry.status === 'incidencia').length;
			const first = new Date(year, month, 1);
			const startOffset = (first.getDay() + 6) % 7;
			const start = new Date(year, month, 1 - startOffset);
			const cells = Array.from({ length: 42 }, (_, index) => {
				const date = new Date(start);
				date.setDate(start.getDate() + index);
				const iso = isoFromDate(date);
				const dayStatus = statusForDay(employee.id, iso);
				const isCurrentMonth = date.getMonth() === month;
				return `
					<button
						class="calendar-day status-${statusClass(dayStatus)} ${isCurrentMonth ? '' : 'is-muted'} ${selectedCalendarDay === iso ? 'is-selected' : ''}"
						type="button"
						data-action="calendar-day"
						data-date="${iso}"
					>
						<strong>${date.getDate()}</strong>
						<span class="calendar-day-label" title="${STATUS_LABELS[dayStatus] || dayStatus}">${calendarStatusLabel(dayStatus)}</span>
					</button>
				`;
			}).join('');

			return `
				${sectionTitle('Calendario', 'Consulta tus registros del mes, vacaciones e incidencias. Pulsa un día para ver el detalle.')}
				<section class="panel calendar-panel">
					<div class="calendar-toolbar">
						<button class="button button-secondary button-small" type="button" data-action="calendar-prev">Mes anterior</button>
						<h2>${calendarCursor.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}</h2>
						<button class="button button-secondary button-small" type="button" data-action="calendar-next">Mes siguiente</button>
					</div>
					${statusLegend(['correcto', 'incidencia', 'festivo', 'vacaciones', 'pendiente', 'sin fichaje', 'fin de semana'])}
					<div class="calendar-grid" aria-label="Calendario mensual">
						${['L', 'M', 'X', 'J', 'V', 'S', 'D'].map((day) => `<div class="calendar-head">${day}</div>`).join('')}
						${cells}
					</div>
					${selectedCalendarDay ? `<div class="top-gap">
						${renderDayDetail(employee.id, selectedCalendarDay, true)}
					</div>` : ''}
					<div class="history-summary calendar-summary">
						${metricCard('Días con fichaje', String(monthEntries.length), monthEntries.length ? 'correcto' : 'sin fichaje')}
						${metricCard('Horas registradas', formatMinutes(monthWorked), 'trabajando')}
						${metricCard('Incidencias', String(monthIncidents), monthIncidents ? 'incidencia' : 'correcto')}
					</div>
				</section>
			`;
		}

		function renderHistory() {
			const employee = currentEmployee();
			const rows = timeEntries
				.filter((entry) => entry.employeeId === employee.id && entry.date.startsWith(historyMonth))
				.sort((a, b) => b.date.localeCompare(a.date));
			const incidentRows = rows.filter((entry) => entry.status === 'incidencia').length;
			const totalWorked = rows.reduce((sum, entry) => sum + workedMinutes(entry), 0);

			return `
				${sectionTitle('Mi historial', 'Consulta tus fichajes por mes. Cada día se puede desplegar para revisar el detalle.')}
				<section class="panel">
					<form id="history-filter-form" class="form-grid compact-form">
						<label class="field">
							<span>Mes</span>
							<input type="month" name="month" value="${historyMonth}" />
						</label>
						<button class="button button-secondary" type="submit">Filtrar</button>
					</form>
					<div class="history-summary">
						${metricCard('Días con fichaje', String(rows.length), rows.length ? 'correcto' : 'sin fichaje')}
						${metricCard('Horas registradas', formatMinutes(totalWorked), 'trabajando')}
						${metricCard('Incidencias', String(incidentRows), incidentRows ? 'incidencia' : 'correcto')}
					</div>
				</section>
				<section class="panel top-gap">
					<h2>Fichajes del mes</h2>
					${rows.length ? rows
						.map(
							(entry) => `
								<details class="record-detail">
									<summary>
										<span>
											<strong>${formatDate(entry.date)}</strong>
											<small>${entry.start || '--:--'} - ${entry.end || 'sin salida'} · ${formatMinutes(workedMinutes(entry))}</small>
										</span>
										${pill(entry.status)}
									</summary>
									${renderDayDetail(employee.id, entry.date)}
								</details>
							`,
						)
						.join('') : emptyState('No hay fichajes para el mes seleccionado.')}
				</section>
			`;
		}

		function renderEmployeeVacations() {
			const employee = currentEmployee();
			const balance = vacationBalance(employee.id);
			const requests = vacations
				.filter((request) => request.employeeId === employee.id)
				.sort((a, b) => b.createdAt.localeCompare(a.createdAt));
			const filteredRequests = filterEmployeeAbsenceRequests(requests, employeeAbsenceFilter);
			const usedVacationDays = balance.enjoyed + balance.futureApproved + balance.pending;
			const progress = employee.vacationDays
				? Math.min((usedVacationDays / employee.vacationDays) * 100, 100)
				: 0;

			return `
				<div class="employee-v2-page employee-v2-absence-page">
					<header class="employee-v2-header">
						<h1>Ausencias</h1>
						<span>Solicita vacaciones, permisos y otras ausencias.</span>
					</header>

					<section class="employee-v2-absence-balance">
						<div>
							<span>Saldo de vacaciones</span>
							<strong>${balance.available} días disponibles</strong>
							<p>Este saldo solo corresponde al tipo Vacaciones.</p>
						</div>
						<div class="employee-v2-absence-progress" aria-label="Vacaciones comprometidas">
							<span style="width: ${progress}%"></span>
						</div>
						<div class="employee-v2-summary-grid">
							<div class="employee-v2-summary-item">
								<span>Disponibles</span>
								<strong>${balance.available} días</strong>
							</div>
							<div class="employee-v2-summary-item">
								<span>Disfrutados</span>
								<strong>${balance.enjoyed} días</strong>
							</div>
							<div class="employee-v2-summary-item">
								<span>Aprobadas futuras</span>
								<strong>${balance.futureApproved} días</strong>
							</div>
							<div class="employee-v2-summary-item">
								<span>Pendientes</span>
								<strong>${balance.pending} días</strong>
							</div>
						</div>
					</section>

					<button class="button button-primary employee-v2-absence-launcher" type="button" data-action="toggle-absence-form">
						Nueva solicitud
					</button>

					<section class="employee-v2-absence-form ${employeeAbsenceFormOpen ? '' : 'hidden'}">
						<form id="absence-request-form">
							<label class="field">
								<span>Tipo de ausencia</span>
								<select name="absenceTypeId">
									${ABSENCE_TYPES.filter((type) => type.active).map((type) => `
										<option value="${type.id}" ${type.id === DEFAULT_ABSENCE_TYPE_ID ? 'selected' : ''}>${escapeHtml(type.name)}</option>
									`).join('')}
