		function adminAbsenceMetrics() {
			const today = todayIso();
			const usedTypes = new Set(vacations.map((request) => resolveAbsenceTypeId(request))).size;
			return {
				pending: vacations.filter((request) => request.status === 'pendiente').length,
				absentToday: vacations.filter((request) => request.status === 'aprobada' && isDateWithin(today, request.from, request.to)).length,
				upcoming: vacations.filter((request) => request.status === 'aprobada' && request.from > today).length,
				usedTypes,
			};
		}

		function adminAbsenceMetric(label: string, value: string, hint: string, tone: string) {
			return `
				<div class="admin-v2-absence-metric metric-${tone}">
					<span>${label}</span>
					<strong>${value}</strong>
					<small>${hint}</small>
				</div>
			`;
		}

		function adminAbsenceRequests() {
			return vacations
				.slice()
				.filter(adminAbsenceMatchesFilters)
				.sort(adminAbsenceSort);
		}

		function adminAbsenceMatchesFilters(request: VacationRequest) {
			const employee = employeeById(request.employeeId);
			const user = adminAbsenceUser(request.employeeId);
			const query = adminAbsenceSearch.trim().toLowerCase();

			if (adminAbsenceStatus !== 'all' && request.status !== adminAbsenceStatus) return false;
			if (adminAbsenceType !== 'all' && resolveAbsenceTypeId(request) !== adminAbsenceType) return false;
			if (adminAbsenceDepartment !== 'all' && employee?.department !== adminAbsenceDepartment) return false;
			if (adminAbsencePeriod === 'today' && !isDateWithin(todayIso(), request.from, request.to)) return false;
			if (adminAbsencePeriod === 'upcoming' && request.from <= todayIso()) return false;
			if (adminAbsencePeriod === 'past' && request.to >= todayIso()) return false;

			if (!query) return true;

			return [
				employee?.name || employeeName(request.employeeId),
				employee?.department || '',
				user?.email || '',
			].some((value) => value.toLowerCase().includes(query));
		}

		function adminAbsenceSort(first: VacationRequest, second: VacationRequest) {
			const rank = (request: VacationRequest) => {
				if (request.status === 'pendiente') return 0;
				if (request.status === 'aprobada' && request.from > todayIso()) return 1;
				return 2;
			};
			const rankDiff = rank(first) - rank(second);
			if (rankDiff) return rankDiff;
			if (rank(first) === 1) {
				const dateDiff = first.from.localeCompare(second.from);
				if (dateDiff) return dateDiff;
			}
			return second.createdAt.localeCompare(first.createdAt);
		}

		function adminSelectedAbsence(requests: VacationRequest[]) {
			if (!requests.length) {
				selectedAdminAbsenceId = '';
				return undefined;
			}
			const selected = requests.find((request) => request.id === selectedAdminAbsenceId);
			if (selected) return selected;
			selectedAdminAbsenceId = requests[0].id;
			return requests[0];
		}

