		function cancelEmployeeVacation(id: string) {
			const employee = currentEmployee();
			const request = vacations.find((item) => item.id === id && item.employeeId === employee.id);

			if (!request || !canCancelEmployeeVacation(request)) {
				showToast('Esta solicitud ya no se puede cancelar.');
				return;
			}

			const wasApproved = request.status === 'aprobada';
			const isVacation = resolveAbsenceTypeId(request) === DEFAULT_ABSENCE_TYPE_ID;
			const typeName = absenceTypeName(request);
			request.status = 'cancelada';
			request.decidedAt = new Date().toISOString();
			addAudit(
				wasApproved && isVacation ? 'Vacaciones canceladas' : 'Solicitud cancelada',
				`${employee.name}: ${typeName} ${absenceRequestDateLabel(request)} (${absenceRequestDurationLabel(request)}).`,
			);
			saveAll();
			showToast(wasApproved && isVacation ? 'Vacaciones futuras canceladas.' : 'Solicitud de ausencia cancelada.');
			renderPage();
		}

