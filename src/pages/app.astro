		function readCollection<T>(key: string, fallback: T[]): T[] {
			const raw = localStorage.getItem(key);
			if (!raw) return fallback;

			try {
				const parsed = JSON.parse(raw) as T[];
				return Array.isArray(parsed) ? parsed : fallback;
			} catch {
				return fallback;
			}
		}

