			const reminderHref = vacationReminderMailto(request);
			return `
				<div class="vacation-card status-border-${statusClass(request.status)}">
					<div class="vacation-card-main">
						<span class="meta-label">${days} días laborables solicitados</span>
						<strong>${formatDate(request.from)} - ${formatDate(request.to)}</strong>
						${request.comment ? `<span>${escapeHtml(request.comment)}</span>` : ''}
					</div>
					<div class="vacation-card-side">
						${pill(request.status)}
						<div class="vacation-card-actions">
							${request.status === 'pendiente' ? `<a class="button button-secondary button-small" href="${reminderHref}">Enviar recordatorio</a>` : ''}
							${canCancel ? `<button class="button button-danger button-small" type="button" data-action="cancel-employee-vacation" data-id="${request.id}">${request.status === 'aprobada' ? 'Cancelar vacaciones' : 'Cancelar solicitud'}</button>` : ''}
						</div>
