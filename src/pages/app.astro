		function performPunch() {
			const employee = currentEmployee();
			const now = currentTime();
			let entry = todayEntry(employee.id);

			if (!entry) {
				entry = {
					id: uniqueId('entry'),
					employeeId: employee.id,
					date: todayIso(),
					start: now,
					breaks: [],
					status: 'correcto',
				};
				timeEntries.push(entry);
				addAudit('Fichaje de entrada', `${employee.name} registró entrada a las ${now}`);
			} else if (activeBreak(entry)) {
				const lastBreak = activeBreak(entry);
				if (lastBreak) lastBreak.end = now;
				addAudit('Fin de pausa', `${employee.name} volvió de pausa a las ${now}`);
			} else if (entry.breaks.length === 0) {
				entry.breaks.push({ start: now });
				addAudit('Inicio de pausa', `${employee.name} inició pausa a las ${now}`);
			} else {
				entry.end = now;
				entry.status = entry.status === 'incidencia' ? 'incidencia' : 'correcto';
				addAudit('Fichaje de salida', `${employee.name} registró salida a las ${now}`);
			}

			saveAll();
			renderPage();
		}

		function addQuickPause(minutes: number) {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);

			if (!entry?.start || entry.end || activeBreak(entry)) {
				showToast('La pausa rápida requiere una jornada activa sin pausa abierta.');
				return;
			}

			const start = currentTime();
			const end = addMinutesToTime(start, minutes);
			entry.breaks.push({ start, end });
			addAudit('Pausa rápida', `${employee.name} registró una pausa de ${minutes} minutos.`);
			saveAll();
			renderPage();
		}

		function toggleManualForm() {
			document.querySelector('#manual-adjustment')?.classList.toggle('hidden');
		}

		function saveManualAdjustment(form: HTMLFormElement) {
			const employee = currentEmployee();
			const formData = new FormData(form);
			const type = String(formData.get('type') || '');
			const date = String(formData.get('date') || todayIso());
			const time = String(formData.get('time') || currentTime());
			const reason = String(formData.get('reason') || '').trim();

			if (!reason) {
				showToast('El motivo es obligatorio para guardar el ajuste.');
				return;
			}

			let entry = findEntry(employee.id, date);
			if (!entry) {
				entry = {
					id: uniqueId('entry'),
					employeeId: employee.id,
					date,
					breaks: [],
					status: 'incidencia',
				};
				timeEntries.push(entry);
			}
			entry.status = 'incidencia';
			entry.notes = `${type} a las ${time}: ${reason}`;

			incidents.push({
				id: uniqueId('incident'),
				employeeId: employee.id,
				date,
				type,
				detail: `${time} · ${reason}`,
				status: 'pendiente',
				createdAt: new Date().toISOString(),
			});
			addAudit('Ajuste manual', `${employee.name}: ${type} el ${formatDate(date)} a las ${time}.`);
			saveAll();
			showToast('Ajuste guardado y enviado a incidencias.');
			renderPage();
		}

		function saveVacationRequest(form: HTMLFormElement) {
			const employee = currentEmployee();
			const formData = new FormData(form);
			const from = String(formData.get('from') || '');
			const to = String(formData.get('to') || '');
			const comment = String(formData.get('comment') || '').trim();

			if (!from || !to || from > to) {
				showToast('Revisa las fechas de la solicitud.');
				return;
			}

			const request: VacationRequest = {
				id: uniqueId('vac'),
				employeeId: employee.id,
				from,
				to,
				days: businessDaysBetween(from, to),
				status: 'pendiente',
				comment,
				createdAt: new Date().toISOString(),
			};

			vacations.push(request);
			addAudit('Solicitud de vacaciones', `${employee.name} solicitó ${request.days} días.`);
			saveAll();
			showToast('Solicitud creada. En producción se enviaría un correo al responsable.');
			renderPage();
		}

		function saveHoliday(form: HTMLFormElement) {
			const formData = new FormData(form);
			const date = String(formData.get('date') || '');
			const name = String(formData.get('name') || '').trim();
			const center = String(formData.get('center') || 'Valencia').trim();

			if (!date || !name || !center) {
				showToast('Completa fecha, nombre y centro.');
				return;
			}

			holidays.push({ id: uniqueId('holiday'), date, name, center });
			addAudit('Festivo añadido', `${name} en ${center} (${formatDate(date)}).`);
			saveAll();
			showToast('Festivo añadido al calendario.');
			renderPage();
		}

		function applyTimeFilters(form: HTMLFormElement) {
			const formData = new FormData(form);
			timeFilters = {
				employeeId: String(formData.get('employeeId') || 'all'),
				from: String(formData.get('from') || startOfMonthIso(new Date())),
				to: String(formData.get('to') || todayIso()),
				status: String(formData.get('status') || 'all'),
			};
			renderPage();
		}

		function reviewIncident(id: string) {
			const incident = incidents.find((item) => item.id === id);
			if (!incident || incident.status === 'revisada') return;

			incident.status = 'revisada';
			incident.reviewedAt = new Date().toISOString();
			addAudit('Incidencia revisada', `${employeeName(incident.employeeId)} · ${incident.type}`);
			saveAll();
			showToast('Incidencia marcada como revisada.');
			renderPage();
		}

		function selectVacation(id: string) {
			selectedVacationId = id;
			renderPage();
		}

		function resolveVacation(status: VacationStatus) {
			const request = vacations.find((item) => item.id === selectedVacationId);
			if (!request || request.status !== 'pendiente') return;

			if (status === 'denegada') {
				const reason = document.querySelector<HTMLTextAreaElement>('#denial-reason')?.value.trim() || '';
				if (!reason) {
					showToast('El motivo es obligatorio para denegar una solicitud.');
					return;
				}
				request.denialReason = reason;
			}

			request.status = status;
			request.decidedAt = new Date().toISOString();
			addAudit(
				status === 'aprobada' ? 'Vacaciones aprobadas' : 'Vacaciones denegadas',
				`${employeeName(request.employeeId)} · ${formatDate(request.from)} - ${formatDate(request.to)}`,
			);
			saveAll();
			showToast('Solicitud actualizada. Email simulado enviado al empleado.');
			renderPage();
		}

		function changeCalendarMonth(offset: number) {
			calendarCursor = new Date(calendarCursor.getFullYear(), calendarCursor.getMonth() + offset, 1);
			selectedCalendarDay = isoFromDate(new Date(calendarCursor.getFullYear(), calendarCursor.getMonth(), 1));
			renderPage();
		}

		function selectCalendarDay(date: string) {
			selectedCalendarDay = date;
			renderPage();
		}

		function exportTimesheets() {
			const totalDays = diffDays(timeFilters.from, timeFilters.to) + 1;
			if (timeFilters.employeeId === 'all' && totalDays > 31) {
				showToast('Para todos los empleados el máximo es 31 días. Solicita una exportación avanzada.');
				return;
			}
			if (timeFilters.employeeId !== 'all' && totalDays > 92) {
				showToast('Para un empleado concreto el máximo es 3 meses. Solicita una exportación avanzada.');
				return;
			}

			const rows = filteredTimeEntries().map((entry) => ({
				fecha: entry.date,
				empleado: employeeName(entry.employeeId),
				entrada: entry.start || '',
				pausas: formatBreaks(entry),
				salida: entry.end || '',
				tiempo: formatMinutes(workedMinutes(entry)),
				estado: entry.status,
			}));

			downloadCsv('fichajes-demo.csv', rows);
			addAudit('Exportación CSV', `Fichajes exportados (${rows.length} registros).`);
			saveAll();
			showToast('CSV de fichajes descargado.');
		}

		function exportGeneric() {
			const form = document.querySelector<HTMLFormElement>('#export-form');
			if (!form) return;

			const formData = new FormData(form);
			const type = String(formData.get('type') || 'fichajes');
			const employeeId = String(formData.get('employeeId') || 'all');
			const from = String(formData.get('from') || '1900-01-01');
			const to = String(formData.get('to') || '2999-12-31');
			let rows: Record<string, string | number>[] = [];

			if (type === 'fichajes') {
				rows = timeEntries
					.filter((entry) => dateInRange(entry.date, from, to))
					.filter((entry) => employeeId === 'all' || entry.employeeId === employeeId)
					.map((entry) => ({
						fecha: entry.date,
						empleado: employeeName(entry.employeeId),
						entrada: entry.start || '',
						salida: entry.end || '',
						estado: entry.status,
					}));
			}

			if (type === 'vacaciones') {
				rows = vacations
					.filter((request) => dateInRange(request.from, from, to))
					.filter((request) => employeeId === 'all' || request.employeeId === employeeId)
					.map((request) => ({
						desde: request.from,
						hasta: request.to,
						empleado: employeeName(request.employeeId),
						dias: request.days,
						estado: request.status,
					}));
			}

			if (type === 'incidencias') {
				rows = incidents
					.filter((incident) => dateInRange(incident.date, from, to))
					.filter((incident) => employeeId === 'all' || incident.employeeId === employeeId)
					.map((incident) => ({
						fecha: incident.date,
						empleado: employeeName(incident.employeeId),
						tipo: incident.type,
						estado: incident.status,
						detalle: incident.detail,
					}));
			}

			if (type === 'auditoria') {
				rows = auditLog
					.filter((entry) => dateInRange(entry.at.slice(0, 10), from, to))
					.map((entry) => ({
						fecha: formatDateTime(entry.at),
						usuario: entry.user,
						accion: entry.action,
						detalle: entry.detail,
					}));
			}

			downloadCsv(`${type}-demo.csv`, rows);
			addAudit('Exportación CSV', `${type} exportado (${rows.length} registros).`);
			saveAll();
			showToast('CSV descargado.');
		}

		function loadDemoData() {
			const defaults = createDefaults();
			timeEntries = readCollection(KEYS.timeEntries, defaults.timeEntries);
			vacations = readCollection(KEYS.vacations, defaults.vacations);
			incidents = readCollection(KEYS.incidents, defaults.incidents);
			holidays = readCollection(KEYS.holidays, defaults.holidays);
			auditLog = readCollection(KEYS.audit, defaults.auditLog);
			saveAll();
		}

		function resetDemoData() {
			const defaults = createDefaults();
			timeEntries = defaults.timeEntries;
			vacations = defaults.vacations;
			incidents = defaults.incidents;
			holidays = defaults.holidays;
			auditLog = defaults.auditLog;
			addAudit('Demo restablecida', 'Se restauraron los datos ficticios iniciales.');
			saveAll();
			renderPage();
		}

