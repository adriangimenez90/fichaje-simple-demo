---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FichajeSimple | Aplicación">
	<div id="app-shell" class="app-shell" hidden>
		<header class="app-header">
			<div class="header-left">
				<div class="brand-lockup" aria-label="FichajeSimple">
					<span class="brand-mark" aria-hidden="true">FS</span>
					<div>
						<strong>FichajeSimple</strong>
						<span class="muted-line">Sourcing Demo S.L. · Valencia</span>
					</div>
				</div>
				<div class="company-chip">
					<span>Empresa demo</span>
					<strong>Sourcing Demo S.L.</strong>
				</div>
			</div>

			<div class="header-actions">
				<div id="user-chip" class="user-chip"></div>
				<button id="reset-demo" class="button button-ghost button-small" type="button">
					Restablecer demo
				</button>
				<button id="logout" class="button button-secondary button-small" type="button">
					Cerrar sesión
				</button>
			</div>
		</header>

		<aside class="sidebar" aria-label="Navegación principal">
			<nav id="sidebar-nav" class="sidebar-nav"></nav>
		</aside>

		<main id="app-main" class="app-main" tabindex="-1">
			<div id="app-content"></div>
		</main>

		<nav id="mobile-nav" class="mobile-nav" aria-label="Navegación móvil"></nav>
	</div>

	<div id="toast" class="toast hidden" role="status" aria-live="polite"></div>

	<script>
		type Role = 'administrador' | 'empleado';
		type EntryStatus = 'correcto' | 'incidencia' | 'pendiente' | 'sin fichaje';
		type VacationStatus = 'pendiente' | 'aprobada' | 'denegada';
		type IncidentStatus = 'pendiente' | 'revisada';

		type Session = {
			id: string;
			email: string;
			name: string;
			role: Role;
			employeeId?: string;
		};

		type Employee = {
			id: string;
			name: string;
			department: string;
			vacationDays: number;
		};

		type TimeBreak = {
			start: string;
			end?: string;
		};

		type TimeEntry = {
			id: string;
			employeeId: string;
			date: string;
			start?: string;
			breaks: TimeBreak[];
			end?: string;
			status: EntryStatus;
			notes?: string;
		};

		type VacationRequest = {
			id: string;
			employeeId: string;
			from: string;
			to: string;
			days: number;
			status: VacationStatus;
			comment?: string;
			denialReason?: string;
			createdAt: string;
			decidedAt?: string;
		};

		type Incident = {
			id: string;
			employeeId: string;
			date: string;
			type: string;
			detail: string;
			status: IncidentStatus;
			createdAt: string;
			reviewedAt?: string;
		};

		type Holiday = {
			id: string;
			date: string;
			name: string;
			center: string;
		};

		type AuditEntry = {
			id: string;
			at: string;
			user: string;
			action: string;
			detail: string;
		};

		const KEYS = {
			session: 'fs_session',
			timeEntries: 'fs_timeEntries',
			vacations: 'fs_vacations',
			incidents: 'fs_incidents',
			holidays: 'fs_holidays',
			audit: 'fs_audit',
		} as const;

		const EMPLOYEES: Employee[] = [
			{ id: 'ana', name: 'Ana Martínez', department: 'Administración', vacationDays: 22 },
			{ id: 'carlos', name: 'Carlos Gómez', department: 'Operaciones', vacationDays: 22 },
			{ id: 'laura', name: 'Laura Pérez', department: 'Responsable', vacationDays: 22 },
			{ id: 'miguel', name: 'Miguel Torres', department: 'Almacén', vacationDays: 22 },
			{ id: 'sara', name: 'Sara Navarro', department: 'Logística', vacationDays: 22 },
			{ id: 'javier', name: 'Javier Ruiz', department: 'Reparto', vacationDays: 22 },
			{ id: 'marta', name: 'Marta Soler', department: 'Atención al cliente', vacationDays: 22 },
		];

		const EMPLOYEE_VIEWS = [
			{ id: 'inicio', label: 'Inicio' },
			{ id: 'fichar', label: 'Fichar' },
			{ id: 'calendario', label: 'Calendario' },
			{ id: 'historial', label: 'Historial' },
			{ id: 'vacaciones', label: 'Vacaciones' },
		];

		const ADMIN_VIEWS = [
			{ id: 'dashboard', label: 'Dashboard' },
			{ id: 'fichajes', label: 'Fichajes' },
			{ id: 'incidencias', label: 'Incidencias' },
			{ id: 'vacaciones-admin', label: 'Vacaciones' },
			{ id: 'festivos', label: 'Festivos' },
			{ id: 'exportaciones', label: 'Exportaciones' },
			{ id: 'auditoria', label: 'Auditoría' },
			{ id: 'configuracion', label: 'Configuración' },
		];

		const STATUS_LABELS: Record<string, string> = {
			correcto: 'Correcto',
			incidencia: 'Incidencia',
			pendiente: 'Pendiente',
			'sin fichaje': 'Sin fichaje',
			festivo: 'Festivo',
			vacaciones: 'Vacaciones',
			'fin de semana': 'Fin de semana',
			aprobada: 'Aprobada',
			denegada: 'Denegada',
			revisada: 'Revisada',
			trabajando: 'Trabajando',
			pausa: 'En pausa',
		};

		let session: Session;
		let activeView = 'inicio';
		let calendarCursor = new Date();
		let selectedCalendarDay = todayIso();
		let selectedVacationId = '';
		let historyMonth = todayIso().slice(0, 7);
		let timeFilters = {
			employeeId: 'all',
			from: startOfMonthIso(new Date()),
			to: todayIso(),
			status: 'all',
		};

		let timeEntries: TimeEntry[] = [];
		let vacations: VacationRequest[] = [];
		let incidents: Incident[] = [];
		let holidays: Holiday[] = [];
		let auditLog: AuditEntry[] = [];

		const shell = document.querySelector<HTMLDivElement>('#app-shell');
		const content = document.querySelector<HTMLDivElement>('#app-content');
		const sidebarNav = document.querySelector<HTMLElement>('#sidebar-nav');
		const mobileNav = document.querySelector<HTMLElement>('#mobile-nav');
		const userChip = document.querySelector<HTMLElement>('#user-chip');
		const toast = document.querySelector<HTMLElement>('#toast');

		init();

		function init() {
			const rawSession = localStorage.getItem(KEYS.session);

			if (!rawSession) {
				window.location.href = '/';
				return;
			}

			try {
				session = JSON.parse(rawSession) as Session;
			} catch {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
				return;
			}

			loadDemoData();
			activeView = session.role === 'administrador' ? 'dashboard' : 'inicio';
			renderShell();
			renderPage();
			bindGlobalEvents();
			if (shell) shell.hidden = false;
		}

		function bindGlobalEvents() {
			document.querySelector('#logout')?.addEventListener('click', () => {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
			});

			document.querySelector('#reset-demo')?.addEventListener('click', () => {
				resetDemoData();
				showToast('Demo restablecida con datos ficticios iniciales.');
			});

			document.addEventListener('click', (event) => {
				const target = event.target as HTMLElement;
				const viewButton = target.closest<HTMLElement>('[data-view]');
				const actionButton = target.closest<HTMLElement>('[data-action]');

				if (viewButton) {
					activeView = viewButton.dataset.view || activeView;
					renderPage();
					renderNav();
					document.querySelector<HTMLElement>('#app-main')?.focus();
					return;
				}

				if (!actionButton) return;

				const action = actionButton.dataset.action;

				if (action === 'punch') performPunch();
				if (action === 'quick-pause') addQuickPause(Number(actionButton.dataset.minutes || 15));
				if (action === 'toggle-manual') toggleManualForm();
				if (action === 'calendar-prev') changeCalendarMonth(-1);
				if (action === 'calendar-next') changeCalendarMonth(1);
				if (action === 'calendar-day') selectCalendarDay(actionButton.dataset.date || todayIso());
				if (action === 'review-incident') reviewIncident(actionButton.dataset.id || '');
				if (action === 'select-vacation') selectVacation(actionButton.dataset.id || '');
				if (action === 'approve-vacation') resolveVacation('aprobada');
				if (action === 'deny-vacation') resolveVacation('denegada');
				if (action === 'export-timesheets') exportTimesheets();
				if (action === 'simulate-pdf') showToast('PDF simulado listo. En producción se generaría un documento firmado.');
				if (action === 'export-generic') exportGeneric();
			});

			document.addEventListener('submit', (event) => {
				const form = event.target as HTMLFormElement;

				if (form.matches('#manual-form')) {
					event.preventDefault();
					saveManualAdjustment(form);
				}

				if (form.matches('#vacation-request-form')) {
					event.preventDefault();
					saveVacationRequest(form);
				}

				if (form.matches('#holiday-form')) {
					event.preventDefault();
					saveHoliday(form);
				}

				if (form.matches('#time-filter-form')) {
					event.preventDefault();
					applyTimeFilters(form);
				}

				if (form.matches('#history-filter-form')) {
					event.preventDefault();
					const formData = new FormData(form);
					historyMonth = String(formData.get('month') || historyMonth);
					renderPage();
				}
			});
		}

		function renderShell() {
			if (userChip) {
				userChip.innerHTML = `
					<span>${session.role === 'administrador' ? 'Administrador' : 'Empleado'}</span>
					<strong>${escapeHtml(session.name)}</strong>
				`;
			}
			renderNav();
		}

		function renderNav() {
			const views = getViews();
			const html = views
				.map(
					(view) => `
						<button
							class="button nav-button"
							type="button"
							data-view="${view.id}"
							aria-current="${activeView === view.id ? 'page' : 'false'}"
						>
							${view.label}
						</button>
					`,
				)
				.join('');

			if (sidebarNav) sidebarNav.innerHTML = html;
			if (mobileNav) mobileNav.innerHTML = html;
		}

		function renderPage() {
			if (!content) return;

			const viewMap: Record<string, () => string> = {
				inicio: renderEmployeeHome,
				fichar: renderPunchClock,
				calendario: renderCalendar,
				historial: renderHistory,
				vacaciones: renderEmployeeVacations,
				dashboard: renderAdminDashboard,
				fichajes: renderAdminTimesheets,
				incidencias: renderAdminIncidents,
				'vacaciones-admin': renderAdminVacations,
				festivos: renderHolidays,
				exportaciones: renderExports,
				auditoria: renderAudit,
				configuracion: renderSettings,
			};

			content.innerHTML = viewMap[activeView]?.() || renderEmployeeHome();
		}

		function renderEmployeeHome() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const status = currentWorkStatus(entry);
			const upcoming = vacations
				.filter(
					(request) =>
						request.employeeId === employee.id &&
						request.to >= todayIso() &&
						(request.status === 'aprobada' || request.status === 'pendiente'),
				)
				.sort((a, b) => a.from.localeCompare(b.from))
				.slice(0, 3);
			const todayIncidents = incidents.filter(
				(incident) => incident.employeeId === employee.id && incident.date === todayIso(),
			);

			return `
				${sectionTitle('Inicio', 'Resumen operativo de tu jornada y próximos permisos.')}
				<div class="grid grid-3">
					${metricCard('Estado actual', status.label, status.key)}
					${metricCard('Tiempo trabajado hoy', formatMinutes(workedMinutes(entry)), 'correcto')}
					${metricCard('Incidencias de hoy', String(todayIncidents.length), todayIncidents.length ? 'incidencia' : 'correcto')}
				</div>
				<div class="grid grid-2 top-gap">
					<section class="panel">
						<h2>Resumen de hoy</h2>
						<div class="summary-list">
							${summaryRow('Entrada', entry?.start || 'Sin registrar')}
							${summaryRow('Pausas', formatBreaks(entry))}
							${summaryRow('Salida', entry?.end || 'Sin registrar')}
							${summaryRow('Estado', pill(status.label, status.key))}
							${summaryRow('Incidencias', todayIncidents.length ? todayIncidents.map((item) => escapeHtml(item.type)).join(', ') : 'Sin incidencias')}
						</div>
					</section>
					<section class="panel">
						<h2>Próximas vacaciones</h2>
						${upcoming.length ? upcoming
							.map(
								(request) => `
									<div class="stat-row">
										<div>
											<strong>${formatDate(request.from)} - ${formatDate(request.to)}</strong>
											<span>${request.days} días · ${escapeHtml(request.comment || 'Sin comentario')}</span>
										</div>
										${pill(request.status)}
									</div>
								`,
							)
							.join('') : emptyState('No tienes vacaciones próximas aprobadas o pendientes.')}
					</section>
				</div>
			`;
		}

		function renderPunchClock() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const status = currentWorkStatus(entry);
			const actionLabel = punchActionLabel(entry);

			return `
				${sectionTitle('Fichar', 'Registra entradas, pausas, salidas y ajustes manuales.')}
				<div class="grid grid-2">
					<section class="panel">
						<h2>Acción principal</h2>
						<button class="button button-primary big-action" type="button" data-action="punch" ${entry?.end ? 'disabled' : ''}>
							${actionLabel}
						</button>
						<div class="summary-list top-gap">
							${summaryRow('Estado', pill(status.label, status.key))}
							${summaryRow('Entrada', entry?.start || 'Sin registrar')}
							${summaryRow('Pausas', formatBreaks(entry))}
							${summaryRow('Salida', entry?.end || 'Sin registrar')}
						</div>
					</section>
					<section class="panel">
						<h2>Acciones rápidas</h2>
						<div class="tab-actions">
							<button class="button button-secondary" type="button" data-action="quick-pause" data-minutes="15">
								Pausa 15 min
							</button>
							<button class="button button-secondary" type="button" data-action="quick-pause" data-minutes="30">
								Pausa 30 min
							</button>
							<button class="button button-ghost" type="button" data-action="toggle-manual">
								Registrar ajuste manual
							</button>
						</div>
						<div id="manual-adjustment" class="manual-box hidden">
							${manualAdjustmentForm()}
						</div>
					</section>
				</div>
			`;
		}

		function renderCalendar() {
			const employee = currentEmployee();
			const year = calendarCursor.getFullYear();
			const month = calendarCursor.getMonth();
			const first = new Date(year, month, 1);
			const startOffset = (first.getDay() + 6) % 7;
			const start = new Date(year, month, 1 - startOffset);
			const cells = Array.from({ length: 42 }, (_, index) => {
				const date = new Date(start);
				date.setDate(start.getDate() + index);
				const iso = isoFromDate(date);
				const dayStatus = statusForDay(employee.id, iso);
				const isCurrentMonth = date.getMonth() === month;
				return `
					<button
						class="calendar-day status-${statusClass(dayStatus)} ${isCurrentMonth ? '' : 'is-muted'} ${selectedCalendarDay === iso ? 'is-selected' : ''}"
						type="button"
						data-action="calendar-day"
						data-date="${iso}"
					>
						<strong>${date.getDate()}</strong>
						<span>${STATUS_LABELS[dayStatus] || dayStatus}</span>
					</button>
				`;
			}).join('');

			return `
				${sectionTitle('Calendario', 'Vista mensual con estados de fichaje, vacaciones y festivos.')}
				<section class="panel">
					<div class="calendar-toolbar">
						<button class="button button-secondary button-small" type="button" data-action="calendar-prev">Mes anterior</button>
						<h2>${calendarCursor.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}</h2>
						<button class="button button-secondary button-small" type="button" data-action="calendar-next">Mes siguiente</button>
					</div>
					<div class="calendar-grid" aria-label="Calendario mensual">
						${['L', 'M', 'X', 'J', 'V', 'S', 'D'].map((day) => `<div class="calendar-head">${day}</div>`).join('')}
						${cells}
					</div>
					<div class="top-gap">
						${renderDayDetail(employee.id, selectedCalendarDay)}
					</div>
				</section>
			`;
		}

		function renderHistory() {
			const employee = currentEmployee();
			const rows = timeEntries
				.filter((entry) => entry.employeeId === employee.id && entry.date.startsWith(historyMonth))
				.sort((a, b) => b.date.localeCompare(a.date));

			return `
				${sectionTitle('Historial', 'Consulta tus fichajes por mes y revisa cada día.')}
				<section class="panel">
					<form id="history-filter-form" class="form-grid compact-form">
						<label class="field">
							<span>Mes</span>
							<input type="month" name="month" value="${historyMonth}" />
						</label>
						<button class="button button-secondary" type="submit">Filtrar</button>
					</form>
				</section>
				<section class="panel top-gap">
					<h2>Fichajes del mes</h2>
					${rows.length ? rows
						.map(
							(entry) => `
								<details class="record-detail">
									<summary>
										<span>${formatDate(entry.date)}</span>
										${pill(entry.status)}
									</summary>
									${renderDayDetail(employee.id, entry.date)}
								</details>
							`,
						)
						.join('') : emptyState('No hay fichajes para el mes seleccionado.')}
				</section>
			`;
		}

		function renderEmployeeVacations() {
			const employee = currentEmployee();
			const balance = vacationBalance(employee.id);
			const requests = vacations
				.filter((request) => request.employeeId === employee.id)
				.sort((a, b) => b.createdAt.localeCompare(a.createdAt));

			return `
				${sectionTitle('Vacaciones', 'Solicita días y revisa el estado de tus permisos.')}
				<div class="grid grid-4">
					${metricCard('Disponibles', String(balance.available), 'correcto')}
					${metricCard('Usados', String(balance.used), 'vacaciones')}
					${metricCard('Pendientes', String(balance.pending), 'pendiente')}
					${metricCard('Denegados', String(balance.denied), 'incidencia')}
				</div>
				<div class="grid grid-2 top-gap">
					<section class="panel">
						<h2>Nueva solicitud</h2>
						<form id="vacation-request-form" class="form-grid">
							<label class="field">
								<span>Fecha desde</span>
								<input type="date" name="from" required />
							</label>
							<label class="field">
								<span>Fecha hasta</span>
								<input type="date" name="to" required />
							</label>
							<label class="field">
								<span>Comentario opcional</span>
								<textarea name="comment" placeholder="Ej. Viaje familiar"></textarea>
							</label>
							<button class="button button-primary" type="submit">Solicitar vacaciones</button>
						</form>
					</section>
					<section class="panel">
						<h2>Mis solicitudes</h2>
						${requests.length ? requests.map(renderVacationRow).join('') : emptyState('Aún no has solicitado vacaciones.')}
					</section>
				</div>
			`;
		}

		function renderAdminDashboard() {
			const today = todayIso();
			const statuses = EMPLOYEES.map((employee) => ({
				employee,
				entry: findEntry(employee.id, today),
			}));
			const workingNow = statuses.filter(({ entry }) => currentWorkStatus(entry).key === 'trabajando').length;
			const inPause = statuses.filter(({ entry }) => currentWorkStatus(entry).key === 'pausa').length;
			const missing = statuses.filter(({ entry }) => !entry?.start).length;
			const pendingIncidents = incidents.filter((incident) => incident.status === 'pendiente').length;
			const pendingVacations = vacations.filter((request) => request.status === 'pendiente').length;

			return `
				${sectionTitle('Dashboard', 'Estado de hoy para Sourcing Demo S.L.')}
				<div class="grid grid-3">
					${metricCard('Empleados activos', String(EMPLOYEES.length), 'correcto')}
					${metricCard('Trabajando ahora', String(workingNow), 'trabajando')}
					${metricCard('En pausa', String(inPause), 'pausa')}
					${metricCard('Sin fichar hoy', String(missing), missing ? 'pendiente' : 'correcto')}
					${metricCard('Incidencias pendientes', String(pendingIncidents), pendingIncidents ? 'incidencia' : 'correcto')}
					${metricCard('Vacaciones pendientes', String(pendingVacations), pendingVacations ? 'pendiente' : 'correcto')}
				</div>
				<section class="panel top-gap">
					<h2>Estado de hoy por empleado</h2>
					<div class="table-wrap">
						<table>
							<thead>
								<tr>
									<th>Empleado</th>
									<th>Departamento</th>
									<th>Entrada</th>
									<th>Pausas</th>
									<th>Salida</th>
									<th>Estado</th>
								</tr>
							</thead>
							<tbody>
								${statuses.map(({ employee, entry }) => `
									<tr>
										<td><strong>${employee.name}</strong></td>
										<td>${employee.department}</td>
										<td>${entry?.start || 'Sin registrar'}</td>
										<td>${formatBreaks(entry)}</td>
										<td>${entry?.end || 'Sin registrar'}</td>
										<td>${pill(currentWorkStatus(entry).label, currentWorkStatus(entry).key)}</td>
									</tr>
								`).join('')}
							</tbody>
						</table>
					</div>
				</section>
			`;
		}

		function renderAdminTimesheets() {
			const rows = filteredTimeEntries();

			return `
				${sectionTitle('Fichajes', 'Filtra registros y exporta CSV con límites de demo.')}
				<section class="panel">
					<form id="time-filter-form" class="form-grid admin-filters">
						<label class="field">
							<span>Empleado</span>
							<select name="employeeId">
								<option value="all" ${timeFilters.employeeId === 'all' ? 'selected' : ''}>Todos los empleados</option>
								${EMPLOYEES.map((employee) => `
									<option value="${employee.id}" ${timeFilters.employeeId === employee.id ? 'selected' : ''}>${employee.name}</option>
								`).join('')}
							</select>
						</label>
						<label class="field">
							<span>Fecha desde</span>
							<input type="date" name="from" value="${timeFilters.from}" />
						</label>
						<label class="field">
							<span>Fecha hasta</span>
							<input type="date" name="to" value="${timeFilters.to}" />
						</label>
						<label class="field">
							<span>Estado</span>
							<select name="status">
								<option value="all" ${timeFilters.status === 'all' ? 'selected' : ''}>Todos</option>
								<option value="correcto" ${timeFilters.status === 'correcto' ? 'selected' : ''}>Correcto</option>
