							<thead>
								<tr>
									<th>Empleado</th>
									<th>Estado</th>
									<th>Entrada</th>
									<th>Salida</th>
									<th>Descanso</th>
									<th>Departamento</th>
								</tr>
							</thead>
							<tbody>
								${filteredStatuses.map(({ employee, entry }) => {
									const status = adminTodayStatus(employee, entry);
									return `
									<tr>
										<td><strong>${employee.name}</strong></td>
										<td>${pill(status.label, status.key)}</td>
										<td>${entry?.start || 'Sin registrar'}</td>
