		function currentEmployee() {
			const employee = EMPLOYEES.find((item) => item.id === session.employeeId);
			return employee || EMPLOYEES[0];
		}

		function employeeById(id: string) {
			return EMPLOYEES.find((employee) => employee.id === id);
		}

		function employeeName(id: string) {
			return EMPLOYEES.find((employee) => employee.id === id)?.name || id;
		}

		function departmentEmployees(department: string) {
			return EMPLOYEES.filter((employee) => employee.department === department);
		}

		function departmentList() {
			return Array.from(new Set(EMPLOYEES.map((employee) => employee.department))).sort((a, b) => a.localeCompare(b));
		}

		function todayEntry(employeeId: string) {
			return findEntry(employeeId, todayIso());
		}

		function findEntry(employeeId: string, date: string) {
			return timeEntries.find((entry) => entry.employeeId === employeeId && entry.date === date);
		}

		function activeBreak(entry?: TimeEntry) {
			return entry?.breaks.find((item) => item.start && !item.end);
		}

		function currentWorkStatus(entry?: TimeEntry) {
			if (!entry?.start) return { label: 'Sin iniciar', key: 'sin-fichaje' };
			if (entry.end) return { label: 'Jornada finalizada', key: 'correcto' };
			if (activeBreak(entry)) return { label: 'En descanso', key: 'pausa' };
			return { label: 'Trabajando', key: 'trabajando' };
		}

		function adminTodayStatus(employee: Employee, entry?: TimeEntry) {
			if (approvedVacationForDate(employee.id, todayIso())) {
				return { label: 'De vacaciones', key: 'vacaciones' };
			}

			const status = currentWorkStatus(entry);
			if (status.key === 'sin-fichaje') return { label: 'Sin fichar', key: 'sin-fichar' };
			return status;
		}

		function approvedVacationForDate(employeeId: string, date: string) {
			return (
				isBusinessDay(date) &&
				vacations.some(
					(request) =>
						request.employeeId === employeeId &&
						request.status === 'aprobada' &&
						isDateWithin(date, request.from, request.to),
				)
			);
		}

		function punchActionLabel(entry?: TimeEntry) {
			if (!entry?.start) return 'Iniciar jornada';
			if (entry.end) return 'Jornada finalizada';
			if (activeBreak(entry)) return 'Finalizar descanso';
			return 'Iniciar descanso';
		}

		function punchHelpText(entry?: TimeEntry) {
			if (!entry?.start) return 'Comienza la jornada de hoy';
			if (entry.end) return 'Todo listo por hoy';
			if (activeBreak(entry)) return 'Vuelve a trabajar';
			return 'Detiene el tiempo de trabajo';
		}

		function checkoutHelpText(entry?: TimeEntry) {
			if (!entry?.start) return 'Primero inicia la jornada';
			if (entry.end) return 'Salida registrada';
			if (activeBreak(entry)) return 'Finaliza el descanso antes';
			return 'Cierra la jornada de hoy';
		}

		function statusForDay(employeeId: string, date: string) {
			const vacation = vacations.find(
				(request) =>
					request.employeeId === employeeId &&
					isActiveVacationRequest(request) &&
					isBusinessDay(date) &&
					isDateWithin(date, request.from, request.to),
			);
			const entry = findEntry(employeeId, date);

			if (holidays.some((holiday) => holiday.date === date)) return 'festivo';
			if (vacation?.status === 'aprobada') return 'vacaciones';
			if (vacation?.status === 'pendiente') return 'pendiente';
			if (entry) return entry.status;
			if (isWeekend(date)) return 'fin de semana';
			return 'sin fichaje';
		}

		function calendarStatusLabel(status: string) {
			if (status === 'correcto') return 'Correcto';
			if (status === 'incidencia') return 'Incidencia';
			if (status === 'pendiente') return 'Pendiente';
			if (status === 'vacaciones') return 'Vacaciones';
			if (status === 'festivo') return 'Festivo';
			if (status === 'fin de semana') return 'Finde';
			if (status === 'sin fichaje') return 'Sin fichaje';
			return STATUS_LABELS[status] || status;
		}

		function formatBreaks(entry?: TimeEntry) {
			if (!entry?.breaks.length) return 'Sin descansos';
			return entry.breaks
				.map((item) => `${breakLabel(item)} ${item.start}-${item.end || 'abierta'}`)
				.join(', ');
		}

		function renderBreakList(entry?: TimeEntry) {
			if (!entry?.breaks.length) return emptyState('Aún no hay descansos registrados hoy.');

			return `
				<div class="break-list">
					${entry.breaks.map((item) => `
						<div class="break-item break-${item.kind || 'manual'}">
							<span>${breakLabel(item)}</span>
							<strong>${item.start} - ${item.end || 'abierta'}</strong>
							<small>${item.end ? formatMinutes(elapsedMinutes(item.start, item.end)) : 'En curso'}</small>
						</div>
					`).join('')}
				</div>
			`;
		}

		function breakLabel(item: TimeBreak) {
			if (item.label) return item.label;
			if (item.kind === 'meal') return 'Comida';
			if (item.kind === 'quick') return 'Pausa rápida';
			return 'Descanso manual';
		}

		function workedMinutes(entry?: TimeEntry) {
			if (!entry?.start) return 0;

			let end = entry.end;
			if (!end && entry.date === todayIso()) end = activeBreak(entry)?.start || currentTime();
			if (!end) return 0;

			let total = elapsedMinutes(entry.start, end);
			entry.breaks.forEach((pause) => {
				if (!pause.end) return;
				total -= elapsedMinutes(pause.start, pause.end);
			});
			return Math.max(total, 0);
		}

		function breakMinutes(entry?: TimeEntry) {
			if (!entry?.breaks.length) return 0;
			return entry.breaks.reduce((sum, pause) => {
				const end = pause.end || (entry.date === todayIso() ? currentTime() : pause.start);
				return sum + elapsedMinutes(pause.start, end);
			}, 0);
		}

		function elapsedMinutes(start: string, end: string) {
			const startMinutes = timeToMinutes(start);
			let endMinutes = timeToMinutes(end);
			if (endMinutes < startMinutes) endMinutes += 24 * 60;
			return Math.max(endMinutes - startMinutes, 0);
		}

		function validateManualTimeAdjustment(
			start: string,
			end: string,
			breaks: TimeBreak[],
			endNextDay: boolean,
			openBreakIndex: number,
		) {
			if (!start) return 'Indica una hora de entrada para guardar el ajuste.';
			if (!isTimeValue(start)) return 'La hora de entrada no tiene un formato válido.';
			if (end && !isTimeValue(end)) return 'La hora de salida no tiene un formato válido.';

			const startMinutes = timeToMinutes(start);
			const endMinutes = end ? relativeWorkdayMinutes(end, start, endNextDay) : undefined;

			if (end && !endNextDay && timeToMinutes(end) < startMinutes) {
				return 'La salida no debería ser anterior a la entrada. Si fue al día siguiente, marca la opción correspondiente.';
			}

			for (let index = 0; index < breaks.length; index += 1) {
				const item = breaks[index];
				const label = `Pausa ${index + 1}`;

				if (!item.start) return `${label}: indica una hora de inicio.`;
				if (!isTimeValue(item.start)) return `${label}: el inicio no tiene un formato válido.`;
				if (item.end && !isTimeValue(item.end)) return `${label}: el fin no tiene un formato válido.`;

				const pauseStart = relativeWorkdayMinutes(item.start, start, endNextDay);
				const pauseEnd = item.end ? relativeWorkdayMinutes(item.end, start, endNextDay) : undefined;

				if (pauseStart < startMinutes) return `${label}: la pausa no debería empezar antes de la entrada.`;
				if (pauseEnd !== undefined && pauseEnd < pauseStart) return `${label}: el fin de pausa no debería ser anterior al inicio.`;
				if (endMinutes !== undefined && pauseStart > endMinutes) return `${label}: la pausa no debería empezar después de la salida.`;
				if (endMinutes !== undefined && pauseEnd === undefined) return `${label}: completa el fin de pausa antes de guardar una salida.`;
				if (endMinutes === undefined && pauseEnd === undefined && index !== openBreakIndex) {
					return `${label}: solo puede quedar abierta la pausa actual.`;
				}
				if (endMinutes !== undefined && pauseEnd !== undefined && pauseEnd > endMinutes) {
					return `${label}: la pausa no debería terminar después de la salida.`;
				}
			}

			return '';
		}

		function relativeWorkdayMinutes(value: string, start: string, allowNextDay: boolean) {
			const minutes = timeToMinutes(value);
			const startMinutes = timeToMinutes(start);
			return allowNextDay && minutes < startMinutes ? minutes + 24 * 60 : minutes;
		}

		function isTimeValue(value: string) {
			return /^\d{2}:\d{2}$/.test(value);
		}

		function showManualFormMessage(form: HTMLFormElement, message: string) {
			const messageElement = form.querySelector<HTMLElement>('[data-manual-message]');
			if (!messageElement) {
				showToast(message);
				return;
			}

			messageElement.textContent = message;
			messageElement.hidden = false;
		}

		function recalculateTimeEntryStatus(entry: TimeEntry): EntryStatus {
			if (!entry.start) return 'sin fichaje';
			if (activeBreak(entry)) return 'pendiente';
			if (!entry.end && entry.date < todayIso()) return 'incidencia';
			return 'correcto';
		}

		function refreshEntryIncident(entry: TimeEntry) {
			const issue = entryIssueDetail(entry);
			const existing = incidents.find(
				(incident) =>
					incident.employeeId === entry.employeeId &&
					incident.date === entry.date &&
					incident.type === 'Revisión de fichaje' &&
					incident.status === 'pendiente',
			);

			if (issue) {
				if (existing) {
					existing.detail = issue;
					return;
				}

				incidents.push({
					id: uniqueId('incident-manual'),
					employeeId: entry.employeeId,
					date: entry.date,
					type: 'Revisión de fichaje',
					detail: issue,
					status: 'pendiente',
					createdAt: new Date().toISOString(),
				});
				return;
			}

			if (existing) {
				existing.status = 'revisada';
				existing.reviewedAt = new Date().toISOString();
			}
		}

		function entryIssueDetail(entry: TimeEntry) {
			if (!entry.start) return 'No consta entrada registrada.';
			if (entry.breaks.some((pause) => !pause.end) && entry.end) return 'Hay una pausa sin hora de fin.';
			if (!entry.end && entry.date < todayIso()) return 'Jornada sin salida registrada.';
			if (activeBreak(entry) && entry.date < todayIso()) return 'Descanso sin finalizar.';
			return '';
		}

		function workedMinutesThisWeek(employeeId: string) {
			const from = startOfCurrentWorkWeekIso();
			const to = endOfCurrentWorkWeekIso();

			return timeEntries
				.filter((entry) => entry.employeeId === employeeId && dateInRange(entry.date, from, to) && !isWeekend(entry.date))
				.reduce((sum, entry) => sum + workedMinutes(entry), 0);
		}

		function startOfCurrentWorkWeekIso() {
			const date = new Date(`${todayIso()}T12:00:00`);
			const day = date.getDay();
			const mondayOffset = day === 0 ? -6 : 1 - day;
			date.setDate(date.getDate() + mondayOffset);
			return isoFromDate(date);
		}

		function endOfCurrentWorkWeekIso() {
			const date = new Date(`${startOfCurrentWorkWeekIso()}T12:00:00`);
			date.setDate(date.getDate() + 4);
			return isoFromDate(date);
		}

		function vacationBalance(employeeId: string) {
			const employee = EMPLOYEES.find((item) => item.id === employeeId) || EMPLOYEES[0];
			const own = vacations.filter((request) => request.employeeId === employeeId);
			const enjoyed = own.filter(isEnjoyedVacation).reduce((sum, item) => sum + vacationRequestDays(item), 0);
			const futureApproved = own.filter(isFutureApprovedVacation).reduce((sum, item) => sum + vacationRequestDays(item), 0);
			const pending = own.filter((request) => request.status === 'pendiente').reduce((sum, item) => sum + vacationRequestDays(item), 0);
			const denied = own.filter((request) => request.status === 'denegada').reduce((sum, item) => sum + vacationRequestDays(item), 0);
			const canceled = own.filter((request) => request.status === 'cancelada').reduce((sum, item) => sum + vacationRequestDays(item), 0);
			const committed = enjoyed + futureApproved + pending;
			return {
				available: Math.max(employee.vacationDays - committed, 0),
				used: enjoyed,
				enjoyed,
				futureApproved,
				pending,
				denied,
				canceled,
			};
		}

		function filteredTimeEntries() {
			return timeEntries
				.filter((entry) => timeFilters.employeeId === 'all' || entry.employeeId === timeFilters.employeeId)
				.filter((entry) => dateInRange(entry.date, timeFilters.from, timeFilters.to))
				.filter((entry) => timeFilters.status === 'all' || entry.status === timeFilters.status)
				.sort((a, b) => b.date.localeCompare(a.date));
		}

		function downloadCsv(filename: string, rows: Record<string, string | number>[]) {
			const headers = Object.keys(rows[0] || { demo: 'Sin datos' });
			const body = rows.length ? rows : [{ demo: 'Sin datos' }];
			const csv = [
				headers.join(';'),
				...body.map((row) => headers.map((header) => csvValue(row[header])).join(';')),
			].join('\r\n');
			const blob = new Blob([`\ufeff${csv}`], { type: 'text/csv;charset=utf-8;' });
			const link = document.createElement('a');
			link.href = URL.createObjectURL(blob);
			link.download = filename;
			link.click();
			URL.revokeObjectURL(link.href);
		}

		function csvValue(value: string | number | undefined) {
			const text = String(value ?? '');
			return `"${text.replaceAll('"', '""')}"`;
		}

		function showToast(message: string) {
			if (!toast) return;
			if (toastTimer) window.clearTimeout(toastTimer);
			toast.textContent = message;
			toast.classList.remove('hidden');
			toastTimer = window.setTimeout(() => toast.classList.add('hidden'), 4200);
		}

		function statusClass(status: string) {
			return status
				.toLowerCase()
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '')
				.replace(/\s+/g, '-');
		}

		function escapeHtml(value: string) {
			return value.replace(/[&<>"']/g, (character) => {
				const entities: Record<string, string> = {
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#39;',
				};
				return entities[character] || character;
			});
		}

		function todayIso() {
			return isoFromDate(new Date());
		}

		function isoFromDate(date: Date) {
			const year = date.getFullYear();
			const month = String(date.getMonth() + 1).padStart(2, '0');
			const day = String(date.getDate()).padStart(2, '0');
			return `${year}-${month}-${day}`;
		}

		function startOfWeekIso(date: string) {
			const weekStart = new Date(`${date}T12:00:00`);
			const offset = (weekStart.getDay() + 6) % 7;
			weekStart.setDate(weekStart.getDate() - offset);
			return isoFromDate(weekStart);
		}

		function startOfMonthIso(date: Date) {
			return isoFromDate(new Date(date.getFullYear(), date.getMonth(), 1));
		}

		function currentTime() {
			const now = new Date();
			return `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
		}

		function currentTimeWithSeconds() {
			const now = new Date();
			return `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}:${String(now.getSeconds()).padStart(2, '0')}`;
		}

		function updateLiveClock() {
			document.querySelectorAll<HTMLElement>('.live-clock').forEach((element) => {
				element.textContent = currentTimeWithSeconds();
			});
		}

		function formatDate(date: string) {
			return new Date(`${date}T12:00:00`).toLocaleDateString('es-ES', {
				day: '2-digit',
				month: '2-digit',
				year: 'numeric',
			});
		}

		function formatDayHeader(date: string) {
			return new Date(`${date}T12:00:00`).toLocaleDateString('es-ES', {
				day: '2-digit',
				month: '2-digit',
			});
		}

		function weekdayShort(date: string) {
			return new Date(`${date}T12:00:00`).toLocaleDateString('es-ES', {
				weekday: 'short',
			});
		}

		function formatDateTime(value: string) {
			return new Date(value).toLocaleString('es-ES', {
				day: '2-digit',
				month: '2-digit',
				year: 'numeric',
				hour: '2-digit',
				minute: '2-digit',
			});
		}

		function formatMinutes(minutes: number) {
			const hours = Math.floor(minutes / 60);
			const remainder = minutes % 60;
			return `${hours} h ${String(remainder).padStart(2, '0')} min`;
		}

		function timeToMinutes(value: string) {
			const [hours, minutes] = value.split(':').map(Number);
			return hours * 60 + minutes;
		}

		function addMinutesToTime(value: string, minutesToAdd: number) {
			const total = timeToMinutes(value) + minutesToAdd;
			const hours = Math.floor(total / 60) % 24;
			const minutes = total % 60;
			return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`;
		}

		function addDaysIso(date: string, amount: number) {
			const next = new Date(`${date}T12:00:00`);
			next.setDate(next.getDate() + amount);
			return isoFromDate(next);
		}

		function clampDateIso(date: string, min: string, max: string) {
			if (date < min) return min;
			if (date > max) return max;
			return date;
		}

		function diffDays(from: string, to: string) {
			const start = new Date(`${from}T12:00:00`).getTime();
			const end = new Date(`${to}T12:00:00`).getTime();
			return Math.round((end - start) / 86400000);
		}

		function dateRange(from: string, to: string) {
			const total = Math.max(diffDays(from, to), 0);
			return Array.from({ length: total + 1 }, (_, index) => addDaysIso(from, index));
		}

		function businessDaysBetween(from: string, to: string) {
			return dateRange(from, to).filter(isBusinessDay).length;
		}

		function isBusinessDay(date: string) {
			return !isWeekend(date) && !holidays.some((holiday) => holiday.date === date);
		}

		function isWeekend(date: string) {
			const day = new Date(`${date}T12:00:00`).getDay();
			return day === 0 || day === 6;
		}

		function isDateWithin(date: string, from: string, to: string) {
			return date >= from && date <= to;
		}

		function rangesOverlap(fromA: string, toA: string, fromB: string, toB: string) {
			return fromA <= toB && fromB <= toA;
		}

		function businessRangesOverlap(fromA: string, toA: string, fromB: string, toB: string) {
			if (!rangesOverlap(fromA, toA, fromB, toB)) return false;
			return dateRange(maxDate(fromA, fromB), minDate(toA, toB)).some(isBusinessDay);
		}

		function isActiveVacationRequest(request: VacationRequest) {
			return request.status === 'aprobada' || request.status === 'pendiente';
		}

		function dateInRange(date: string, from: string, to: string) {
			return (!from || date >= from) && (!to || date <= to);
		}

		function countVacationDaysInRange(employeeId: string, from: string, to: string) {
			return vacations
				.filter(
					(request) =>
						request.employeeId === employeeId &&
						request.status === 'aprobada' &&
						rangesOverlap(from, to, request.from, request.to),
				)
				.reduce((sum, request) => {
					return (
						sum +
						dateRange(maxDate(from, request.from), minDate(to, request.to)).filter(
							isBusinessDay,
						).length
					);
				}, 0);
		}

		function minDate(a: string, b: string) {
			return a < b ? a : b;
		}

		function maxDate(a: string, b: string) {
			return a > b ? a : b;
		}

		function uniqueId(prefix: string) {
			return `${prefix}-${Math.random().toString(36).slice(2, 9)}-${Date.now().toString(36)}`;
		}
	</script>
</Layout>
