			`;
		}

		function adminRecordsDate() {
			return selectedAdminRecordDate || todayIso();
		}

		function adminRecordRows() {
			const date = adminRecordsDate();
			const query = adminRecordsSearch.trim().toLowerCase();
			return EMPLOYEES
				.slice()
				.sort((a, b) => a.name.localeCompare(b.name))
				.map((employee) => {
					const entry = findEntry(employee.id, date);
					const dayIncidents = incidentsForEmployeeDate(employee.id, date);
					const absence = adminFullDayAbsence(employee.id, date);
					const status = adminRecordStatus(entry, dayIncidents, absence);
					return { employee, entry, incidents: dayIncidents, absence, status, date };
				})
				.filter((row) => adminRecordsDepartment === 'all' || row.employee.department === adminRecordsDepartment)
				.filter((row) => {
					if (!query) return true;
					return [row.employee.name, row.employee.department].some((value) => value.toLowerCase().includes(query));
				})
				.filter((row) => adminRecordsStatus === 'all' || row.status.key === adminRecordsStatus);
		}

		function adminRecordsSummary(rows: ReturnType<typeof adminRecordRows>) {
			return {
				working: rows.filter((row) => row.status.key === 'trabajando').length,
				paused: rows.filter((row) => row.status.key === 'pausa').length,
				finished: rows.filter((row) => row.status.key === 'correcto').length,
				missing: rows.filter((row) => row.status.key === 'sin-fichar').length,
				incidents: rows.filter((row) => row.incidents.length).length,
			};
		}

		function adminRecordsState(label: string, value: number, status: string) {
			return `
				<div class="admin-v2-records-state">
					<span>${label}</span>
					<strong>${value}</strong>
					${pill(label, status)}
				</div>
			`;
		}

		function incidentsForEmployeeDate(employeeId: string, date: string) {
			return incidents
				.filter((incident) => incident.employeeId === employeeId && incident.date === date)
				.slice()
				.sort((a, b) => b.createdAt.localeCompare(a.createdAt));
		}

		function adminFullDayAbsence(employeeId: string, date: string) {
			return vacations.find(
				(request) =>
					request.employeeId === employeeId &&
					request.status === 'aprobada' &&
					!absenceUsesHours(request, ABSENCE_TYPES) &&
					isDateWithin(date, request.from, request.to),
			);
		}

		function adminRecordStatus(
			entry: TimeEntry | undefined,
			dayIncidents: Incident[],
			absence?: VacationRequest,
		) {
			if (absence) return { label: `Ausente · ${absenceTypeName(absence)}`, key: 'vacaciones' };
			if (dayIncidents.some((incident) => incident.status === 'pendiente') || entry?.status === 'incidencia') {
				return { label: 'Con incidencia', key: 'incidencia' };
			}
			const status = dateStatusForEntry(entry);
			if (status.key === 'sin-fichaje') return { label: 'Sin fichar', key: 'sin-fichar' };
			return status;
		}

		function dateStatusForEntry(entry?: TimeEntry) {
			if (!entry?.start) return { label: 'Sin iniciar', key: 'sin-fichaje' };
			if (entry.end) return { label: 'Finalizada', key: 'correcto' };
			if (activeBreak(entry)) return { label: 'En pausa', key: 'pausa' };
			return { label: 'Trabajando', key: 'trabajando' };
		}

		function renderAdminRecordsTable(rows: ReturnType<typeof adminRecordRows>) {
			return `
				<div class="table-wrap admin-v2-records-table-wrap">
					<table class="admin-v2-records-table">
						<thead>
							<tr>
								<th>Persona</th>
								<th>Departamento</th>
								<th>Entrada</th>
								<th>Pausas</th>
								<th>Salida</th>
								<th>Trabajado</th>
								<th>Estado</th>
								<th>Incidencias</th>
								<th>Acción</th>
							</tr>
						</thead>
						<tbody>
							${rows.map(renderAdminRecordTableRow).join('')}
						</tbody>
					</table>
				</div>
				<div class="admin-v2-record-mobile-list">
					${rows.map(renderAdminRecordMobileCard).join('')}
				</div>
			`;
		}

		function renderAdminRecordTableRow(row: ReturnType<typeof adminRecordRows>[number]) {
			return `
				<tr class="${row.incidents.length ? 'has-incident' : ''}">
					<td>
						<div class="admin-v2-record-person">
							<span class="admin-v2-person-avatar" aria-hidden="true">${escapeHtml(personInitials(row.employee.name))}</span>
							<strong>${escapeHtml(row.employee.name)}</strong>
						</div>
					</td>
					<td>${escapeHtml(row.employee.department)}</td>
					<td>${row.entry?.start || '—'}</td>
					<td>${adminRecordBreakSummary(row.entry)}</td>
					<td>${row.entry?.end || '—'}</td>
					<td>${formatMinutes(workedMinutes(row.entry))}</td>
					<td>${pill(row.status.label, row.status.key)}</td>
					<td>${row.incidents.length ? pill(String(row.incidents.length), 'incidencia') : '—'}</td>
					<td>${adminRecordViewButton(row.employee.id, row.date, 'Ver')}</td>
				</tr>
			`;
		}

		function renderAdminRecordMobileCard(row: ReturnType<typeof adminRecordRows>[number]) {
			return `
				<article class="admin-v2-record-mobile-card ${row.incidents.length ? 'has-incident' : ''}">
					<div class="admin-v2-record-card-head">
						<div>
							<strong>${escapeHtml(row.employee.name)}</strong>
							<span>${escapeHtml(row.employee.department)}</span>
						</div>
						${pill(row.status.label, row.status.key)}
					</div>
					<div class="admin-card-grid">
						${summaryRow('Horario', `${row.entry?.start || '—'} → ${row.entry?.end || '—'}`)}
						${summaryRow('Trabajado', formatMinutes(workedMinutes(row.entry)))}
						${summaryRow('Pausas', adminRecordBreakSummary(row.entry))}
