		function createDefaults() {
			const today = todayIso();
			const usersSeed: AppUser[] = [
				{
					id: 'admin_global',
					name: 'Administrador demo',
					email: 'admin.demo@fichajesimple.es',
					department: 'Dirección',
					role: 'admin_global',
					active: true,
				},
				{
					id: 'validador_vacaciones',
					name: 'Validador vacaciones',
					email: 'vacaciones.demo@fichajesimple.es',
					department: 'Administración',
					role: 'validador_vacaciones',
					active: true,
				},
				...EMPLOYEES.map((employee) => ({
					id: employee.id,
					name: employee.name,
					email:
						employee.id === 'ana'
							? 'ana.demo@fichajesimple.es'
							: employee.id === 'miguel'
								? 'miguel.demo@fichajesimple.es'
								: `${employee.id}@sourcingdemo.es`,
					department: employee.department,
					role: 'empleado' as Role,
					active: true,
					employeeId: employee.id,
				})),
			];
			const timeEntriesSeed: TimeEntry[] = [];
			const incidentsSeed: Incident[] = [];

			EMPLOYEES.forEach((employee, employeeIndex) => {
				for (let offset = 1; offset <= 120; offset += 1) {
					const date = addDaysIso(today, -offset);
					if (isWeekend(date)) continue;

					const missedDay = (offset + employeeIndex * 5) % 43 === 0;
					const missingEnd = (offset + employeeIndex * 3) % 37 === 0;
					const lateStart = (offset + employeeIndex) % 29 === 0;
					const longBreak = (offset + employeeIndex * 2) % 31 === 0;
					if (missedDay) {
						incidentsSeed.push({
							id: uniqueId(`incident-missed-${employee.id}-${offset}`),
							employeeId: employee.id,
							date,
							type: 'Sin fichaje',
							detail: 'No consta entrada registrada en una jornada laborable.',
							status: offset < 35 ? 'revisada' : 'pendiente',
							createdAt: new Date(Date.now() - offset * 86400000).toISOString(),
							reviewedAt: offset < 35 ? new Date(Date.now() - (offset - 1) * 86400000).toISOString() : undefined,
						});
						continue;
					}

					const start = lateStart ? '09:38' : employeeIndex % 2 === 0 ? '08:47' : '09:04';
					const breakStart = employeeIndex % 2 === 0 ? '11:18' : '12:05';
					const breakEnd = longBreak ? '12:25' : employeeIndex % 2 === 0 ? '11:34' : '12:28';
					const end = missingEnd ? undefined : employeeIndex % 2 === 0 ? '17:04' : '17:24';
					const status: EntryStatus = missingEnd || lateStart || longBreak ? 'incidencia' : 'correcto';

					timeEntriesSeed.push({
						id: uniqueId(`seed-${employee.id}-${offset}`),
						employeeId: employee.id,
						date,
						start,
						breaks: [{ start: breakStart, end: breakEnd }],
						end,
						status,
						notes: missingEnd
							? 'Salida pendiente de revisar'
							: lateStart
								? 'Entrada fuera del horario habitual'
								: longBreak
									? 'Pausa superior a lo habitual'
									: undefined,
					});

					if (status === 'incidencia') {
						incidentsSeed.push({
							id: uniqueId(`incident-${employee.id}-${offset}`),
							employeeId: employee.id,
							date,
							type: missingEnd ? 'Salida olvidada' : lateStart ? 'Entrada tardía' : 'Pausa prolongada',
							detail: missingEnd
								? 'Jornada sin salida registrada.'
								: lateStart
									? `Entrada registrada a las ${start}.`
									: `Pausa registrada entre ${breakStart} y ${breakEnd}.`,
							status: offset < 40 ? 'revisada' : 'pendiente',
							createdAt: new Date(Date.now() - offset * 86400000).toISOString(),
							reviewedAt: offset < 40 ? new Date(Date.now() - (offset - 1) * 86400000).toISOString() : undefined,
						});
					}
				}
			});

			timeEntriesSeed.push(
				{ id: uniqueId('today-ana'), employeeId: 'ana', date: today, start: '08:52', breaks: [{ start: '11:20', end: '11:35' }], status: 'correcto' },
				{ id: uniqueId('today-laura'), employeeId: 'laura', date: today, start: '08:40', breaks: [], status: 'correcto' },
