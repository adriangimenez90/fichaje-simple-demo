		}

		function saveManualAdjustment(form: HTMLFormElement) {
			const employee = currentEmployee();
			const formData = new FormData(form);
			const date = String(formData.get('date') || todayIso());
			const start = String(formData.get('start') || '').trim();
			const end = String(formData.get('end') || '').trim();
			const reason = String(formData.get('reason') || '').trim();
			let entry = findEntry(employee.id, date);
			const originalBreaks = entry?.breaks || [];
			const openBreakIndex = originalBreaks.findIndex((item) => item.start && !item.end);
			const adjustedBreaks = originalBreaks.map((item, index) => ({
				...item,
				start: String(formData.get(`break-start-${index}`) || item.start).trim(),
				end: String(formData.get(`break-end-${index}`) || '').trim() || undefined,
			}));
			const validationMessage = validateManualTimeAdjustment(
				start,
				end,
				adjustedBreaks,
				Boolean(formData.get('endNextDay')),
				openBreakIndex,
			);

			if (validationMessage) {
				showManualFormMessage(form, validationMessage);
				return;
			}

			if (!entry) {
				entry = {
					id: uniqueId('entry'),
					employeeId: employee.id,
					date,
					breaks: [],
					status: 'correcto',
				};
				timeEntries.push(entry);
			}

			entry.start = start;
			entry.end = end || undefined;
			entry.breaks = adjustedBreaks;
			entry.status = recalculateTimeEntryStatus(entry);
			entry.notes = reason || 'Ajuste manual sin motivo indicado';

			refreshEntryIncident(entry);
			addAudit(
				'Ajuste manual',
				`${employee.name}: registro de ${formatDate(date)} actualizado. ${reason || 'Ajuste manual sin motivo indicado'}.`,
			);
			saveAll();
			showToast('Registro actualizado. Los tiempos se han recalculado.');
			renderPage();
		}

