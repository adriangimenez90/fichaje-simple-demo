					</div>
					<div class="admin-today-card-list">
						${filteredStatuses.map(({ employee, entry }) => renderAdminTodayCard(employee, entry)).join('')}
					</div>
					${filteredStatuses.length ? '' : emptyState('No hay empleados con este estado ahora mismo.')}
				</section>
			`;
		}

