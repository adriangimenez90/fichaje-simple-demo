		function canCancelEmployeeVacation(request: VacationRequest) {
			if (request.status === 'pendiente') return true;
			return isFutureApprovedVacation(request);
		}

		function vacationReminderMailto(request: VacationRequest) {
			const employee = employeeName(request.employeeId);
			const subject = encodeURIComponent('Recordatorio de vacaciones pendientes');
			const body = encodeURIComponent(
				`Hola,\n\n${employee} tiene una solicitud de vacaciones pendiente de revisión.\n\nFechas: ${formatDate(request.from)} - ${formatDate(request.to)}\nDías laborables solicitados: ${vacationRequestDays(request)}\n\n¿Podéis revisarla cuando sea posible?\n\nGracias.`,
			);
			return `mailto:responsable.vacaciones@empresa-demo.es?subject=${subject}&body=${body}`;
		}

		function renderVacationAdminDetail(request: VacationRequest, scopeEmployees = EMPLOYEES) {
			const rangeDays = dateRange(request.from, request.to);
			const scopeIds = new Set(scopeEmployees.map((employee) => employee.id));
			const approvedConflictEmployees = new Set(
				vacations
					.filter(
						(item) =>
							item.id !== request.id &&
							item.employeeId !== request.employeeId &&
							scopeIds.has(item.employeeId) &&
							item.status === 'aprobada' &&
							businessRangesOverlap(request.from, request.to, item.from, item.to),
					)
					.map((item) => item.employeeId),
			);
			const pendingConflictEmployees = new Set(
				vacations
					.filter(
						(item) =>
							item.id !== request.id &&
							item.employeeId !== request.employeeId &&
							scopeIds.has(item.employeeId) &&
							item.status === 'pendiente' &&
							businessRangesOverlap(request.from, request.to, item.from, item.to),
					)
					.map((item) => item.employeeId),
			);
			const comparisonRows = scopeEmployees.map((employee) => `
				<tr>
					<th class="sticky-col">
						<strong>${employee.name}</strong>
						<span>${employee.department}</span>
					</th>
					${rangeDays.map((date) => renderVacationComparisonCell(employee.id, date, request)).join('')}
				</tr>
			`).join('');

			return `
				<div class="vacation-admin-summary">
					<div>
						<span class="meta-label">Solicitud seleccionada</span>
						<strong>${employeeName(request.employeeId)}</strong>
						<p>${formatDate(request.from)} - ${formatDate(request.to)} · ${vacationRequestDays(request)} días laborables · ${escapeHtml(employeeById(request.employeeId)?.department || 'Sin departamento')}</p>
						${pill(request.status)}
					</div>
					<div class="conflict-meter ${approvedConflictEmployees.size ? 'has-conflict' : ''}">
						<strong>${approvedConflictEmployees.size}</strong>
						<span>empleados coinciden con vacaciones aprobadas</span>
					</div>
					<div class="conflict-meter ${pendingConflictEmployees.size ? 'has-warning' : ''}">
						<strong>${pendingConflictEmployees.size}</strong>
						<span>empleados coinciden con solicitudes pendientes</span>
					</div>
				</div>
				<div class="comparison-legend top-gap">
					<span><i class="cell-actual"></i> Solicitud actual</span>
					<span><i class="cell-approved"></i> Vacaciones aprobadas</span>
					<span><i class="cell-pending"></i> Solicitud pendiente</span>
					<span><i class="cell-free"></i> Libre</span>
					<span><i class="cell-off"></i> No laborable</span>
				</div>
				<p class="helper-text top-gap">Tabla comparativa por empleado y día. Si el rango es largo, desplázate horizontalmente para revisar todas las fechas.</p>
				<div class="table-wrap vacation-matrix-wrap top-gap">
					<table class="vacation-matrix">
						<thead>
							<tr>
								<th class="sticky-col">Empleado</th>
								${rangeDays.map((date) => `<th>${formatDayHeader(date)}</th>`).join('')}
							</tr>
						</thead>
						<tbody>${comparisonRows}</tbody>
					</table>
				</div>
				<div class="form-grid top-gap responsible-decision-form ${request.status !== 'pendiente' ? 'hidden' : ''}">
					<label class="field">
						<span>Motivo de denegación</span>
						<textarea id="denial-reason" placeholder="Obligatorio solo si se deniega">${escapeHtml(request.denialReason || '')}</textarea>
					</label>
					<div class="tab-actions">
						<button class="button button-primary" type="button" data-action="approve-vacation" data-id="${request.id}" ${request.status !== 'pendiente' ? 'disabled' : ''}>Aprobar</button>
						<button class="button button-danger" type="button" data-action="deny-vacation" data-id="${request.id}" ${request.status !== 'pendiente' ? 'disabled' : ''}>Denegar</button>
					</div>
				</div>
			`;
		}

		function vacationConflictCounts(request: VacationRequest, scopeEmployees = EMPLOYEES) {
			const details = vacationConflictDetails(request, scopeEmployees);
			const approved = new Set(details.filter((item) => item.request.status === 'aprobada').map((item) => item.request.employeeId));
			const pending = new Set(details.filter((item) => item.request.status === 'pendiente').map((item) => item.request.employeeId));

			return {
				approved: approved.size,
				pending: pending.size,
			};
		}

		function renderVacationComparisonCell(employeeId: string, date: string, request: VacationRequest) {
			if (!isBusinessDay(date)) {
				return `<td class="comparison-cell cell-off">--</td>`;
			}

			if (employeeId === request.employeeId && isDateWithin(date, request.from, request.to)) {
				return `<td class="comparison-cell cell-actual">Actual</td>`;
			}

			const overlapping = vacations.find(
				(item) =>
					item.id !== request.id &&
					item.employeeId === employeeId &&
					isActiveVacationRequest(item) &&
					isBusinessDay(date) &&
					isDateWithin(date, item.from, item.to),
			);

			if (overlapping?.status === 'aprobada') {
				return `<td class="comparison-cell cell-approved">Aprobada</td>`;
			}

			if (overlapping?.status === 'pendiente') {
				return `<td class="comparison-cell cell-pending">Pendiente</td>`;
			}

			return `<td class="comparison-cell cell-free">Libre</td>`;
		}

		function employeeVacationPreview(from: string, to: string) {
			const employee = currentEmployee();
			if (!from || !to) {
				employeeVacationPreviewWeekStart = '';
				return `
					<section class="vacation-preview employee-vacation-preview">
						<div class="panel-heading">
							<div>
								<h3>Coincidencias con tu equipo</h3>
								<p class="helper-text">Selecciona fechas para comprobar si coincides con alguien de tu departamento.</p>
							</div>
						</div>
						${emptyState('Selecciona fechas para comprobar coincidencias con tu equipo.')}
					</section>
				`;
			}

			if (from > to) {
				employeeVacationPreviewWeekStart = '';
				return `
					<section class="vacation-preview employee-vacation-preview">
						<div class="panel-heading">
							<div>
								<h3>Coincidencias con tu equipo</h3>
								<p class="helper-text">Revisa el rango antes de comparar vacaciones.</p>
							</div>
						</div>
						${emptyState('La fecha hasta debe ser igual o posterior a la fecha desde.')}
					</section>
				`;
			}

			ensureEmployeeVacationPreviewWeek(from, to);
			const weekStart = employeeVacationPreviewWeekStart;
			const weekEnd = addDaysIso(weekStart, 6);
			const weekDays = dateRange(weekStart, weekEnd);
			const minWeekStart = startOfWeekIso(from);
			const maxWeekStart = startOfWeekIso(to);
			const previewRequest: VacationRequest = {
				id: 'preview-current-request',
				employeeId: employee.id,
				from,
				to,
				days: businessDaysBetween(from, to),
				status: 'pendiente',
				createdAt: new Date().toISOString(),
			};
			const peers = departmentEmployees(employee.department);
			const overlaps = vacations
				.filter(
					(request) =>
						request.employeeId !== employee.id &&
						isActiveVacationRequest(request) &&
						peers.some((peer) => peer.id === request.employeeId) &&
						businessRangesOverlap(from, to, request.from, request.to),
				)
				.sort((a, b) => a.from.localeCompare(b.from));
			const pastRequestNote = from < todayIso()
				? `<p class="vacation-regularization-note">Estás solicitando vacaciones en fechas pasadas. Se registrará como regularización.</p>`
				: '';

			const comparisonRows = peers.map((peer) => `
				<tr>
					<th class="sticky-col">
						<strong>${peer.name}</strong>
						<span>${peer.department}</span>
					</th>
					${weekDays.map((date) => renderEmployeeVacationComparisonCell(peer.id, date, previewRequest)).join('')}
				</tr>
			`).join('');

			return `
				<section class="vacation-preview employee-vacation-preview">
					<div class="panel-heading">
						<div>
							<h3>Coincidencias en ${escapeHtml(employee.department)}</h3>
							<p class="helper-text">${formatDate(from)} - ${formatDate(to)} · ${previewRequest.days} días laborables solicitados.</p>
						</div>
					</div>
					${pastRequestNote}
					<div class="vacation-week-nav">
						<button class="button button-tertiary button-small" type="button" data-action="employee-vacation-week-prev" ${weekStart <= minWeekStart ? 'disabled' : ''}>Semana anterior</button>
						<strong>${formatDayHeader(weekStart)} - ${formatDayHeader(weekEnd)}</strong>
						<button class="button button-tertiary button-small" type="button" data-action="employee-vacation-week-next" ${weekStart >= maxWeekStart ? 'disabled' : ''}>Semana siguiente</button>
					</div>
					${overlaps.length ? `
						<div class="overlap-list">
							${overlaps.map((request) => `
								<div>
									<strong>${employeeName(request.employeeId)}</strong>
									<span>${request.status === 'aprobada' ? 'Aprobadas' : 'Pendiente'} del ${formatDate(request.from)} al ${formatDate(request.to)}</span>
								</div>
							`).join('')}
						</div>
					` : emptyState('No hay coincidencias aprobadas o pendientes en este rango.')}
					<div class="comparison-legend top-gap">
						<span><i class="cell-actual"></i> Solicitud actual</span>
						<span><i class="cell-approved"></i> Vacaciones aprobadas</span>
						<span><i class="cell-pending"></i> Solicitud pendiente</span>
						<span><i class="cell-free"></i> Libre</span>
						<span><i class="cell-off"></i> No laborable</span>
					</div>
					<div class="table-wrap vacation-matrix-wrap vacation-week-table top-gap">
						<table class="vacation-matrix">
							<thead>
								<tr>
									<th class="sticky-col">Empleado</th>
									${weekDays.map((date) => `<th class="${!isBusinessDay(date) ? 'is-weekend' : ''}">${formatDayHeader(date)}<span>${weekdayShort(date)}</span></th>`).join('')}
								</tr>
							</thead>
							<tbody>${comparisonRows}</tbody>
						</table>
					</div>
					<div class="vacation-week-cards top-gap">
						${weekDays.map((date) => renderEmployeeVacationDayCard(date, peers, previewRequest)).join('')}
					</div>
				</section>
			`;
		}

		function employeeVacationCellState(employeeId: string, date: string, request: VacationRequest) {
			if (!isBusinessDay(date)) {
				const holiday = holidays.find((item) => item.date === date);
				return {
					key: 'off',
					short: '-',
					label: holiday ? 'Festivo' : 'No laborable',
					title: holiday ? `Festivo: ${holiday.name}` : 'Fin de semana',
				};
			}

			if (employeeId === request.employeeId && isDateWithin(date, request.from, request.to)) {
				return {
					key: 'actual',
					short: 'Actual',
					label: 'Solicitud actual',
					title: 'Solicitud actual',
				};
			}

			const overlapping = vacations.find(
				(item) =>
					item.id !== request.id &&
					item.employeeId === employeeId &&
					isActiveVacationRequest(item) &&
					isDateWithin(date, item.from, item.to),
			);

			if (overlapping?.status === 'aprobada') {
				return {
					key: 'approved',
					short: 'VAC',
					label: 'Aprobada',
					title: `Vacaciones aprobadas del ${formatDate(overlapping.from)} al ${formatDate(overlapping.to)}`,
				};
			}

			if (overlapping?.status === 'pendiente') {
				return {
					key: 'pending',
					short: 'PEN',
					label: 'Pendiente',
					title: `Solicitud pendiente del ${formatDate(overlapping.from)} al ${formatDate(overlapping.to)}`,
				};
			}

			return {
				key: 'free',
				short: 'Libre',
				label: 'Libre',
				title: 'Libre',
			};
		}

		function renderEmployeeVacationComparisonCell(employeeId: string, date: string, request: VacationRequest) {
			const state = employeeVacationCellState(employeeId, date, request);
			const weekendClass = !isBusinessDay(date) ? ' is-weekend' : '';
			return `<td class="comparison-cell employee-comparison-cell cell-${state.key}${weekendClass}" title="${escapeHtml(`${employeeName(employeeId)} Â· ${formatDate(date)} Â· ${state.title}`)}">${state.short}</td>`;
		}

		function renderEmployeeVacationDayCard(date: string, peers: Employee[], request: VacationRequest) {
			return `
				<article class="vacation-day-card ${!isBusinessDay(date) ? 'is-weekend' : ''}">
					<div class="vacation-day-card-head">
						<strong>${formatDayHeader(date)}</strong>
						<span>${weekdayShort(date)}</span>
					</div>
					<div class="vacation-day-card-list">
						${peers.map((peer) => {
							const state = employeeVacationCellState(peer.id, date, request);
							return `
								<div class="vacation-day-row">
									<span>${peer.name}</span>
									<strong class="employee-day-state cell-${state.key}" title="${escapeHtml(state.title)}">${state.label}</strong>
								</div>
							`;
						}).join('')}
					</div>
				</article>
			`;
		}

		function ensureEmployeeVacationPreviewWeek(from: string, to: string) {
			if (!from || !to || from > to) {
				employeeVacationPreviewWeekStart = '';
				return;
			}

			const minWeekStart = startOfWeekIso(from);
			const maxWeekStart = startOfWeekIso(to);

			if (
				!employeeVacationPreviewWeekStart ||
				employeeVacationPreviewWeekStart < minWeekStart ||
				employeeVacationPreviewWeekStart > maxWeekStart
			) {
				employeeVacationPreviewWeekStart = minWeekStart;
			}
		}

		function shiftEmployeeVacationPreviewWeek(amount: number) {
			const form = document.querySelector<HTMLFormElement>('#vacation-request-form');
			if (!form) return;

			const formData = new FormData(form);
			const from = String(formData.get('from') || '');
			const to = String(formData.get('to') || '');

			if (!from || !to || from > to) {
				showToast('Selecciona fechas para navegar por semanas.');
				return;
			}

			ensureEmployeeVacationPreviewWeek(from, to);
			employeeVacationPreviewWeekStart = clampDateIso(
				addDaysIso(employeeVacationPreviewWeekStart, amount),
				startOfWeekIso(from),
				startOfWeekIso(to),
			);
			updateEmployeeVacationPreview();
		}

		function updateEmployeeVacationPreview() {
			const form = document.querySelector<HTMLFormElement>('#vacation-request-form');
			const target = document.querySelector<HTMLElement>('#employee-vacation-preview');
			if (!form || !target) return;

			const formData = new FormData(form);
			target.innerHTML = employeeVacationPreview(
				String(formData.get('from') || ''),
				String(formData.get('to') || ''),
			);
		}

