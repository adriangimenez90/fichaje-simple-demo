					<label class="field">
						<span>Motivo de denegación</span>
						<textarea id="denial-reason" placeholder="Obligatorio solo si se deniega">${escapeHtml(request.denialReason || '')}</textarea>
					</label>
					<div class="tab-actions">
						<button class="button button-primary" type="button" data-action="approve-vacation" ${request.status !== 'pendiente' ? 'disabled' : ''}>Aprobar</button>
						<button class="button button-danger" type="button" data-action="deny-vacation" ${request.status !== 'pendiente' ? 'disabled' : ''}>Denegar</button>
					</div>
				</div>
			`;
		}

		function vacationConflictCounts(request: VacationRequest, scopeEmployees = EMPLOYEES) {
			const scopeIds = new Set(scopeEmployees.map((employee) => employee.id));
			const approved = new Set(
				vacations
					.filter(
						(item) =>
							item.id !== request.id &&
							item.employeeId !== request.employeeId &&
							scopeIds.has(item.employeeId) &&
							item.status === 'aprobada' &&
							rangesOverlap(request.from, request.to, item.from, item.to),
					)
					.map((item) => item.employeeId),
			);
			const pending = new Set(
				vacations
					.filter(
						(item) =>
							item.id !== request.id &&
							item.employeeId !== request.employeeId &&
							scopeIds.has(item.employeeId) &&
							item.status === 'pendiente' &&
							rangesOverlap(request.from, request.to, item.from, item.to),
					)
					.map((item) => item.employeeId),
			);

			return {
				approved: approved.size,
				pending: pending.size,
			};
		}

		function renderVacationComparisonCell(employeeId: string, date: string, request: VacationRequest) {
			if (employeeId === request.employeeId && isDateWithin(date, request.from, request.to)) {
				return `<td class="comparison-cell cell-actual">Actual</td>`;
			}

			const overlapping = vacations.find(
				(item) =>
					item.id !== request.id &&
					item.employeeId === employeeId &&
					item.status !== 'denegada' &&
					isDateWithin(date, item.from, item.to),
			);

			if (overlapping?.status === 'aprobada') {
				return `<td class="comparison-cell cell-approved">Aprobada</td>`;
			}

			if (overlapping?.status === 'pendiente') {
				return `<td class="comparison-cell cell-pending">Pendiente</td>`;
			}

			return `<td class="comparison-cell cell-free">Libre</td>`;
		}

		function employeeVacationPreview(from: string, to: string) {
			const employee = currentEmployee();
			if (!from || !to) {
				return emptyState('Selecciona fecha desde y hasta para ver coincidencias de tu departamento.');
			}

			if (from > to) {
				return emptyState('La fecha hasta debe ser igual o posterior a la fecha desde.');
			}

			const rangeDays = dateRange(from, to);
			const previewRequest: VacationRequest = {
				id: 'preview-current-request',
				employeeId: employee.id,
				from,
				to,
				days: businessDaysBetween(from, to),
				status: 'pendiente',
				createdAt: new Date().toISOString(),
			};
			const peers = departmentEmployees(employee.department);
			const overlaps = vacations
				.filter(
					(request) =>
						request.employeeId !== employee.id &&
						request.status !== 'denegada' &&
						peers.some((peer) => peer.id === request.employeeId) &&
						rangesOverlap(from, to, request.from, request.to),
				)
				.sort((a, b) => a.from.localeCompare(b.from));

			const comparisonRows = peers.map((peer) => `
				<tr>
					<th class="sticky-col">
						<strong>${peer.name}</strong>
						<span>${peer.department}</span>
					</th>
					${rangeDays.map((date) => renderVacationComparisonCell(peer.id, date, previewRequest)).join('')}
				</tr>
			`).join('');

			return `
				<section class="vacation-preview">
					<div class="panel-heading">
						<div>
							<h3>Coincidencias en ${escapeHtml(employee.department)}</h3>
							<p class="helper-text">${formatDate(from)} - ${formatDate(to)} · ${previewRequest.days} días laborables solicitados.</p>
						</div>
					</div>
					${overlaps.length ? `
						<div class="overlap-list">
							${overlaps.map((request) => `
								<div>
									<strong>${employeeName(request.employeeId)}</strong>
									<span>${request.status === 'aprobada' ? 'Aprobadas' : 'Pendiente'} del ${formatDate(request.from)} al ${formatDate(request.to)}</span>
								</div>
							`).join('')}
						</div>
					` : emptyState('No hay vacaciones aprobadas o pendientes de tu departamento en esas fechas.')}
					<div class="comparison-legend top-gap">
						<span><i class="cell-actual"></i> Solicitud actual</span>
						<span><i class="cell-approved"></i> Vacaciones aprobadas</span>
						<span><i class="cell-pending"></i> Solicitud pendiente</span>
						<span><i class="cell-free"></i> Libre</span>
					</div>
					<div class="table-wrap vacation-matrix-wrap top-gap">
						<table class="vacation-matrix">
							<thead>
								<tr>
									<th class="sticky-col">Empleado</th>
									${rangeDays.map((date) => `<th>${formatDayHeader(date)}</th>`).join('')}
								</tr>
							</thead>
							<tbody>${comparisonRows}</tbody>
						</table>
					</div>
				</section>
			`;
		}

