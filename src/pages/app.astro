---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FichajeSimple">
	<div id="app-shell" class="app-shell" hidden>
		<header class="app-header">
			<div class="header-left">
				<div class="brand-lockup" aria-label="FichajeSimple">
					<img class="brand-icon" src="/brand/fichajesimple-icon.png" alt="FichajeSimple" />
					<div>
						<strong>FichajeSimple</strong>
						<span class="muted-line">Empresa Demo · Centro Principal</span>
					</div>
				</div>
				<span class="demo-badge">Demo pública · Datos ficticios · Navegador</span>
			</div>

			<div class="header-actions">
				<div id="user-chip" class="user-chip"></div>
				<button id="reset-demo" class="button button-tertiary button-small reset-demo-button" type="button">
					Reset
				</button>
				<button id="logout" class="button button-secondary button-small" type="button">
					Cerrar sesión
				</button>
			</div>
		</header>

		<aside class="sidebar" aria-label="Navegación principal">
			<nav id="sidebar-nav" class="sidebar-nav"></nav>
		</aside>

		<main id="app-main" class="app-main" tabindex="-1">
			<div id="app-content"></div>
		</main>

		<nav id="mobile-nav" class="mobile-nav" aria-label="Navegación móvil"></nav>
	</div>

	<div id="toast" class="toast hidden" role="status" aria-live="polite"></div>

	<script>
		type Role = 'admin_global' | 'validador_vacaciones' | 'empleado';
		type EntryStatus = 'correcto' | 'incidencia' | 'pendiente' | 'sin fichaje';
		type VacationStatus = 'pendiente' | 'aprobada' | 'denegada';
		type IncidentStatus = 'pendiente' | 'revisada';
		type TeamCalendarMode = 'month' | 'planning';

		type Session = {
			id: string;
			email: string;
			name: string;
			role: Role;
			department?: string;
			employeeId?: string;
		};

		type AppUser = {
			id: string;
			name: string;
			email: string;
			department: string;
			role: Role;
			active: boolean;
			employeeId?: string;
		};

		type Employee = {
			id: string;
			name: string;
			department: string;
			vacationDays: number;
		};

		type TimeBreak = {
			start: string;
			end?: string;
			kind?: 'manual' | 'quick' | 'meal';
			label?: string;
		};

		type TimeEntry = {
			id: string;
			employeeId: string;
			date: string;
			start?: string;
			breaks: TimeBreak[];
			end?: string;
			status: EntryStatus;
			notes?: string;
		};

		type VacationRequest = {
			id: string;
			employeeId: string;
			from: string;
			to: string;
			days: number;
			status: VacationStatus;
			comment?: string;
			denialReason?: string;
			createdAt: string;
			decidedAt?: string;
		};

		type Incident = {
			id: string;
			employeeId: string;
			date: string;
			type: string;
			detail: string;
			status: IncidentStatus;
			createdAt: string;
			reviewedAt?: string;
		};

		type Holiday = {
			id: string;
			date: string;
			name: string;
			center: string;
		};

		type AuditEntry = {
			id: string;
			at: string;
			user: string;
			action: string;
			detail: string;
		};

		type ScheduledReport = {
			id: string;
			reportType: string;
			frequency: string;
			sendDay: string;
			recipient: string;
			format: string;
			active: boolean;
			createdAt: string;
		};

		const KEYS = {
			demoVersion: 'fs_demoVersion',
			session: 'fs_session',
			timeEntries: 'fs_timeEntries',
			vacations: 'fs_vacations',
			incidents: 'fs_incidents',
			holidays: 'fs_holidays',
			scheduledReports: 'fs_scheduledReports',
			users: 'fs_users',
			audit: 'fs_audit',
		} as const;

		const DEMO_VERSION = 'fichaje-simple-roles-2026-07';

		const EMPLOYEES: Employee[] = [
			{ id: 'ana', name: 'Ana Martínez', department: 'Administración', vacationDays: 22 },
			{ id: 'carlos', name: 'Carlos Gómez', department: 'Operaciones', vacationDays: 22 },
			{ id: 'laura', name: 'Laura Pérez', department: 'Administración', vacationDays: 22 },
			{ id: 'miguel', name: 'Miguel Torres', department: 'Almacén', vacationDays: 22 },
			{ id: 'sara', name: 'Sara Navarro', department: 'Administración', vacationDays: 22 },
			{ id: 'javier', name: 'Javier Ruiz', department: 'Reparto', vacationDays: 22 },
			{ id: 'marta', name: 'Marta Soler', department: 'Atención al cliente', vacationDays: 22 },
		];

		const EMPLOYEE_VIEWS = [
			{ id: 'fichar', label: 'Fichar', hint: 'Entrada, descanso y salida' },
			{ id: 'vacaciones', label: 'Mis vacaciones', hint: 'Saldo y solicitudes' },
			{ id: 'calendario', label: 'Mi calendario', hint: 'Estados por día' },
			{ id: 'historial', label: 'Mi historial', hint: 'Registros mensuales' },
		];

		const VALIDATOR_VIEWS = [
			{ id: 'solicitudes', label: 'Solicitudes', hint: 'Validación de vacaciones' },
			{ id: 'calendario-equipo', label: 'Calendario equipo', hint: 'Vacaciones por departamento' },
			{ id: 'historico-vacaciones', label: 'Histórico vacaciones', hint: 'Solicitudes y estados' },
		];

		const ADMIN_VIEWS = [
			{ id: 'dashboard', label: 'Resumen', hint: 'Estado del equipo' },
			{ id: 'usuarios', label: 'Usuarios', hint: 'Altas y roles demo' },
			{ id: 'fichajes', label: 'Fichajes', hint: 'Consulta y CSV' },
			{ id: 'vacaciones-admin', label: 'Vacaciones', hint: 'Aprobaciones y solapes' },
			{ id: 'incidencias', label: 'Incidencias', hint: 'Pendientes de revisar' },
			{ id: 'informes', label: 'Informes', hint: 'Reportes y envíos simulados' },
			{ id: 'exportaciones', label: 'Exportaciones', hint: 'Descarga manual' },
			{ id: 'festivos', label: 'Festivos', hint: 'Calendario del centro' },
			{ id: 'auditoria', label: 'Auditoría', hint: 'Actividad local' },
			{ id: 'configuracion', label: 'Configuración', hint: 'Datos de demo' },
		];

		const STATUS_LABELS: Record<string, string> = {
			correcto: 'Correcto',
			incidencia: 'Incidencia',
			pendiente: 'Pendiente',
			'sin fichaje': 'Sin fichaje',
			festivo: 'Festivo',
			vacaciones: 'Vacaciones',
			'fin de semana': 'Fin de semana',
			aprobada: 'Aprobada',
			denegada: 'Denegada',
			revisada: 'Revisada',
			trabajando: 'Trabajando',
			pausa: 'En descanso',
			activo: 'Activo',
			inactivo: 'Inactivo',
		};

		let session: Session;
		let activeView = 'inicio';
		let calendarCursor = new Date();
		let selectedCalendarDay = todayIso();
		let selectedVacationId = '';
		let historyMonth = todayIso().slice(0, 7);
		let teamCalendarDepartment = 'all';
		let teamCalendarMode: TeamCalendarMode = 'month';
		let teamCalendarCursor = new Date();
		let selectedTeamCalendarDay = todayIso();
		let vacationHistoryFilters = {
			employeeId: 'all',
			department: 'all',
			status: 'all',
		};
		let timeFilters = {
			employeeId: 'all',
			from: startOfMonthIso(new Date()),
			to: todayIso(),
			status: 'all',
		};

		let timeEntries: TimeEntry[] = [];
		let vacations: VacationRequest[] = [];
		let incidents: Incident[] = [];
		let holidays: Holiday[] = [];
		let scheduledReports: ScheduledReport[] = [];
		let users: AppUser[] = [];
		let auditLog: AuditEntry[] = [];

		const shell = document.querySelector<HTMLDivElement>('#app-shell');
		const content = document.querySelector<HTMLDivElement>('#app-content');
		const sidebarNav = document.querySelector<HTMLElement>('#sidebar-nav');
		const mobileNav = document.querySelector<HTMLElement>('#mobile-nav');
		const userChip = document.querySelector<HTMLElement>('#user-chip');
		const toast = document.querySelector<HTMLElement>('#toast');
		let toastTimer: number | undefined;

		init();

		function init() {
			const rawSession = localStorage.getItem(KEYS.session);

			if (!rawSession) {
				window.location.href = '/';
				return;
			}

			try {
				session = JSON.parse(rawSession) as Session;
			} catch {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
				return;
			}

			if (!['admin_global', 'validador_vacaciones', 'empleado'].includes(session.role)) {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
				return;
			}

			loadDemoData();
			activeView = defaultViewForRole(session.role);
			renderShell();
			renderPage();
			bindGlobalEvents();
			window.setInterval(updateLiveClock, 1000);
			if (shell) shell.hidden = false;
		}

		function bindGlobalEvents() {
			document.querySelector('#logout')?.addEventListener('click', () => {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
			});

			document.querySelector('#reset-demo')?.addEventListener('click', () => {
				resetDemoData();
				showToast('Demo restablecida con datos ficticios iniciales.');
			});

			document.addEventListener('click', (event) => {
				const target = event.target as HTMLElement;
				const viewButton = target.closest<HTMLElement>('[data-view]');
				const actionButton = target.closest<HTMLElement>('[data-action]');

				if (viewButton) {
					activeView = viewButton.dataset.view || activeView;
					renderPage();
					renderNav();
					document.querySelector<HTMLElement>('#app-main')?.focus();
					return;
				}

				if (!actionButton) return;

				const action = actionButton.dataset.action;

				if (action === 'punch') performPunch();
				if (action === 'checkout') checkoutDay();
				if (action === 'quick-pause') addQuickPause(Number(actionButton.dataset.minutes || 15));
				if (action === 'toggle-manual') toggleManualForm();
				if (action === 'calendar-prev') changeCalendarMonth(-1);
				if (action === 'calendar-next') changeCalendarMonth(1);
				if (action === 'calendar-day') selectCalendarDay(actionButton.dataset.date || todayIso());
				if (action === 'team-calendar-prev') changeTeamCalendarMonth(-1);
				if (action === 'team-calendar-next') changeTeamCalendarMonth(1);
				if (action === 'team-calendar-day') selectTeamCalendarDay(actionButton.dataset.date || todayIso());
				if (action === 'review-incident') reviewIncident(actionButton.dataset.id || '');
				if (action === 'select-vacation') selectVacation(actionButton.dataset.id || '');
				if (action === 'approve-vacation') resolveVacation('aprobada');
				if (action === 'deny-vacation') resolveVacation('denegada');
				if (action === 'export-timesheets') exportTimesheets();
				if (action === 'simulate-pdf') showToast('PDF simulado listo. En producción se generaría un documento firmado.');
				if (action === 'export-generic') exportGeneric();
				if (action === 'toggle-user') toggleUser(actionButton.dataset.id || '');
				if (action === 'rotate-user-role') rotateUserRole(actionButton.dataset.id || '');
				if (action === 'simulate-edit-user') simulateEditUser(actionButton.dataset.id || '');
				if (action === 'reset-demo') {
					resetDemoData();
					showToast('Demo restablecida con datos ficticios iniciales.');
				}
			});

			document.addEventListener('change', (event) => {
				const target = event.target as HTMLElement;
				if (target.matches('#vacation-request-form input[name="from"], #vacation-request-form input[name="to"]')) {
					updateEmployeeVacationPreview();
				}
			});

			document.addEventListener('submit', (event) => {
				const form = event.target as HTMLFormElement;

				if (form.matches('#manual-form')) {
					event.preventDefault();
					saveManualAdjustment(form);
				}

				if (form.matches('#vacation-request-form')) {
					event.preventDefault();
					saveVacationRequest(form);
				}

				if (form.matches('#holiday-form')) {
					event.preventDefault();
					saveHoliday(form);
				}

				if (form.matches('#time-filter-form')) {
					event.preventDefault();
					applyTimeFilters(form);
				}

				if (form.matches('#report-schedule-form')) {
					event.preventDefault();
					saveScheduledReport(form);
				}

				if (form.matches('#user-form')) {
					event.preventDefault();
					saveUser(form);
				}

				if (form.matches('#team-calendar-filter-form')) {
					event.preventDefault();
					const formData = new FormData(form);
					teamCalendarDepartment = String(formData.get('department') || 'all');
					const nextMode = String(formData.get('mode') || 'month');
					teamCalendarMode = nextMode === 'planning' ? 'planning' : 'month';
					renderPage();
				}

				if (form.matches('#vacation-history-filter-form')) {
					event.preventDefault();
					const formData = new FormData(form);
					vacationHistoryFilters = {
						employeeId: String(formData.get('employeeId') || 'all'),
						department: String(formData.get('department') || 'all'),
						status: String(formData.get('status') || 'all'),
					};
					renderPage();
				}

				if (form.matches('#history-filter-form')) {
					event.preventDefault();
					const formData = new FormData(form);
					historyMonth = String(formData.get('month') || historyMonth);
					renderPage();
				}
			});
		}

		function renderShell() {
			if (userChip) {
				userChip.innerHTML = `
					<span>${roleLabel(session.role)}</span>
					<strong>${escapeHtml(session.name)}</strong>
				`;
			}
			renderNav();
		}

		function renderNav() {
			const views = getViews();
			const currentRoleLabel = roleLabel(session.role);
			const groupedViews = navigationGroups(views);
			const navIntro = `
				<div class="nav-context">
					<span>Vista activa</span>
					<strong>${currentRoleLabel}</strong>
					<small>${roleHint(session.role)}</small>
				</div>
			`;
			const sidebarHtml = groupedViews
				.map((group) => `
					<div class="nav-group">
						${group.label ? `<span class="nav-group-label">${group.label}</span>` : ''}
						${group.items.map(renderNavButton).join('')}
					</div>
				`)
				.join('');
			const mobileHtml = views
				.map(
					(view) => `
						<button
							class="button nav-button"
							type="button"
							data-view="${view.id}"
							aria-current="${activeView === view.id ? 'page' : 'false'}"
						>
							${view.label}
						</button>
					`,
				)
				.join('');

			if (sidebarNav) sidebarNav.innerHTML = navIntro + sidebarHtml;
			if (mobileNav) mobileNav.innerHTML = mobileHtml;
		}

		function renderNavButton(view: { id: string; label: string; hint: string }) {
			return `
				<button
					class="button nav-button"
					type="button"
					data-view="${view.id}"
					aria-current="${activeView === view.id ? 'page' : 'false'}"
				>
					<span class="nav-dot" aria-hidden="true"></span>
					<span>
						<strong>${view.label}</strong>
						<small>${view.hint}</small>
					</span>
				</button>
			`;
		}

		function renderPage() {
			if (!content) return;

			const viewMap: Record<string, () => string> = {
				inicio: renderEmployeeHome,
				fichar: renderPunchClock,
				calendario: renderCalendar,
				historial: renderHistory,
				vacaciones: renderEmployeeVacations,
				dashboard: renderAdminDashboard,
				usuarios: renderUsers,
				fichajes: renderAdminTimesheets,
				incidencias: renderAdminIncidents,
				'vacaciones-admin': renderAdminVacations,
				festivos: renderHolidays,
				informes: renderReports,
				exportaciones: renderExports,
				auditoria: renderAudit,
				configuracion: renderSettings,
				solicitudes: renderValidatorRequests,
				'calendario-equipo': renderTeamCalendar,
				'historico-vacaciones': renderVacationHistory,
			};

			content.innerHTML = viewMap[activeView]?.() || viewMap[defaultViewForRole(session.role)]?.() || renderPunchClock();
			updateLiveClock();
		}

		function renderEmployeeHome() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const status = currentWorkStatus(entry);
			const upcoming = vacations
				.filter(
					(request) =>
						request.employeeId === employee.id &&
						request.to >= todayIso() &&
						(request.status === 'aprobada' || request.status === 'pendiente'),
				)
				.sort((a, b) => a.from.localeCompare(b.from))
				.slice(0, 3);
			const todayIncidents = incidents.filter(
				(incident) => incident.employeeId === employee.id && incident.date === todayIso(),
			);

			return `
				${sectionTitle('Inicio', 'Resumen operativo de tu jornada y próximos permisos.')}
				<section class="panel quick-punch-card">
					<div>
						<span class="meta-label">Fichaje rápido</span>
						<strong>${status.label}</strong>
						<p class="helper-text">Hora actual: <span class="live-clock">${currentTimeWithSeconds()}</span></p>
					</div>
					<button class="button button-primary" type="button" data-action="punch" ${entry?.end ? 'disabled' : ''}>
						${punchActionLabel(entry)}
					</button>
				</section>
				<div class="grid grid-3">
					${metricCard('Estado actual', status.label, status.key)}
					${metricCard('Tiempo trabajado hoy', formatMinutes(workedMinutes(entry)), 'correcto')}
					${metricCard('Incidencias de hoy', String(todayIncidents.length), todayIncidents.length ? 'incidencia' : 'correcto')}
				</div>
				<div class="grid grid-2 top-gap">
					<section class="panel">
						<h2>Resumen de hoy</h2>
						<div class="summary-list">
							${summaryRow('Entrada', entry?.start || 'Sin registrar')}
							${summaryRow('Descansos', formatBreaks(entry))}
							${summaryRow('Salida', entry?.end || 'Sin registrar')}
							${summaryRow('Tiempo en descanso', formatMinutes(breakMinutes(entry)))}
							${summaryRow('Estado', pill(status.label, status.key))}
							${summaryRow('Incidencias', todayIncidents.length ? todayIncidents.map((item) => escapeHtml(item.type)).join(', ') : 'Sin incidencias')}
						</div>
					</section>
					<section class="panel">
						<h2>Próximas vacaciones</h2>
						${upcoming.length ? upcoming
							.map(
								(request) => `
									<div class="stat-row">
										<div>
											<strong>${formatDate(request.from)} - ${formatDate(request.to)}</strong>
											<span>${request.days} días · ${escapeHtml(request.comment || 'Sin comentario')}</span>
										</div>
										${pill(request.status)}
									</div>
								`,
							)
							.join('') : emptyState('No tienes vacaciones próximas aprobadas o pendientes.')}
					</section>
				</div>
			`;
		}

		function renderPunchClock() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const status = currentWorkStatus(entry);
			const actionLabel = punchActionLabel(entry);
			const actionHelp = punchHelpText(entry);
			const isOnBreak = Boolean(activeBreak(entry));
			const canCheckout = Boolean(entry?.start && !entry.end && !activeBreak(entry));
			const checkoutHelp = checkoutHelpText(entry);
			const weeklyWorked = workedMinutesThisWeek(employee.id);
			const weeklyOverLimit = weeklyWorked > 40 * 60;

			return `
				${sectionTitle('Fichar', 'Entrada, descansos y salida de hoy.')}
				<div class="grid punch-layout">
					<section class="panel punch-panel">
						<div class="punch-status-row">
							<div class="punch-state-card">
								<span class="meta-label">Estado actual</span>
								<strong>${status.label}</strong>
								<div class="top-gap-small">${pill(status.label, status.key)}</div>
							</div>
							<div class="clock-card">
								<span>Hora actual</span>
								<strong class="live-clock">${currentTimeWithSeconds()}</strong>
							</div>
						</div>
						<div class="punch-actions">
							<button class="button button-primary punch-button" type="button" data-action="punch" ${entry?.end ? 'disabled' : ''}>
								<span>${actionLabel}</span>
								<small>${actionHelp}</small>
							</button>
							<div class="checkout-action">
								<button class="button button-secondary punch-button punch-button-secondary" type="button" data-action="checkout" ${canCheckout ? '' : 'disabled'}>
									<span>Fichar salida</span>
									<small>${checkoutHelp}</small>
								</button>
								${isOnBreak ? '<p class="checkout-help">Finaliza el descanso antes de fichar salida.</p>' : ''}
							</div>
						</div>
						<div class="punch-kpis">
							<div>
								<span>Entrada</span>
								<strong>${entry?.start || '--:--'}</strong>
							</div>
							<div>
								<span>Descansos</span>
								<strong>${entry?.breaks.length || 0}</strong>
							</div>
							<div>
								<span>Salida</span>
								<strong>${entry?.end || '--:--'}</strong>
							</div>
							<div>
								<span>Trabajado hoy</span>
								<strong>${formatMinutes(workedMinutes(entry))}</strong>
							</div>
							<div>
								<span>En descanso</span>
								<strong>${formatMinutes(breakMinutes(entry))}</strong>
							</div>
							<div class="${weeklyOverLimit ? 'punch-kpi-alert' : ''}">
								<span>Trabajado semanal</span>
								<strong>${formatMinutes(weeklyWorked)}</strong>
								${weeklyOverLimit ? '<small>Supera 40 h</small>' : ''}
							</div>
						</div>
					</section>
					<section class="panel quick-actions-panel">
						<h2>Acciones rápidas</h2>
						<p class="helper-text">Usa estas pausas cuando ya estés trabajando. Para un descanso abierto, usa el botón principal.</p>
						<div class="tab-actions">
							<button class="button button-secondary" type="button" data-action="quick-pause" data-minutes="15">
								Pausa 15 min
							</button>
							<button class="button button-secondary" type="button" data-action="quick-pause" data-minutes="30">
								Pausa 30 min
							</button>
							<button class="button button-secondary" type="button" data-action="quick-pause" data-minutes="60">
								Comida 1 h
							</button>
							<button class="button button-secondary" type="button" data-action="quick-pause" data-minutes="120">
								Comida 2 h
							</button>
							<button class="button button-ghost" type="button" data-action="toggle-manual">
								Editar registro de hoy
							</button>
						</div>
						<div class="break-summary">
							<span class="meta-label">Descansos de hoy</span>
							${renderBreakList(entry)}
						</div>
						<div id="manual-adjustment" class="manual-box hidden">
							${manualAdjustmentForm()}
						</div>
					</section>
				</div>
			`;
