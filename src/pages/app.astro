---
import Layout from '../layouts/Layout.astro';
import '../styles/employee-v2.css';
import '../styles/responsible-v2.css';
---

<Layout title="FichajeSimple">
	<div id="app-shell" class="app-shell" hidden>
		<header class="app-header">
			<div class="header-left">
				<div class="brand-lockup" aria-label="FichajeSimple">
					<img class="brand-icon" src="/brand/fichajesimple-icon.png" alt="FichajeSimple" />
					<div>
						<strong>FichajeSimple</strong>
						<span class="muted-line">Empresa Demo · Centro Principal</span>
					</div>
				</div>
				<span class="demo-badge">Demo pública · Datos ficticios · Navegador</span>
			</div>

			<div class="header-actions">
				<div id="user-chip" class="user-chip"></div>
				<button id="reset-demo" class="button button-tertiary button-small reset-demo-button" type="button" title="Restablece los datos demo 2026 y borra cambios locales del navegador">
					Demo 2026
				</button>
				<button id="logout" class="button button-secondary button-small" type="button">
					Cerrar sesión
				</button>
			</div>
		</header>

		<aside class="sidebar" aria-label="Navegación principal">
			<nav id="sidebar-nav" class="sidebar-nav"></nav>
		</aside>

		<main id="app-main" class="app-main" tabindex="-1">
			<div id="app-content"></div>
		</main>

		<nav id="mobile-nav" class="mobile-nav" aria-label="Navegación móvil"></nav>
	</div>

	<div id="toast" class="toast hidden" role="status" aria-live="polite"></div>

	<script>
		type EmployeeAbsenceFilter = 'all' | 'pending' | 'approved' | 'history';

		import type {
			AbsenceCategory,
			AdminIncidentFilter,
			AdminTodayFilter,
			AppUser,
			AuditEntry,
			DemoData,
			DocumentRequirement,
			Employee,
			EmployeeVacationFilter,
			Holiday,
			Incident,
			Role,
			ScheduledReport,
			Session,
			TeamCalendarMode,
			TimeBreak,
			TimeEntry,
			VacationRequest,
			VacationStatus,
		} from '../lib/types';
		import { createDemoData } from '../data/demo';
		import {
			ABSENCE_TYPES,
			DEFAULT_ABSENCE_TYPE_ID,
		} from '../config/absence-types';
		import {
			loadDemoDataFromStorage,
			saveDemoDataToStorage,
		} from '../lib/storage';
		import {
			ADMIN_VIEWS,
			DEMO_YEAR,
			EMPLOYEE_VIEWS,
			EMPLOYEES,
			KEYS,
			STATUS_LABELS,
			VALIDATOR_VIEWS,
		} from '../config/app';
		import {
			addDaysIso,
			clampDateIso,
			dateInRange,
			dateRange,
			diffDays,
			isDateWithin,
			isWeekend,
			isoFromDate,
			monthKey,
			monthLabel,
			monthRangeFromInput,
			startOfMonthIso,
			startOfWeekIso,
			todayIso,
			weekInputValue,
			weekRangeFromInput,
		} from '../lib/date';
		import {
			escapeHtml,
			formatDate,
			formatDateTime,
			formatDayHeader,
			statusClass,
			weekdayShort,
		} from '../lib/format';
		import {
			addMinutesToTime,
			currentTime,
			currentTimeWithSeconds,
			formatMinutes,
			formatSignedMinutes,
			timeToMinutes,
		} from '../lib/time';
		import { downloadCsv } from '../lib/csv';
		import {
			activeBreak,
			breakLabel,
			breakMinutes,
			elapsedMinutes,
			formatBreaks,
			recalculateTimeEntryStatus,
			validateManualTimeAdjustment,
			workedMinutes,
		} from '../domain/time-entry';
		import {
			businessDaysBetween as calculateBusinessDaysBetween,
			businessRangesOverlap as checkBusinessRangesOverlap,
			calculateVacationBalance,
			countVacationDaysInRange as calculateVacationDaysInRange,
			filterEmployeeVacationRequests as filterVacationRequests,
			absenceDeductsVacationBalance,
			absenceConflictRequests,
			absenceUsesHours,
			findAbsenceType,
			isActiveVacationRequest as checkActiveVacationRequest,
			isBusinessDay as checkBusinessDay,
			isEnjoyedVacation as checkEnjoyedVacation,
			isFutureApprovedVacation as checkFutureApprovedVacation,
			resolveAbsenceTypeId,
			vacationConflictCounts as calculateVacationConflictCounts,
			vacationConflictDetails as calculateVacationConflictDetails,
			vacationRequestDays as calculateVacationRequestDays,
		} from '../domain/absence';

		let session: Session;
		let activeView = 'inicio';
		let calendarCursor = new Date();
		let selectedCalendarDay = '';
		let calendarAdjustmentDate = '';
		let selectedVacationId = '';
		let employeeVacationFilter: EmployeeVacationFilter = 'all';
		let employeeAbsenceFilter: EmployeeAbsenceFilter = 'all';
		let employeeAbsenceFormOpen = false;
		let employeeVacationPreviewWeekStart = '';
		let historyMonth = todayIso().slice(0, 7);
		let teamCalendarDepartment = 'all';
		let teamCalendarMode: TeamCalendarMode = 'month';
		let teamCalendarCursor = new Date();
		let selectedTeamCalendarDay = '';
		let adminVacationCursor = new Date();
		let selectedAdminVacationDay = '';
		let adminVacationFilters: {
			employeeId: string;
			department: string;
		} = {
			employeeId: 'all',
			department: 'all',
		};
		let vacationHistoryFilters = {
			employeeId: 'all',
			department: 'all',
			status: 'all',
		};
		let validatorRequestFilter: VacationStatus | 'all' = 'pendiente';
		let timeFilters = {
			employeeId: 'all',
			from: startOfMonthIso(new Date()),
			to: todayIso(),
			status: 'all',
		};
		let adminTodayFilter: AdminTodayFilter = 'all';
		let adminIncidentFilter: AdminIncidentFilter = 'pendiente';
		let adminUserSearch = '';
		let selectedAdminUserId = '';
		let selectedTimesheetSummaryKey = '';

		let timeEntries: TimeEntry[] = [];
		let vacations: VacationRequest[] = [];
		let incidents: Incident[] = [];
		let holidays: Holiday[] = [];
		let scheduledReports: ScheduledReport[] = [];
		let users: AppUser[] = [];
		let auditLog: AuditEntry[] = [];

		const shell = document.querySelector<HTMLDivElement>('#app-shell');
		const content = document.querySelector<HTMLDivElement>('#app-content');
		const sidebarNav = document.querySelector<HTMLElement>('#sidebar-nav');
		const mobileNav = document.querySelector<HTMLElement>('#mobile-nav');
		const userChip = document.querySelector<HTMLElement>('#user-chip');
		const toast = document.querySelector<HTMLElement>('#toast');
		let toastTimer: number | undefined;

		init();

		function init() {
			const rawSession = localStorage.getItem(KEYS.session);

			if (!rawSession) {
				window.location.href = '/';
				return;
			}

			try {
				session = JSON.parse(rawSession) as Session;
			} catch {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
				return;
			}

			if (!['admin_global', 'validador_vacaciones', 'empleado'].includes(session.role)) {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
				return;
			}

			loadDemoData();
			activeView = defaultViewForRole(session.role);
			renderShell();
			renderPage();
			bindGlobalEvents();
			window.setInterval(updateLiveClock, 1000);
			if (shell) shell.hidden = false;
		}

		function bindGlobalEvents() {
			document.querySelector('#logout')?.addEventListener('click', () => {
				localStorage.removeItem(KEYS.session);
				window.location.href = '/';
			});

			document.querySelector('#reset-demo')?.addEventListener('click', () => {
				resetDemoData();
				showToast('Datos demo 2026 restablecidos. Se han borrado los cambios locales del navegador.');
			});

			document.addEventListener('click', (event) => {
				const target = event.target as HTMLElement;
				const viewButton = target.closest<HTMLElement>('[data-view]');
				const actionButton = target.closest<HTMLElement>('[data-action]');

				if (viewButton) {
					activeView = viewButton.dataset.view || activeView;
					renderPage();
					renderNav();
					document.querySelector<HTMLElement>('#app-main')?.focus();
					return;
				}

				if (!actionButton) return;

				const action = actionButton.dataset.action;

				if (action === 'punch') performPunch();
				if (action === 'checkout') checkoutDay();
				if (action === 'quick-pause') addQuickPause(Number(actionButton.dataset.minutes || 15));
				if (action === 'toggle-manual') toggleManualForm();
				if (action === 'calendar-prev') changeCalendarMonth(-1);
				if (action === 'calendar-next') changeCalendarMonth(1);
				if (action === 'calendar-day') selectCalendarDay(actionButton.dataset.date || todayIso());
				if (action === 'open-calendar-adjustment') openCalendarAdjustment(actionButton.dataset.date || selectedCalendarDay);
				if (action === 'close-calendar-adjustment') closeCalendarAdjustment();
				if (action === 'employee-vacation-filter') setEmployeeVacationFilter(actionButton.dataset.filter || 'all');
				if (action === 'toggle-absence-form') toggleEmployeeAbsenceForm();
				if (action === 'employee-absence-filter') setEmployeeAbsenceFilter(actionButton.dataset.filter || 'all');
				if (action === 'employee-vacation-week-prev') shiftEmployeeVacationPreviewWeek(-7);
				if (action === 'employee-vacation-week-next') shiftEmployeeVacationPreviewWeek(7);
				if (action === 'cancel-employee-vacation') cancelEmployeeVacation(actionButton.dataset.id || '');
				if (action === 'admin-vacation-prev') changeAdminVacationMonth(-1);
				if (action === 'admin-vacation-next') changeAdminVacationMonth(1);
				if (action === 'admin-vacation-day') selectAdminVacationDay(actionButton.dataset.date || todayIso());
				if (action === 'team-calendar-prev') changeTeamCalendarMonth(-1);
				if (action === 'team-calendar-next') changeTeamCalendarMonth(1);
				if (action === 'team-calendar-day') selectTeamCalendarDay(actionButton.dataset.date || todayIso());
				if (action === 'review-incident') reviewIncident(actionButton.dataset.id || '');
				if (action === 'select-vacation') selectVacation(actionButton.dataset.id || '');
				if (action === 'validator-request-filter') setValidatorRequestFilter(actionButton.dataset.filter || 'pendiente');
				if (action === 'approve-vacation') resolveVacation('aprobada', actionButton.dataset.id || '');
				if (action === 'deny-vacation') resolveVacation('denegada', actionButton.dataset.id || '');
				if (action === 'delete-holiday') deleteHoliday(actionButton.dataset.id || '');
				if (action === 'export-timesheets') exportTimesheets();
				if (action === 'export-timesheets-simple') exportTimesheetsFromExportForm();
				if (action === 'export-hours-report-simple') exportHoursReportFromForm();
				if (action === 'simulate-pdf') showToast('PDF simulado listo. En producción se generaría un documento firmado.');
				if (action === 'export-generic') exportGeneric();
				if (action === 'toggle-user') toggleUser(actionButton.dataset.id || '');
				if (action === 'rotate-user-role') rotateUserRole(actionButton.dataset.id || '');
				if (action === 'simulate-edit-user') simulateEditUser(actionButton.dataset.id || '');
				if (action === 'admin-today-filter') setAdminTodayFilter(actionButton.dataset.filter || 'all');
				if (action === 'open-pending-incidents') openPendingIncidents();
				if (action === 'select-admin-user') selectAdminUser(actionButton.dataset.id || '');
				if (action === 'select-timesheet-summary') selectTimesheetSummary(actionButton.dataset.id || '');
				if (action === 'admin-incident-filter') setAdminIncidentFilter(actionButton.dataset.filter || 'pendiente');
				if (action === 'reset-demo') {
					resetDemoData();
					showToast('Datos demo 2026 restablecidos. Se han borrado los cambios locales del navegador.');
				}
			});

			document.addEventListener('change', (event) => {
				const target = event.target as HTMLElement;
				if (target.closest('#absence-request-form')) {
					updateEmployeeAbsenceForm();
				}

				const teamCalendarForm = target.closest<HTMLFormElement>('#team-calendar-filter-form');
				if (teamCalendarForm && target.matches('select')) {
					applyTeamCalendarFilters(teamCalendarForm);
				}

				if (target.matches('#export-hours-report-form select[name="scope"]')) {
					updateExportReportPeriodFields();
				}
			});

			document.addEventListener('input', (event) => {
				const target = event.target as HTMLElement;
				if (target.closest('#absence-request-form')) {
					updateEmployeeAbsenceForm();
				}
			});

			document.addEventListener('submit', (event) => {
				const form = event.target as HTMLFormElement;

				if (form.matches('#manual-form')) {
					event.preventDefault();
					saveManualAdjustment(form);
				}

				if (form.matches('#absence-request-form')) {
					event.preventDefault();
					saveAbsenceRequest(form);
				}

				if (form.matches('#holiday-form')) {
					event.preventDefault();
					saveHoliday(form);
				}

				if (form.matches('#time-filter-form')) {
					event.preventDefault();
					applyTimeFilters(form);
				}

				if (form.matches('#report-schedule-form')) {
					event.preventDefault();
					saveScheduledReport(form);
				}

				if (form.matches('#user-form')) {
					event.preventDefault();
					saveUser(form);
				}

				if (form.matches('#user-search-form')) {
					event.preventDefault();
					applyUserSearch(form);
				}

				if (form.matches('#team-calendar-filter-form')) {
					event.preventDefault();
					applyTeamCalendarFilters(form);
				}

				if (form.matches('#admin-vacation-filter-form')) {
					event.preventDefault();
					applyAdminVacationFilters(form);
				}

				if (form.matches('#vacation-history-filter-form')) {
					event.preventDefault();
					const formData = new FormData(form);
					vacationHistoryFilters = {
						employeeId: String(formData.get('employeeId') || 'all'),
						department: String(formData.get('department') || 'all'),
						status: String(formData.get('status') || 'all'),
					};
					renderPage();
				}

				if (form.matches('#history-filter-form')) {
					event.preventDefault();
					const formData = new FormData(form);
					historyMonth = String(formData.get('month') || historyMonth);
					renderPage();
				}
			});
		}

		function renderShell() {
			if (shell) {
				shell.dataset.role = session.role;
			}
			if (userChip) {
				const displayName = session.role === 'validador_vacaciones'
					? 'Responsable de ausencias'
					: session.name;
				userChip.innerHTML = `
					<span>${roleLabel(session.role)}</span>
					<strong>${escapeHtml(displayName)}</strong>
				`;
			}
			renderNav();
		}

		function renderNav() {
			const views = getViews();
			const currentRoleLabel = roleLabel(session.role);
			const groupedViews = navigationGroups(views);
			const navIntro = `
				<div class="nav-context">
					<span>Vista activa</span>
					<strong>${currentRoleLabel}</strong>
					<small>${roleHint(session.role)}</small>
				</div>
			`;
			const sidebarHtml = groupedViews
				.map((group) => `
					<div class="nav-group">
						${group.label ? `<span class="nav-group-label">${group.label}</span>` : ''}
						${group.items.map(renderNavButton).join('')}
					</div>
				`)
				.join('');
			const mobileHtml = views
				.map(
					(view) => `
						<button
							class="button nav-button"
							type="button"
							data-view="${view.id}"
							aria-current="${activeView === view.id ? 'page' : 'false'}"
						>
							${session.role === 'empleado' ? employeeNavIcon(view.id) : ''}
							<span>${view.label}</span>
						</button>
					`,
				)
				.join('');

			if (sidebarNav) sidebarNav.innerHTML = navIntro + sidebarHtml;
			if (mobileNav) mobileNav.innerHTML = mobileHtml;
		}

		function renderNavButton(view: { id: string; label: string; hint: string }) {
			return `
				<button
					class="button nav-button"
					type="button"
					data-view="${view.id}"
					aria-current="${activeView === view.id ? 'page' : 'false'}"
				>
					<span class="nav-dot" aria-hidden="true"></span>
					<span>
						<strong>${view.label}</strong>
						<small>${view.hint}</small>
					</span>
				</button>
			`;
		}

		function employeeNavIcon(viewId: string) {
			if (viewId === 'fichar') {
				return `
					<svg class="employee-v2-nav-icon" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="8"></circle>
						<path d="M12 7v5l3 2"></path>
					</svg>
				`;
			}

			if (viewId === 'vacaciones') {
				return `
					<svg class="employee-v2-nav-icon" viewBox="0 0 24 24" aria-hidden="true">
						<rect x="4" y="5" width="16" height="15" rx="2"></rect>
						<path d="M8 3v4M16 3v4M4 10h16M9 15l2 2 4-5"></path>
					</svg>
				`;
			}

			if (viewId === 'calendario') {
				return `
					<svg class="employee-v2-nav-icon" viewBox="0 0 24 24" aria-hidden="true">
						<rect x="4" y="5" width="16" height="15" rx="2"></rect>
						<path d="M8 3v4M16 3v4M4 10h16"></path>
					</svg>
				`;
			}

			return `
				<svg class="employee-v2-nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="12" cy="8" r="4"></circle>
					<path d="M5 20a7 7 0 0 1 14 0"></path>
				</svg>
			`;
		}

		function renderPage() {
			if (!content) return;

			const viewMap: Record<string, () => string> = {
				inicio: renderEmployeeHome,
				fichar: renderPunchClock,
				calendario: renderCalendar,
				historial: renderHistory,
				vacaciones: renderEmployeeVacations,
				perfil: renderEmployeeProfile,
				dashboard: renderAdminDashboard,
				usuarios: renderUsers,
				fichajes: renderAdminTimesheets,
				incidencias: renderAdminIncidents,
				'vacaciones-admin': renderAdminVacations,
				festivos: renderHolidays,
				informes: renderReports,
				exportaciones: renderExports,
				auditoria: renderAudit,
				configuracion: renderSettings,
				solicitudes: renderValidatorRequests,
				'calendario-equipo': renderTeamCalendar,
				'historico-vacaciones': renderVacationHistory,
			};

			content.innerHTML = viewMap[activeView]?.() || viewMap[defaultViewForRole(session.role)]?.() || renderPunchClock();
			updateLiveClock();
			if (session.role === 'empleado' && activeView === 'vacaciones') {
				queueMicrotask(updateEmployeeAbsenceForm);
			}
		}

		function renderEmployeeHome() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const status = currentWorkStatus(entry);
			const upcoming = vacations
				.filter(
					(request) =>
						request.employeeId === employee.id &&
						request.to >= todayIso() &&
						(request.status === 'aprobada' || request.status === 'pendiente'),
				)
				.sort((a, b) => a.from.localeCompare(b.from))
				.slice(0, 3);
			const todayIncidents = incidents.filter(
				(incident) => incident.employeeId === employee.id && incident.date === todayIso(),
			);

			return `
				${sectionTitle('Inicio', 'Resumen operativo de tu jornada y próximos permisos.')}
				<section class="panel quick-punch-card">
					<div>
						<span class="meta-label">Fichaje rápido</span>
						<strong>${status.label}</strong>
						<p class="helper-text">Hora actual: <span class="live-clock">${currentTimeWithSeconds()}</span></p>
					</div>
					<button class="button button-primary" type="button" data-action="punch" ${entry?.end ? 'disabled' : ''}>
						${punchActionLabel(entry)}
					</button>
				</section>
				<div class="grid grid-3">
					${metricCard('Estado actual', status.label, status.key)}
					${metricCard('Tiempo trabajado hoy', formatMinutes(workedMinutes(entry)), 'correcto')}
					${metricCard('Incidencias de hoy', String(todayIncidents.length), todayIncidents.length ? 'incidencia' : 'correcto')}
				</div>
				<div class="grid grid-2 top-gap">
					<section class="panel">
						<h2>Resumen de hoy</h2>
						<div class="summary-list">
							${summaryRow('Entrada', entry?.start || 'Sin registrar')}
							${summaryRow('Descansos', formatBreaks(entry))}
							${summaryRow('Salida', entry?.end || 'Sin registrar')}
							${summaryRow('Tiempo en descanso', formatMinutes(breakMinutes(entry)))}
							${summaryRow('Estado', pill(status.label, status.key))}
							${summaryRow('Incidencias', todayIncidents.length ? todayIncidents.map((item) => escapeHtml(item.type)).join(', ') : 'Sin incidencias')}
						</div>
					</section>
					<section class="panel">
						<h2>Próximas vacaciones</h2>
						${upcoming.length ? upcoming
							.map(
								(request) => `
									<div class="stat-row">
										<div>
											<strong>${formatDate(request.from)} - ${formatDate(request.to)}</strong>
											<span>${request.days} días · ${escapeHtml(request.comment || 'Sin comentario')}</span>
										</div>
										${pill(request.status)}
									</div>
								`,
							)
							.join('') : emptyState('No tienes vacaciones próximas aprobadas o pendientes.')}
					</section>
				</div>
			`;
		}

		function renderPunchClock() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const status = currentWorkStatus(entry);
			const actionLabel = punchActionLabel(entry);
			const actionHelp = punchHelpText(entry);
			const isOnBreak = Boolean(activeBreak(entry));
			const canCheckout = Boolean(entry?.start && !entry.end && !activeBreak(entry));
			const checkoutHelp = checkoutHelpText(entry);
			const weeklyWorked = workedMinutesThisWeek(employee.id);
			const firstName = employee.name.split(' ')[0];
			const todayLabel = new Date(`${todayIso()}T12:00:00`).toLocaleDateString('es-ES', {
				weekday: 'long',
				day: 'numeric',
				month: 'long',
			});
			const timelineItems = [
				entry?.start
					? `<li class="employee-v2-timeline-item is-done"><span>Entrada</span><strong>${entry.start}</strong></li>`
					: `<li class="employee-v2-timeline-item"><span>Entrada</span><strong>Sin registrar</strong></li>`,
				...(entry?.breaks || []).map(
					(item) => `
						<li class="employee-v2-timeline-item ${item.end ? 'is-done' : 'is-current'}">
							<span>${breakLabel(item)}</span>
							<strong>${item.start} - ${item.end || 'abierta'}</strong>
						</li>
					`,
				),
				entry?.end
					? `<li class="employee-v2-timeline-item is-done"><span>Salida</span><strong>${entry.end}</strong></li>`
					: `<li class="employee-v2-timeline-item"><span>Salida</span><strong>Sin registrar</strong></li>`,
			].join('');

			return `
				<div class="employee-v2-page">
					<header class="employee-v2-header">
						<p>${todayLabel}</p>
						<h1>Hola, ${escapeHtml(firstName)}</h1>
						<span>Gestiona tu jornada de hoy.</span>
					</header>

					<section class="employee-v2-status-card">
						<div class="employee-v2-status-top">
							<div>
