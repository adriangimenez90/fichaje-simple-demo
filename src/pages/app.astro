		}

		function manualAdjustmentForm(date = todayIso(), source: 'punch' | 'calendar' = 'punch') {
			const employee = currentEmployee();
			const entry = findEntry(employee.id, date);
			const salidaNextDay = Boolean(entry?.start && entry?.end && timeToMinutes(entry.end) < timeToMinutes(entry.start));
			const isCalendarSource = source === 'calendar';
			const title = isCalendarSource
				? entry
					? 'Editar registro'
					: 'Crear registro'
				: 'Ajustar horas de hoy';
			const status = entry
				? isCalendarSource
					? { label: STATUS_LABELS[statusForDay(employee.id, date)] || statusForDay(employee.id, date), key: statusForDay(employee.id, date) }
					: currentWorkStatus(entry)
				: { label: 'Sin fichaje', key: 'sin fichaje' };
			const breakFields = entry?.breaks.length
				? entry.breaks
					.map(
						(item, index) => `
							<fieldset class="manual-break-field">
								<legend>${escapeHtml(breakLabel(item))} ${index + 1}</legend>
								<label class="field">
									<span>Inicio de pausa</span>
									<input type="time" name="break-start-${index}" value="${item.start || ''}" required />
								</label>
								<label class="field">
									<span>Fin de pausa</span>
									<input type="time" name="break-end-${index}" value="${item.end || ''}" />
								</label>
							</fieldset>
						`,
					)
					.join('')
				: isCalendarSource && !entry
					? `
						<fieldset class="manual-break-field">
							<legend>Pausa opcional</legend>
							<label class="field">
								<span>Inicio de pausa</span>
								<input type="time" name="new-break-start" />
							</label>
							<label class="field">
								<span>Fin de pausa</span>
								<input type="time" name="new-break-end" />
							</label>
						</fieldset>
					`
					: `<div class="manual-empty">No hay pausas registradas para ${isCalendarSource ? 'este día' : 'editar hoy'}.</div>`;

			return `
				<form id="manual-form" class="manual-editor ${isCalendarSource ? 'calendar-manual-editor' : ''} top-gap">
					<div class="manual-editor-head">
						<div>
							<span class="meta-label">${title}</span>
							<strong>${formatDate(date)}</strong>
						</div>
						${pill(status.label, status.key)}
					</div>
					<input type="hidden" name="date" value="${date}" />
					<input type="hidden" name="source" value="${source}" />
					<div class="manual-editor-grid">
						<label class="field">
							<span>Hora de entrada</span>
							<input type="time" name="start" value="${entry?.start || ''}" required />
						</label>
						<label class="field">
							<span>Hora de salida</span>
							<input type="time" name="end" value="${entry?.end || ''}" />
						</label>
					</div>
					<label class="manual-check">
						<input type="checkbox" name="endNextDay" ${salidaNextDay ? 'checked' : ''} />
						<span>La salida fue al día siguiente</span>
					</label>
					<div class="manual-breaks">
						<div>
							<span class="meta-label">${entry ? 'Pausas existentes' : 'Pausa opcional'}</span>
							<p class="helper-text">${entry ? 'Puedes corregir inicio y fin de cada pausa ya registrada.' : 'Puedes añadir una pausa si ese día hubo descanso.'}</p>
						</div>
						${breakFields}
					</div>
					<label class="field">
						<span>Motivo del ajuste (opcional)</span>
						<textarea name="reason" placeholder="Ejemplo: corrección solicitada por olvido al fichar"></textarea>
					</label>
					<p class="manual-message" data-manual-message hidden></p>
					<div class="manual-actions">
						<button class="button button-primary" type="submit">${entry ? 'Guardar ajuste' : 'Crear registro'}</button>
						<button class="button button-secondary" type="button" data-action="${isCalendarSource ? 'close-calendar-adjustment' : 'toggle-manual'}">Cancelar</button>
					</div>
					<fieldset class="hidden" disabled>
					<label class="field">
						<span>Tipo</span>
						<select name="type" required>
							<option value="Entrada olvidada">Entrada olvidada</option>
							<option value="Salida olvidada">Salida olvidada</option>
							<option value="Pausa olvidada">Pausa olvidada</option>
							<option value="Corrección de hora">Corrección de hora</option>
						</select>
					</label>
					<label class="field">
						<span>Fecha</span>
						<input type="date" name="date" value="${date}" required />
					</label>
					<label class="field">
						<span>Hora</span>
						<input type="time" name="time" value="${currentTime()}" required />
					</label>
					<label class="field">
						<span>Motivo obligatorio</span>
						<textarea name="reason" required placeholder="Describe el motivo del ajuste"></textarea>
					</label>
					<button class="button button-primary" type="submit">Guardar ajuste</button>
					</fieldset>
				</form>
			`;
		}

		function renderDayDetail(employeeId: string, date: string, allowManualAdjustment = false) {
			const entry = findEntry(employeeId, date);
			const dayStatus = statusForDay(employeeId, date);
			const holiday = holidays.find((item) => item.date === date);
			const vacation = vacations.find(
				(request) =>
					request.employeeId === employeeId &&
					isActiveVacationRequest(request) &&
					isBusinessDay(date) &&
					isDateWithin(date, request.from, request.to),
			);
			const dayIncidents = incidents.filter(
				(incident) => incident.employeeId === employeeId && incident.date === date,
			);
			const incidentText = dayIncidents.length
				? dayIncidents.map((item) => `${escapeHtml(item.type)}: ${escapeHtml(item.detail)}`).join('<br>')
				: 'Sin incidencias';
			const isFutureDay = date > todayIso();
			const isSpecialDay = isWeekend(date) || Boolean(holiday);
			const isAdjustmentOpen = allowManualAdjustment && calendarAdjustmentDate === date;
			const actionLabel = dayStatus === 'incidencia' || dayIncidents.length ? 'Corregir incidencia' : 'Editar registro';
			const actionClass = dayStatus === 'incidencia' || dayIncidents.length ? 'button-danger' : 'button-secondary';
			const specialDayNote = isSpecialDay
				? '<p class="calendar-day-note">Este día parece fin de semana o festivo.</p>'
				: '';

			if (!entry) {
				return `
					<div class="day-detail">
						<div class="day-detail-head">
							<div>
								<span class="meta-label">Detalle del día</span>
								<h3>${formatDate(date)}</h3>
							</div>
							${pill(STATUS_LABELS[dayStatus] || dayStatus, dayStatus)}
						</div>
						${emptyState('No hay registro de jornada para este día.')}
						${allowManualAdjustment ? `
							<div class="day-detail-actions">
								${isFutureDay ? `
									<p class="calendar-day-note">No se pueden crear registros futuros en la demo.</p>
								` : `
									${specialDayNote}
									<button class="button button-primary" type="button" data-action="open-calendar-adjustment" data-date="${date}">Crear registro</button>
								`}
							</div>
							${isAdjustmentOpen && !isFutureDay ? manualAdjustmentForm(date, 'calendar') : ''}
						` : ''}
						<div class="summary-list top-gap">
							${summaryRow('Festivo', holiday ? escapeHtml(holiday.name) : 'No')}
							${summaryRow('Vacaciones', vacation ? `${formatDate(vacation.from)} - ${formatDate(vacation.to)} (${vacation.status})` : 'No')}
							${summaryRow('Incidencia', incidentText)}
						</div>
					</div>
				`;
			}

			return `
				<div class="day-detail">
					<div class="day-detail-head">
						<div>
							<span class="meta-label">Detalle del día</span>
							<h3>${formatDate(date)}</h3>
						</div>
						${pill(STATUS_LABELS[dayStatus] || dayStatus, dayStatus)}
					</div>
					<div class="day-detail-grid">
						<div><span>Entrada</span><strong>${entry.start || 'Sin registrar'}</strong></div>
						<div><span>Pausas / descansos</span><strong>${formatBreaks(entry)}</strong></div>
						<div><span>Salida</span><strong>${entry.end || 'Sin registrar'}</strong></div>
						<div><span>Trabajado</span><strong>${formatMinutes(workedMinutes(entry))}</strong></div>
						<div><span>Descanso</span><strong>${formatMinutes(breakMinutes(entry))}</strong></div>
					</div>
					${allowManualAdjustment ? `
						<div class="day-detail-actions">
							<button class="button ${actionClass}" type="button" data-action="open-calendar-adjustment" data-date="${date}">${actionLabel}</button>
						</div>
						${isAdjustmentOpen ? manualAdjustmentForm(date, 'calendar') : ''}
					` : ''}
					<div class="summary-list top-gap">
						${summaryRow('Festivo', holiday ? escapeHtml(holiday.name) : 'No')}
						${summaryRow('Vacaciones', vacation ? `${formatDate(vacation.from)} - ${formatDate(vacation.to)} (${vacation.status})` : 'No')}
						${summaryRow('Incidencia', incidentText)}
					</div>
				</div>
			`;
		}

		function renderVacationRow(request: VacationRequest) {
			const days = vacationRequestDays(request);
