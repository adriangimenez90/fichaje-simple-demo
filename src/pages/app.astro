		function buildExpectedHoursReport(scope: 'week' | 'month', from: string, to: string, employeeId = 'all') {
			const employees = EMPLOYEES.filter((employee) => employeeId === 'all' || employee.id === employeeId);
			const period = scope === 'week'
				? `Semana ${formatDate(from)} - ${formatDate(to)}`
				: monthLabel(from.slice(0, 7));

			return employees.map((employee) => {
				const entries = timeEntries.filter(
					(entry) => entry.employeeId === employee.id && dateInRange(entry.date, from, to),
				);
				const worked = entries.reduce((sum, entry) => sum + workedMinutes(entry), 0);
				const laborDays = businessDaysBetween(from, to);
				const vacationDays = countVacationDaysInRange(employee.id, from, to);
				const expectedDays = Math.max(laborDays - vacationDays, 0);
				const expected = expectedDays * 8 * 60;
				const employeeIncidents = incidents.filter(
					(incident) => incident.employeeId === employee.id && dateInRange(incident.date, from, to),
				).length;
				return [
					employee.name,
					employee.department,
					period,
					formatMinutes(worked),
					formatMinutes(expected),
					formatSignedMinutes(worked - expected),
					String(employeeIncidents),
				];

			});
		}

