		function renderVacationComparisonCell(employeeId: string, date: string, request: VacationRequest) {
			if (!isBusinessDay(date)) {
				return `<td class="comparison-cell cell-off">--</td>`;
			}

			if (employeeId === request.employeeId && isDateWithin(date, request.from, request.to)) {
				return `<td class="comparison-cell cell-actual">Actual</td>`;
			}

			const overlapping = vacations.find(
				(item) =>
					item.id !== request.id &&
					item.employeeId === employeeId &&
					isActiveVacationRequest(item) &&
					isBusinessDay(date) &&
					isDateWithin(date, item.from, item.to),
			);

			if (overlapping?.status === 'aprobada') {
				return `<td class="comparison-cell cell-approved">Aprobada</td>`;
			}

			if (overlapping?.status === 'pendiente') {
				return `<td class="comparison-cell cell-pending">Pendiente</td>`;
			}

			return `<td class="comparison-cell cell-free">Libre</td>`;
		}

		function employeeVacationPreview(from: string, to: string) {
			const employee = currentEmployee();
			if (!from || !to) {
				employeeVacationPreviewWeekStart = '';
				return `
					<section class="vacation-preview employee-vacation-preview">
						<div class="panel-heading">
							<div>
								<h3>Coincidencias con tu equipo</h3>
								<p class="helper-text">Selecciona fechas para comprobar si coincides con alguien de tu departamento.</p>
							</div>
						</div>
						${emptyState('Selecciona fechas para comprobar coincidencias con tu equipo.')}
					</section>
				`;
			}

			if (from > to) {
				employeeVacationPreviewWeekStart = '';
				return `
					<section class="vacation-preview employee-vacation-preview">
						<div class="panel-heading">
							<div>
								<h3>Coincidencias con tu equipo</h3>
								<p class="helper-text">Revisa el rango antes de comparar vacaciones.</p>
							</div>
						</div>
						${emptyState('La fecha hasta debe ser igual o posterior a la fecha desde.')}
					</section>
				`;
			}

			ensureEmployeeVacationPreviewWeek(from, to);
			const weekStart = employeeVacationPreviewWeekStart;
			const weekEnd = addDaysIso(weekStart, 6);
			const weekDays = dateRange(weekStart, weekEnd);
			const minWeekStart = startOfWeekIso(from);
			const maxWeekStart = startOfWeekIso(to);
			const previewRequest: VacationRequest = {
				id: 'preview-current-request',
				employeeId: employee.id,
				from,
				to,
				days: businessDaysBetween(from, to),
				status: 'pendiente',
				createdAt: new Date().toISOString(),
			};
			const peers = departmentEmployees(employee.department);
			const overlaps = vacations
				.filter(
					(request) =>
						request.employeeId !== employee.id &&
						isActiveVacationRequest(request) &&
						peers.some((peer) => peer.id === request.employeeId) &&
						businessRangesOverlap(from, to, request.from, request.to),
				)
				.sort((a, b) => a.from.localeCompare(b.from));
			const pastRequestNote = from < todayIso()
				? `<p class="vacation-regularization-note">Estás solicitando vacaciones en fechas pasadas. Se registrará como regularización.</p>`
				: '';

			const comparisonRows = peers.map((peer) => `
				<tr>
					<th class="sticky-col">
						<strong>${peer.name}</strong>
						<span>${peer.department}</span>
					</th>
					${weekDays.map((date) => renderEmployeeVacationComparisonCell(peer.id, date, previewRequest)).join('')}
				</tr>
			`).join('');

			return `
				<section class="vacation-preview employee-vacation-preview">
					<div class="panel-heading">
						<div>
							<h3>Coincidencias en ${escapeHtml(employee.department)}</h3>
							<p class="helper-text">${formatDate(from)} - ${formatDate(to)} · ${previewRequest.days} días laborables solicitados.</p>
						</div>
					</div>
					${pastRequestNote}
					<div class="vacation-week-nav">
						<button class="button button-tertiary button-small" type="button" data-action="employee-vacation-week-prev" ${weekStart <= minWeekStart ? 'disabled' : ''}>Semana anterior</button>
						<strong>${formatDayHeader(weekStart)} - ${formatDayHeader(weekEnd)}</strong>
						<button class="button button-tertiary button-small" type="button" data-action="employee-vacation-week-next" ${weekStart >= maxWeekStart ? 'disabled' : ''}>Semana siguiente</button>
					</div>
					${overlaps.length ? `
						<div class="overlap-list">
							${overlaps.map((request) => `
								<div>
									<strong>${employeeName(request.employeeId)}</strong>
									<span>${request.status === 'aprobada' ? 'Aprobadas' : 'Pendiente'} del ${formatDate(request.from)} al ${formatDate(request.to)}</span>
								</div>
							`).join('')}
						</div>
					` : emptyState('No hay coincidencias aprobadas o pendientes en este rango.')}
					<div class="comparison-legend top-gap">
						<span><i class="cell-actual"></i> Solicitud actual</span>
						<span><i class="cell-approved"></i> Vacaciones aprobadas</span>
						<span><i class="cell-pending"></i> Solicitud pendiente</span>
						<span><i class="cell-free"></i> Libre</span>
						<span><i class="cell-off"></i> No laborable</span>
					</div>
					<div class="table-wrap vacation-matrix-wrap vacation-week-table top-gap">
						<table class="vacation-matrix">
							<thead>
								<tr>
									<th class="sticky-col">Empleado</th>
									${weekDays.map((date) => `<th class="${!isBusinessDay(date) ? 'is-weekend' : ''}">${formatDayHeader(date)}<span>${weekdayShort(date)}</span></th>`).join('')}
								</tr>
							</thead>
							<tbody>${comparisonRows}</tbody>
						</table>
