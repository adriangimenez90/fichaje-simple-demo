		function buildHoursReport(days: number) {
			const to = todayIso();
			const from = addDaysIso(to, -(days - 1));
			const expectedDays = dateRange(from, to).filter(
				(date) => !isWeekend(date) && !holidays.some((holiday) => holiday.date === date),
			).length;

			return EMPLOYEES.map((employee) => {
				const entries = timeEntries.filter(
					(entry) => entry.employeeId === employee.id && dateInRange(entry.date, from, to),
				);
				const daysWithEntry = new Set(entries.map((entry) => entry.date)).size;
				const vacationDays = countVacationDaysInRange(employee.id, from, to);
				const employeeIncidents = incidents.filter(
					(incident) => incident.employeeId === employee.id && dateInRange(incident.date, from, to),
				).length;
				const daysWithoutEntry = Math.max(expectedDays - daysWithEntry - vacationDays, 0);
				const hours = formatMinutes(entries.reduce((sum, entry) => sum + workedMinutes(entry), 0));
				const status =
					employeeIncidents > 0
						? pill('Revisar', 'incidencia')
						: daysWithoutEntry > 2
							? pill('Atención', 'pendiente')
							: pill('Correcto', 'correcto');

				return [
					employee.name,
					String(daysWithEntry),
					String(daysWithoutEntry),
					hours,
					String(employeeIncidents),
					String(vacationDays),
					status,
				];
			});
		}

		function buildMissingPunchReport() {
			const today = todayIso();
			return EMPLOYEES.filter((employee) => !findEntry(employee.id, today)?.start).map((employee) => [
				employee.name,
				formatDate(today),
				employee.department,
				pill('Sin fichaje', 'sin fichaje'),
				'Enviar recordatorio',
			]);
		}

		function renderScheduledReportsTable() {
			const rows = scheduledReports
				.slice()
				.sort((a, b) => b.createdAt.localeCompare(a.createdAt))
				.map((report) => [
					escapeHtml(report.reportType),
					escapeHtml(`${report.frequency} · ${report.sendDay}`),
					escapeHtml(report.recipient),
					escapeHtml(report.format),
					report.active ? pill('Activo', 'correcto') : pill('Inactivo', 'sin fichaje'),
				]);

			return renderSimpleTable(['Tipo', 'Frecuencia', 'Destinatario', 'Formato', 'Estado'], rows);
		}

		function performPunch() {
			const employee = currentEmployee();
			const now = currentTime();
			let entry = todayEntry(employee.id);
			let feedback = '';

			if (!entry) {
				entry = {
					id: uniqueId('entry'),
					employeeId: employee.id,
					date: todayIso(),
					start: now,
					breaks: [],
					status: 'correcto',
				};
				timeEntries.push(entry);
				addAudit('Fichaje de entrada', `${employee.name} registró entrada a las ${now}`);
				feedback = `Entrada registrada a las ${now}.`;
			} else if (activeBreak(entry)) {
				const lastBreak = activeBreak(entry);
				if (lastBreak) lastBreak.end = now;
				addAudit('Fin de descanso', `${employee.name} reanudó jornada a las ${now}`);
				feedback = `Jornada reanudada a las ${now}.`;
			} else {
				entry.breaks.push({ start: now, kind: 'manual', label: 'Descanso manual' });
				addAudit('Inicio de descanso', `${employee.name} inició descanso a las ${now}`);
				feedback = `Descanso iniciado a las ${now}.`;
			}

			entry.status = recalculateTimeEntryStatus(entry);
			saveAll();
			showToast(feedback);
			renderPage();
		}

		function checkoutDay() {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);
			const now = currentTime();

			if (!entry?.start || entry.end) {
				showToast('No hay una jornada activa para cerrar.');
				return;
			}

			if (activeBreak(entry)) {
				showToast('Reanuda la jornada antes de fichar la salida.');
				return;
			}

			entry.end = now;
			entry.status = recalculateTimeEntryStatus(entry);
			addAudit('Fichaje de salida', `${employee.name} registró salida a las ${now}`);
			saveAll();
			showToast(`Salida registrada a las ${now}. Jornada guardada.`);
			renderPage();
		}

		function addQuickPause(minutes: number) {
			const employee = currentEmployee();
			const entry = todayEntry(employee.id);

			if (!entry?.start || entry.end || activeBreak(entry)) {
				showToast('La pausa rápida requiere una jornada activa sin descanso abierto.');
				return;
			}

			const start = currentTime();
			const end = addMinutesToTime(start, minutes);
			const label = minutes >= 60 ? `Comida ${minutes / 60} h` : `Pausa ${minutes} min`;
			entry.breaks.push({
				start,
				end,
				kind: minutes >= 60 ? 'meal' : 'quick',
				label,
			});
			addAudit('Pausa rápida', `${employee.name} registró ${label.toLowerCase()}.`);
			saveAll();
			showToast(`${label} registrada con fin automático a las ${end}.`);
			renderPage();
		}

