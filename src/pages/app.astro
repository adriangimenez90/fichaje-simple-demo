			return checkFutureApprovedVacation(request, todayIso());
		}

		function isEnjoyedVacation(request: VacationRequest) {
			return checkEnjoyedVacation(request, todayIso());
		}

		function vacationRequestDays(request: VacationRequest) {
			return calculateVacationRequestDays(request, holidays);
		}

