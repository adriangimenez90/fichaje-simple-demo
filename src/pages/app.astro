							return `
								<div class="vacation-day-row">
									<span>${peer.name}</span>
									<strong class="employee-day-state cell-${state.key}" title="${escapeHtml(state.title)}">${state.label}</strong>
								</div>
							`;
						}).join('')}
					</div>
				</article>
			`;
		}

		function ensureEmployeeVacationPreviewWeek(from: string, to: string) {
			if (!from || !to || from > to) {
				employeeVacationPreviewWeekStart = '';
				return;
			}

			const minWeekStart = startOfWeekIso(from);
			const maxWeekStart = startOfWeekIso(to);

			if (
				!employeeVacationPreviewWeekStart ||
				employeeVacationPreviewWeekStart < minWeekStart ||
				employeeVacationPreviewWeekStart > maxWeekStart
			) {
				employeeVacationPreviewWeekStart = minWeekStart;
			}
		}

		function shiftEmployeeVacationPreviewWeek(amount: number) {
			const form = document.querySelector<HTMLFormElement>('#vacation-request-form');
			if (!form) return;

			const formData = new FormData(form);
			const from = String(formData.get('from') || '');
			const to = String(formData.get('to') || '');

			if (!from || !to || from > to) {
				showToast('Selecciona fechas para navegar por semanas.');
				return;
			}

			ensureEmployeeVacationPreviewWeek(from, to);
			employeeVacationPreviewWeekStart = clampDateIso(
				addDaysIso(employeeVacationPreviewWeekStart, amount),
				startOfWeekIso(from),
				startOfWeekIso(to),
			);
			updateEmployeeVacationPreview();
		}

		function updateEmployeeVacationPreview() {
			const form = document.querySelector<HTMLFormElement>('#vacation-request-form');
			const target = document.querySelector<HTMLElement>('#employee-vacation-preview');
			if (!form || !target) return;

			const formData = new FormData(form);
			target.innerHTML = employeeVacationPreview(
				String(formData.get('from') || ''),
				String(formData.get('to') || ''),
			);
		}

