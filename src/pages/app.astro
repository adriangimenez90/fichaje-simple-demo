		function updateEmployeeAbsenceForm() {
			const form = document.querySelector<HTMLFormElement>('#absence-request-form');
			if (!form) return;

			const formData = new FormData(form);
			const absenceTypeId = String(formData.get('absenceTypeId') || DEFAULT_ABSENCE_TYPE_ID);
			const draftRequest = {
				id: 'draft-absence',
				employeeId: currentEmployee().id,
				from: todayIso(),
				to: todayIso(),
				days: 0,
				status: 'pendiente',
				createdAt: '',
				absenceTypeId,
			} as VacationRequest;
			const type = findAbsenceType(draftRequest, ABSENCE_TYPES) || ABSENCE_TYPES[0];
			const usesHours = type.unit === 'hours';
			const daysBlock = form.querySelector<HTMLElement>('[data-absence-unit="days"]');
			const hoursBlock = form.querySelector<HTMLElement>('[data-absence-unit="hours"]');
			const typeInfo = form.querySelector<HTMLElement>('[data-absence-type-info]');
			const summary = form.querySelector<HTMLElement>('[data-absence-summary]');
			const attachment = form.querySelector<HTMLInputElement>('input[name="attachment"]');

			daysBlock?.classList.toggle('hidden', usesHours);
			hoursBlock?.classList.toggle('hidden', !usesHours);

			form.querySelectorAll<HTMLInputElement>('[data-absence-unit="days"] input').forEach((input) => {
				input.required = !usesHours;
			});
			form.querySelectorAll<HTMLInputElement>('[data-absence-unit="hours"] input').forEach((input) => {
				input.required = usesHours;
			});
			if (attachment) attachment.required = type.documentRequirement === 'required';

			if (typeInfo) {
				const deductsBalance = absenceDeductsVacationBalance(draftRequest, ABSENCE_TYPES);
				typeInfo.innerHTML = `
					<strong>${escapeHtml(type.name)}</strong>
					<span>${absenceCategoryLabel(type.category)}</span>
					<span>Solicitud por ${usesHours ? 'horas' : 'días'}</span>
					<span>${type.requiresApproval ? 'Requiere aprobación' : 'Registro directo'}</span>
					<span>${absenceDocumentLabel(type.documentRequirement)}</span>
					<span>${deductsBalance ? 'Descuenta vacaciones' : 'No descuenta vacaciones'}</span>
				`;
			}

			if (!summary) return;

			if (usesHours) {
				const date = String(formData.get('date') || '');
				const startTime = String(formData.get('startTime') || '');
				const endTime = String(formData.get('endTime') || '');
				if (!date || !startTime || !endTime || timeToMinutes(endTime) <= timeToMinutes(startTime)) {
					summary.textContent = 'Completa los datos para ver el resumen.';
					return;
				}
				const hours = (timeToMinutes(endTime) - timeToMinutes(startTime)) / 60;
				summary.innerHTML = `
					<strong>${escapeHtml(type.name)}</strong>
					<span>${formatDate(date)} · ${startTime} - ${endTime}</span>
					<span>${hours.toLocaleString('es-ES', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} h</span>
					<span>${type.requiresApproval ? 'Pendiente de aprobación' : 'Se registrará automáticamente'}</span>
					<span>${absenceDocumentLabel(type.documentRequirement)}</span>
				`;
				return;
			}

			const from = String(formData.get('from') || '');
			const to = String(formData.get('to') || '');
			if (!from || !to || from > to) {
				summary.textContent = 'Completa los datos para ver el resumen.';
				return;
			}

			const days = businessDaysBetween(from, to);
			if (days <= 0) {
				summary.textContent = 'Completa los datos para ver el resumen.';
				return;
			}

			summary.innerHTML = `
				<strong>${escapeHtml(type.name)}</strong>
				<span>${formatDate(from)} - ${formatDate(to)}</span>
				<span>${days} días</span>
				<span>${type.requiresApproval ? 'Pendiente de aprobación' : 'Se registrará automáticamente'}</span>
				<span>${absenceDocumentLabel(type.documentRequirement)}</span>
			`;
		}

