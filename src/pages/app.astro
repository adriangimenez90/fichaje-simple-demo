		function adminDashboardMetric(
			label: string,
			value: string,
			status = 'correcto',
			helper = '',
			view = '',
			todayFilter: AdminTodayFilter | '' = '',
			action = '',
		) {
			const attrs = view
				? `data-view="${view}"`
				: todayFilter
					? `data-action="admin-today-filter" data-filter="${todayFilter}"`
					: action
						? `data-action="${action}"`
						: '';
			const isActive = todayFilter && adminTodayFilter === todayFilter;
			return `
				<button class="metric-card admin-metric-card ${attrs ? 'is-clickable' : ''} ${isActive ? 'is-active' : ''}" type="button" ${attrs}>
					<span>${label}</span>
					<strong>${value}</strong>
					${helper ? `<small>${helper}</small>` : ''}
					<div class="top-gap-small">${pill(STATUS_LABELS[status] || status, status)}</div>
				</button>
			`;
		}

