													class="button button-secondary button-small"
													type="button"
													data-action="review-incident"
													data-id="${incident.id}"
													${incident.status === 'revisada' ? 'disabled' : ''}
												>
													Marcar revisada
												</button>
											</td>
										</tr>
									`).join('')}
								</tbody>
							</table>
						</div>
						<div class="admin-incident-card-list top-gap">
							${rows.map(renderAdminIncidentCard).join('')}
						</div>
					` : emptyState(adminIncidentFilter === 'pendiente' ? 'No hay incidencias pendientes.' : 'No hay incidencias con este filtro.')}
				</section>
			`;
		}

		function renderAdminVacations() {
			const visibleEmployees = adminVacationEmployees();
			return `
				${sectionTitle('Vacaciones', 'Quién está de vacaciones y cómo queda el equipo.')}
				${renderAdminVacationCalendar(visibleEmployees)}
			`;
		}

		function renderAdminVacationCalendar(employees: Employee[]) {
			const departments = departmentList();
			const employeeOptions = adminVacationFilters.department === 'all'
				? EMPLOYEES
				: departmentEmployees(adminVacationFilters.department);
			const monthLabel = adminVacationCursor.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

			return `
				<section class="panel admin-vacation-calendar-panel">
					<div class="panel-heading">
						<div>
							<h2>Calendario de vacaciones</h2>
							<p class="helper-text">Solo muestra vacaciones aprobadas, festivos y fines de semana.</p>
						</div>
					</div>
					<form id="admin-vacation-filter-form" class="form-grid admin-vacation-controls">
						<label class="field">
							<span>Departamento</span>
							<select name="department">
								<option value="all" ${adminVacationFilters.department === 'all' ? 'selected' : ''}>Todos</option>
								${departments.map((department) => `<option value="${department}" ${adminVacationFilters.department === department ? 'selected' : ''}>${department}</option>`).join('')}
							</select>
						</label>
						<label class="field">
							<span>Empleado</span>
							<select name="employeeId">
								<option value="all" ${adminVacationFilters.employeeId === 'all' ? 'selected' : ''}>Todos</option>
								${employeeOptions.map((employee) => `<option value="${employee.id}" ${adminVacationFilters.employeeId === employee.id ? 'selected' : ''}>${employee.name}</option>`).join('')}
							</select>
						</label>
						<button class="button button-secondary button-small" type="submit">Aplicar</button>
					</form>
					<div class="calendar-toolbar admin-vacation-toolbar">
						<button class="button button-secondary button-small" type="button" data-action="admin-vacation-prev">← Mes anterior</button>
						<h2>${monthLabel}</h2>
						<button class="button button-secondary button-small" type="button" data-action="admin-vacation-next">Mes siguiente →</button>
					</div>
					${adminVacationLegend()}
					${renderAdminVacationMonthCalendar(employees)}
				</section>
			`;
		}

		function adminVacationLegend() {
			return `
				<div class="comparison-legend team-vacation-legend">
					<span><i class="team-legend-approved"></i> Vacaciones aprobadas</span>
					<span><i class="team-legend-free"></i> Libre</span>
					<span><i class="team-legend-weekend"></i> Fin de semana</span>
					<span><i class="team-legend-holiday"></i> Festivo</span>
				</div>
			`;
		}

		function renderAdminVacationMonthCalendar(employees: Employee[]) {
			if (!employees.length) return emptyState('No hay empleados con estos filtros.');

			const year = adminVacationCursor.getFullYear();
			const month = adminVacationCursor.getMonth();
			const first = new Date(year, month, 1);
			const startOffset = (first.getDay() + 6) % 7;
			const start = new Date(year, month, 1 - startOffset);
			const cells = Array.from({ length: 42 }, (_, index) => {
				const date = new Date(start);
				date.setDate(start.getDate() + index);
				const iso = isoFromDate(date);
				const dayData = adminVacationDayData(iso, employees);
				const dayStatus = teamVacationDayStatus(dayData, iso);
				const names = uniqueVacationNames([...dayData.approved, ...dayData.pending]);
				const visibleNames = names.slice(0, 3);
				const extraCount = Math.max(names.length - visibleNames.length, 0);
				const isCurrentMonth = date.getMonth() === month;

				return `
					<button
						class="team-calendar-day admin-vacation-day team-day-${dayStatus} ${isCurrentMonth ? '' : 'is-muted'} ${selectedAdminVacationDay === iso ? 'is-selected' : ''}"
						type="button"
						data-action="admin-vacation-day"
						data-date="${iso}"
						title="${teamVacationTooltip(iso, dayData)}"
					>
						<strong>${date.getDate()}</strong>
						<div class="team-day-names">
							${visibleNames.map((name) => `<span>${escapeHtml(name)}</span>`).join('')}
							${extraCount ? `<span class="more-count">+${extraCount} más</span>` : ''}
						</div>
					</button>
				`;
			}).join('');

			return `
				<div class="team-calendar-grid top-gap" aria-label="Calendario mensual de vacaciones">
					${['L', 'M', 'X', 'J', 'V', 'S', 'D'].map((day) => `<div class="calendar-head">${day}</div>`).join('')}
					${cells}
				</div>
				${selectedAdminVacationDay ? renderAdminVacationDayDetail(selectedAdminVacationDay, employees) : ''}
			`;
		}

		function renderAdminVacationDayDetail(date: string, employees: Employee[]) {
			const dayData = adminVacationDayData(date, employees);
			const holiday = holidays.find((item) => item.date === date);
			const dayStatus = teamVacationDayStatus(dayData, date);

			return `
				<section class="team-day-detail admin-vacation-day-detail top-gap" aria-live="polite">
					<div class="day-detail-head">
						<div>
							<span class="meta-label">Detalle del día</span>
							<h3>${formatDate(date)}</h3>
						</div>
						${pill(teamVacationDayStatusLabel(dayStatus), dayStatus)}
					</div>
					<div class="summary-list team-day-flags">
						${summaryRow('Festivo', holiday ? `${escapeHtml(holiday.name)} · ${escapeHtml(holiday.center)}` : 'No')}
						${summaryRow('Fin de semana', isWeekend(date) ? 'Sí' : 'No')}
					</div>
					${dayData.approved.length ? `
						<div>
							<h4>Personas de vacaciones</h4>
							${renderTeamVacationList(dayData.approved)}
						</div>
					` : emptyState('Sin vacaciones registradas.')}
					${renderAdminDepartmentAvailability(date, employees)}
				</section>
			`;
		}

		function renderAdminDepartmentAvailability(date: string, employees: Employee[]) {
			const approvedIds = new Set(adminVacationDayData(date, employees).approved.map((request) => request.employeeId));
			const rows = departmentList()
				.map((department) => {
					const departmentPeople = employees.filter((employee) => employee.department === department);
					if (!departmentPeople.length) return '';
					const total = departmentPeople.length;
					const away = departmentPeople.filter((employee) => approvedIds.has(employee.id)).length;
					const availability = total ? Math.round(((total - away) / total) * 100) : 100;
					const status = availability >= 67 ? 'high' : availability >= 34 ? 'medium' : 'low';
					return `
						<div class="department-availability-row availability-${status}">
							<strong>${escapeHtml(department)}</strong>
							<span>${total} total</span>
							<span>${away} de vacaciones</span>
							<b>${availability}% disponible</b>
						</div>
					`;
				})
				.filter(Boolean)
				.join('');

			return `
				<div class="department-availability top-gap">
					<h4>Disponibilidad por departamento</h4>
					${rows || emptyState('No hay empleados visibles para calcular disponibilidad.')}
				</div>
			`;
		}

		function renderAdminVacationCards(requests: VacationRequest[], emptyMessage: string) {
			if (!requests.length) return emptyState(emptyMessage);

			return `
				<div class="admin-vacation-card-list">
					${requests.map((request) => {
						const employee = employeeById(request.employeeId);
						const label = request.status === 'aprobada' && isEnjoyedVacation(request) ? 'Disfrutada' : STATUS_LABELS[request.status] || request.status;
						return `
							<article class="admin-vacation-card">
								<div>
									<strong>${employeeName(request.employeeId)}</strong>
									<span>${escapeHtml(employee?.department || 'Sin departamento')}</span>
								</div>
								<div class="admin-card-grid">
									${summaryRow('Fechas', `${formatDate(request.from)} - ${formatDate(request.to)}`)}
									${summaryRow('Días laborables', String(vacationRequestDays(request)))}
									${summaryRow('Estado', pill(label, request.status))}
									${summaryRow('Comentario', escapeHtml(request.comment || 'Sin comentario'))}
								</div>
							</article>
						`;
					}).join('')}
				</div>
			`;
		}

		function renderAdminDeniedVacationCards(requests: VacationRequest[]) {
			if (!requests.length) return emptyState('No hay solicitudes denegadas con estos filtros.');

			return `
				<div class="admin-vacation-card-list denied-vacation-list">
					${requests.map((request) => {
						const employee = employeeById(request.employeeId);
						return `
							<article class="admin-vacation-card">
								<div>
									<strong>${employeeName(request.employeeId)}</strong>
									<span>${escapeHtml(employee?.department || 'Sin departamento')}</span>
								</div>
								<div class="admin-card-grid">
									${summaryRow('Fechas', `${formatDate(request.from)} - ${formatDate(request.to)}`)}
									${summaryRow('Días laborables', String(vacationRequestDays(request)))}
									${summaryRow('Motivo', escapeHtml(request.denialReason || 'Sin motivo registrado'))}
									${summaryRow('Decisión', request.decidedAt ? formatDateTime(request.decidedAt) : 'Sin fecha')}
								</div>
							</article>
						`;
					}).join('')}
				</div>
			`;
		}

		function adminVacationEmployees() {
			return EMPLOYEES.filter((employee) => {
				if (adminVacationFilters.department !== 'all' && employee.department !== adminVacationFilters.department) return false;
				if (adminVacationFilters.employeeId !== 'all' && employee.id !== adminVacationFilters.employeeId) return false;
				return true;
			});
		}

		function adminVacationMonthDateRange() {
			const year = adminVacationCursor.getFullYear();
			const month = adminVacationCursor.getMonth();
			return dateRange(isoFromDate(new Date(year, month, 1)), isoFromDate(new Date(year, month + 1, 0)));
		}

		function adminVacationMonthRequests(employees: Employee[]) {
			const monthDays = adminVacationMonthDateRange();
			const from = monthDays[0];
			const to = monthDays[monthDays.length - 1];
			const employeeIds = new Set(employees.map((employee) => employee.id));
			return vacations
				.filter((request) => employeeIds.has(request.employeeId))
				.filter((request) => businessRangesOverlap(from, to, request.from, request.to));
		}

		function adminVacationRequestsForDate(date: string, employees: Employee[]) {
			if (!isBusinessDay(date)) return [];

			const employeeIds = new Set(employees.map((employee) => employee.id));
			return vacations
				.filter((request) => employeeIds.has(request.employeeId))
				.filter((request) => request.status === 'aprobada')
				.filter((request) => isDateWithin(date, request.from, request.to));
		}

		function adminVacationDayData(date: string, employees: Employee[]) {
			const dayRequests = adminVacationRequestsForDate(date, employees);
			return {
				approved: dayRequests.filter((request) => request.status === 'aprobada'),
				pending: dayRequests.filter((request) => request.status === 'pendiente'),
			};
		}

		function adminDeniedVacationRequests() {
			const year = String(adminVacationCursor.getFullYear());
			const employees = new Set(adminVacationEmployees().map((employee) => employee.id));
			return vacations
				.filter((request) => request.status === 'denegada')
				.filter((request) => employees.has(request.employeeId))
				.filter((request) => request.from.startsWith(year) || request.to.startsWith(year))
				.sort((a, b) => b.createdAt.localeCompare(a.createdAt));
		}

		function renderValidatorRequests() {
			const requests = vacations
				.sort((a, b) => a.from.localeCompare(b.from));
			const filteredRequests = validatorRequestFilter === 'all'
				? requests
				: requests.filter((request) => request.status === validatorRequestFilter);
			const selected =
				filteredRequests.find((request) => request.id === selectedVacationId) ||
				filteredRequests[0] ||
				requests.find((request) => request.id === selectedVacationId);
			selectedVacationId = selected?.id || '';
			const scopedEmployees = selected ? departmentEmployees(employeeById(selected.employeeId)?.department || '') : [];
			const balance = selected ? vacationBalance(selected.employeeId) : undefined;
			const conflictCounts = selected ? vacationConflictCounts(selected, scopedEmployees) : { approved: 0, pending: 0 };
			const filterButtons: Array<{ filter: VacationStatus | 'all'; label: string }> = [
				{ filter: 'pendiente', label: 'Pendientes' },
				{ filter: 'aprobada', label: 'Aprobadas' },
				{ filter: 'denegada', label: 'Denegadas' },
				{ filter: 'all', label: 'Todas' },
			]
				.map(({ filter, label }) => {
					const count = filter === 'all'
						? requests.length
						: requests.filter((request) => request.status === filter).length;
					return validatorFilterButton(label, filter, validatorRequestFilter, count);
				})
				.join('');

			return `
				${sectionTitle('Solicitudes', 'Valida vacaciones pendientes y revisa solapes del departamento antes de decidir.')}
				<div class="responsible-requests-layout">
					<section class="panel responsible-list-panel">
						<div class="panel-heading">
							<div>
								<h2>Solicitudes de vacaciones</h2>
								<p class="helper-text">Filtra por estado y selecciona una solicitud para ver detalle y coincidencias.</p>
							</div>
						</div>
						<div class="request-filter-bar responsible-filter-bar" aria-label="Filtrar solicitudes">
							${filterButtons}
						</div>
						<div class="responsible-request-list top-gap">
							${filteredRequests.length ? filteredRequests.map((request) => `
								<article class="responsible-request-shell ${selected?.id === request.id ? 'is-active' : ''}">
								<button
									class="vacation-select responsible-request-card ${selected?.id === request.id ? 'is-active' : ''}"
									type="button"
									data-action="select-vacation"
									data-id="${request.id}"
								>
									<span>
										<strong>${employeeName(request.employeeId)}</strong>
										<small>${escapeHtml(employeeById(request.employeeId)?.department || 'Sin departamento')}</small>
										${formatDate(request.from)} - ${formatDate(request.to)} · ${vacationRequestDays(request)} días laborables
										${request.comment ? `<small>${escapeHtml(request.comment)}</small>` : ''}
										${responsibleConflictLine(request)}
									</span>
									${pill(request.status)}
								</button>
								${request.status === 'pendiente' ? `
									<div class="responsible-card-actions">
										<button class="button button-primary button-small" type="button" data-action="approve-vacation" data-id="${request.id}">Aprobar</button>
										<button class="button button-danger button-small" type="button" data-action="deny-vacation" data-id="${request.id}">Denegar</button>
									</div>
								` : ''}
								</article>
							`).join('') : emptyState(`No hay solicitudes ${validatorRequestFilter === 'all' ? 'registradas' : STATUS_LABELS[validatorRequestFilter]?.toLowerCase() || 'con este estado'}.`)}
						</div>
					</section>
					<section class="panel responsible-detail-panel" ${selected ? `data-selected-vacation-id="${selected.id}"` : ''}>
						<h2>Detalle y solapes</h2>
						${selected ? `
							<div class="summary-list">
								${summaryRow('Solicitante', employeeName(selected.employeeId))}
								${summaryRow('Departamento', escapeHtml(employeeById(selected.employeeId)?.department || 'Sin departamento'))}
								${summaryRow('Fechas', `${formatDate(selected.from)} - ${formatDate(selected.to)}`)}
								${summaryRow('Días laborables', String(vacationRequestDays(selected)))}
								${summaryRow('Coincidencias aprobadas', String(conflictCounts.approved))}
										${summaryRow('Coincidencias pendientes', String(conflictCounts.pending))}
										${summaryRow('Comentario', escapeHtml(selected.comment || 'Sin comentario'))}
										${summaryRow('Saldo disponible', `${balance?.available ?? 0} días`)}
									</div>
									${renderResponsibleConflictDetails(selected, scopedEmployees)}
									<div class="top-gap">
										${renderVacationAdminDetail(selected, scopedEmployees)}
									</div>
						` : emptyState('Selecciona una solicitud.')}
					</section>
				</div>
			`;
		}

		function renderTeamCalendar() {
			return `
				${sectionTitle('Calendario del equipo', 'Consulta vacaciones y posibles solapes de forma visual.')}
				${renderTeamCalendarContent()}
			`;
		}

		function renderTeamCalendarContent() {
			const departments = departmentList();
			const visibleEmployees = teamCalendarEmployees();
			const monthLabel = teamCalendarCursor.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

			return `
				<section class="panel">
					<div class="panel-heading">
						<div>
							<h2>Planning del equipo</h2>
							<p class="helper-text">Elige un departamento y revisa quién coincide en vacaciones.</p>
						</div>
					</div>
					<form id="team-calendar-filter-form" class="form-grid team-calendar-controls">
						<label class="field">
							<span>Departamento</span>
							<select name="department">
								<option value="all" ${teamCalendarDepartment === 'all' ? 'selected' : ''}>Todos</option>
								${departments.map((department) => `<option value="${department}" ${teamCalendarDepartment === department ? 'selected' : ''}>${department}</option>`).join('')}
							</select>
						</label>
						<label class="field">
							<span>Vista</span>
							<select name="mode">
								<option value="month" ${teamCalendarMode === 'month' ? 'selected' : ''}>Calendario mensual</option>
								<option value="planning" ${teamCalendarMode === 'planning' ? 'selected' : ''}>Planning por empleado</option>
							</select>
						</label>
						<button class="button button-secondary button-small" type="submit">Aplicar filtro</button>
					</form>
				</section>
				<section class="panel top-gap team-calendar-panel">
					<div class="calendar-toolbar">
						<button class="button button-secondary button-small" type="button" data-action="team-calendar-prev">← Mes anterior</button>
						<h2>${monthLabel}</h2>
						<button class="button button-secondary button-small" type="button" data-action="team-calendar-next">Mes siguiente →</button>
					</div>
					${teamVacationLegend()}
					<p class="helper-text">
						${teamCalendarMode === 'month'
							? 'Usa el calendario para ver vacaciones por días. En móvil, toca un día para ver el detalle debajo.'
							: 'Usa el planning para comparar personas por fechas.'}
					</p>
					${teamCalendarMode === 'month' ? renderTeamMonthCalendar(visibleEmployees) : renderTeamPlanning(visibleEmployees)}
					<div class="team-calendar-meta">
						${metricCard('Personas visibles', String(visibleEmployees.length), 'correcto')}
						${metricCard('Vacaciones aprobadas del mes', String(teamMonthRequests(visibleEmployees).filter((request) => request.status === 'aprobada').length), 'vacaciones')}
						${metricCard('Solicitudes pendientes del mes', String(teamMonthRequests(visibleEmployees).filter((request) => request.status === 'pendiente').length), 'pendiente')}
					</div>
				</section>
			`;
		}

		function renderTeamMonthCalendar(employees: Employee[]) {
			if (!employees.length) return emptyState('No hay empleados para el departamento seleccionado.');

			const year = teamCalendarCursor.getFullYear();
			const month = teamCalendarCursor.getMonth();
			const first = new Date(year, month, 1);
			const startOffset = (first.getDay() + 6) % 7;
			const start = new Date(year, month, 1 - startOffset);
			const cells = Array.from({ length: 42 }, (_, index) => {
				const date = new Date(start);
				date.setDate(start.getDate() + index);
				const iso = isoFromDate(date);
				const dayData = teamVacationDayData(iso, employees);
				const dayStatus = teamVacationDayStatus(dayData, iso);
				const names = uniqueVacationNames([...dayData.approved, ...dayData.pending]);
				const visibleNames = names.slice(0, 3);
				const extraCount = Math.max(names.length - visibleNames.length, 0);
				const isCurrentMonth = date.getMonth() === month;

				return `
					<button
						class="team-calendar-day team-day-${dayStatus} ${isCurrentMonth ? '' : 'is-muted'} ${selectedTeamCalendarDay === iso ? 'is-selected' : ''}"
						type="button"
						data-action="team-calendar-day"
						data-date="${iso}"
						title="${teamVacationTooltip(iso, dayData)}"
					>
						<strong>${date.getDate()}</strong>
						<div class="team-day-names">
							${visibleNames.map((name) => `<span>${escapeHtml(name)}</span>`).join('')}
							${extraCount ? `<span class="more-count">+${extraCount} más</span>` : ''}
						</div>
					</button>
				`;
			}).join('');

			return `
				<div class="team-calendar-grid top-gap" aria-label="Calendario mensual del equipo">
					${['L', 'M', 'X', 'J', 'V', 'S', 'D'].map((day) => `<div class="calendar-head">${day}</div>`).join('')}
					${cells}
				</div>
				${selectedTeamCalendarDay ? renderTeamDayDetail(selectedTeamCalendarDay, employees) : ''}
			`;
		}

		function renderTeamPlanning(employees: Employee[]) {
			if (!employees.length) return emptyState('No hay empleados para el departamento seleccionado.');

			const monthDays = teamMonthDateRange();

			return `
				<div class="table-wrap vacation-matrix-wrap team-planning-wrap top-gap">
					<table class="vacation-matrix team-planning-table">
						<thead>
							<tr>
								<th class="sticky-col">Empleado</th>
								${monthDays.map((date) => `
									<th class="${!isBusinessDay(date) ? 'is-weekend' : ''}">
										<span>${formatDayHeader(date)}</span>
										<small>${weekdayShort(date)}</small>
									</th>
								`).join('')}
							</tr>
						</thead>
						<tbody>
							${employees.map((employee) => `
								<tr>
									<th class="sticky-col">
										<strong>${employee.name}</strong>
										<span>${employee.department}</span>
									</th>
									${monthDays.map((date) => renderTeamPlanningCell(employee, date)).join('')}
								</tr>
							`).join('')}
						</tbody>
					</table>
				</div>
			`;
		}

		function renderTeamPlanningCell(employee: Employee, date: string) {
			if (!isBusinessDay(date)) {
				const holiday = holidays.find((item) => item.date === date);
				const state = holiday ? 'holiday' : 'weekend';
				return `
					<td
						class="planning-cell planning-${state} is-weekend"
						title="${escapeHtml(`${employee.name}\n${formatDate(date)}\n${holiday ? `Festivo: ${holiday.name}` : 'Fin de semana'}`)}"
					>
						${holiday ? 'FES' : ''}
					</td>
				`;
			}

			const requests = teamVacationRequestsForDate(date, [employee]);
			const approved = requests.filter((request) => request.status === 'aprobada');
			const pending = requests.filter((request) => request.status === 'pendiente');
			const state = approved.length && pending.length ? 'mixed' : approved.length ? 'approved' : pending.length ? 'pending' : 'free';
			const label = state === 'approved' ? 'VAC' : state === 'pending' ? 'PEN' : state === 'mixed' ? 'MIX' : '';

			return `
				<td
					class="planning-cell planning-${state} ${isWeekend(date) ? 'is-weekend' : ''}"
					title="${teamPlanningTooltip(employee, date, requests)}"
				>
					${label}
				</td>
			`;
		}

		function renderTeamDayDetail(date: string, employees: Employee[]) {
			const dayData = teamVacationDayData(date, employees);
			const holiday = holidays.find((item) => item.date === date);
			const isWeekendDay = isWeekend(date);
			const dayStatus = teamVacationDayStatus(dayData, date);

			return `
				<section class="team-day-detail top-gap" aria-live="polite">
					<div class="day-detail-head">
						<div>
							<span class="meta-label">Detalle del día</span>
							<h3>${formatDate(date)}</h3>
						</div>
						${pill(teamVacationDayStatusLabel(dayStatus), dayStatus)}
					</div>
					<div class="summary-list team-day-flags">
						${summaryRow('Festivo', holiday ? `${escapeHtml(holiday.name)} · ${escapeHtml(holiday.center)}` : 'No')}
						${summaryRow('Fin de semana', isWeekendDay ? 'Sí' : 'No')}
					</div>
					${dayData.approved.length || dayData.pending.length ? `
						<div class="grid grid-2">
							<div>
								<h4>Aprobadas</h4>
								${renderTeamVacationList(dayData.approved)}
							</div>
							<div>
								<h4>Pendientes</h4>
								${renderTeamVacationList(dayData.pending)}
							</div>
						</div>
					` : emptyState('Sin vacaciones registradas.')}
				</section>
			`;
		}

		function renderTeamVacationList(requests: VacationRequest[]) {
			if (!requests.length) return `<p class="helper-text">Sin registros.</p>`;

			return `
				<div class="team-vacation-list">
					${requests.map((request) => `
						<div>
							<strong>${employeeName(request.employeeId)}</strong>
							<span>${formatDate(request.from)} - ${formatDate(request.to)} · ${vacationRequestDays(request)} días laborables</span>
						</div>
					`).join('')}
				</div>
			`;
		}

		function teamVacationLegend() {
			return `
				<div class="comparison-legend team-vacation-legend">
					<span><i class="team-legend-approved"></i> Aprobadas</span>
					<span><i class="team-legend-pending"></i> Pendientes</span>
					<span><i class="team-legend-mixed"></i> Mixto</span>
					<span><i class="team-legend-free"></i> Libre</span>
					<span><i class="team-legend-weekend"></i> Fin de semana</span>
					<span><i class="team-legend-holiday"></i> Festivo</span>
				</div>
			`;
		}

		function teamCalendarEmployees() {
			return teamCalendarDepartment === 'all' ? EMPLOYEES : departmentEmployees(teamCalendarDepartment);
		}

		function teamMonthDateRange() {
			const year = teamCalendarCursor.getFullYear();
			const month = teamCalendarCursor.getMonth();
			return dateRange(isoFromDate(new Date(year, month, 1)), isoFromDate(new Date(year, month + 1, 0)));
		}

		function teamMonthRequests(employees: Employee[]) {
			const monthDays = teamMonthDateRange();
			const from = monthDays[0];
			const to = monthDays[monthDays.length - 1];
			const employeeIds = new Set(employees.map((employee) => employee.id));
			return vacations
				.filter(isActiveVacationRequest)
				.filter((request) => employeeIds.has(request.employeeId))
				.filter((request) => businessRangesOverlap(from, to, request.from, request.to));
		}

		function teamVacationRequestsForDate(date: string, employees: Employee[]) {
			if (!isBusinessDay(date)) return [];

			const employeeIds = new Set(employees.map((employee) => employee.id));
			return vacations
				.filter(isActiveVacationRequest)
				.filter((request) => employeeIds.has(request.employeeId))
				.filter((request) => isDateWithin(date, request.from, request.to));
		}

		function teamVacationDayData(date: string, employees: Employee[]) {
			const dayRequests = teamVacationRequestsForDate(date, employees);
			return {
				approved: dayRequests.filter((request) => request.status === 'aprobada'),
				pending: dayRequests.filter((request) => request.status === 'pendiente'),
			};
		}

		function teamVacationDayStatus(dayData: { approved: VacationRequest[]; pending: VacationRequest[] }, date = '') {
			if (date && holidays.some((holiday) => holiday.date === date)) return 'holiday';
			if (date && isWeekend(date)) return 'weekend';
			if (dayData.approved.length && dayData.pending.length) return 'mixed';
			if (dayData.approved.length) return 'approved';
			if (dayData.pending.length) return 'pending';
			return 'free';
		}

		function teamVacationDayStatusLabel(status: string) {
			if (status === 'approved') return 'Aprobadas';
			if (status === 'pending') return 'Pendientes';
			if (status === 'mixed') return 'Mixto';
			if (status === 'holiday') return 'Festivo';
			if (status === 'weekend') return 'Fin de semana';
			return 'Libre';
		}

		function teamVacationTooltip(date: string, dayData: { approved: VacationRequest[]; pending: VacationRequest[] }) {
			const approvedNames = uniqueVacationNames(dayData.approved).join(', ') || 'Ninguna';
			const pendingNames = uniqueVacationNames(dayData.pending).join(', ') || 'Ninguna';
			const empty = !dayData.approved.length && !dayData.pending.length ? '\nSin vacaciones registradas' : '';
			const holiday = holidays.find((item) => item.date === date);
			const special = holiday ? `\nFestivo: ${holiday.name}` : isWeekend(date) ? '\nFin de semana' : '';
			return escapeHtml(`${formatDate(date)}${special}\nAprobadas: ${approvedNames}\nPendientes: ${pendingNames}${empty}`);
		}

		function teamPlanningTooltip(employee: Employee, date: string, requests: VacationRequest[]) {
			if (!requests.length) {
				return escapeHtml(`${employee.name}\n${formatDate(date)}\nLibre`);
			}

			const detail = requests
				.map((request) => `${request.status === 'aprobada' ? 'Aprobada' : 'Pendiente'}: ${formatDate(request.from)} - ${formatDate(request.to)}`)
				.join('\n');
			return escapeHtml(`${employee.name}\n${formatDate(date)}\n${detail}`);
		}

		function uniqueVacationNames(requests: VacationRequest[]) {
			return Array.from(new Set(requests.map((request) => employeeName(request.employeeId))));
		}

