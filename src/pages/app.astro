							<span>Mes</span>
							<input type="month" name="month" value="${historyMonth}" />
						</label>
						<button class="button button-secondary" type="submit">Filtrar</button>
					</form>
					<div class="history-summary">
						${metricCard('Días con fichaje', String(rows.length), rows.length ? 'correcto' : 'sin fichaje')}
						${metricCard('Horas registradas', formatMinutes(totalWorked), 'trabajando')}
						${metricCard('Incidencias', String(incidentRows), incidentRows ? 'incidencia' : 'correcto')}
					</div>
				</section>
				<section class="panel top-gap">
					<h2>Fichajes del mes</h2>
					${rows.length ? rows
						.map(
							(entry) => `
								<details class="record-detail">
									<summary>
										<span>
											<strong>${formatDate(entry.date)}</strong>
											<small>${entry.start || '--:--'} - ${entry.end || 'sin salida'} · ${formatMinutes(workedMinutes(entry))}</small>
										</span>
										${pill(entry.status)}
									</summary>
									${renderDayDetail(employee.id, entry.date)}
								</details>
