						<div>
							<h2>Estado de hoy</h2>
							<p class="helper-text">Mostrando: ${filterLabel}.</p>
						</div>
						${adminTodayFilter !== 'all' ? `<button class="button button-tertiary button-small" type="button" data-action="admin-today-filter" data-filter="all">Ver todos</button>` : ''}
					</div>
					<div class="table-wrap admin-today-table">
