		function renderTimesheetDetail(rows: TimeEntry[]) {
			if (!selectedTimesheetSummaryKey) {
				return emptyState('Selecciona una persona del resumen para ver sus registros.');
			}

			const selected = timesheetSummaryRows(rows).find((item) => item.key === selectedTimesheetSummaryKey);
			if (!selected) return emptyState('Ese resumen ya no tiene registros con los filtros actuales.');

			const detailRows = rows.filter(
				(entry) => entry.employeeId === selected.employee.id && monthKey(entry.date) === selected.month,
			);
			const detailIncidents = incidents
				.filter((incident) => incident.employeeId === selected.employee.id)
				.filter((incident) => monthKey(incident.date) === selected.month)
				.filter((incident) => dateInRange(incident.date, timeFilters.from, timeFilters.to))
				.sort((a, b) => b.createdAt.localeCompare(a.createdAt));

			return `
				<div class="panel-heading">
					<div>
						<h2>Detalle de ${selected.employee.name}</h2>
						<p class="helper-text">${selected.monthLabel}. ${detailRows.length} registro${detailRows.length === 1 ? '' : 's'}.</p>
					</div>
				</div>
				${renderTimesheetTable(detailRows)}
				${detailIncidents.length ? `
					<div class="top-gap">
						<h3>Incidencias de este periodo</h3>
						<div class="admin-incident-card-list is-visible">
							${detailIncidents.map(renderAdminIncidentCard).join('')}
						</div>
					</div>
				` : ''}
			`;
		}

		function timesheetSummaryRows(rows: TimeEntry[]) {
			const grouped = new Map<string, {
				key: string;
				employee: Employee;
				month: string;
				monthLabel: string;
				days: number;
				worked: number;
				incidents: number;
			}>();

			rows.forEach((entry) => {
				const employee = employeeById(entry.employeeId);
				if (!employee) return;

				const month = monthKey(entry.date);
				const key = `${entry.employeeId}|${month}`;
				const existing = grouped.get(key) || {
					key,
					employee,
					month,
					monthLabel: monthLabel(month),
					days: 0,
					worked: 0,
					incidents: 0,
				};
				existing.days += 1;
				existing.worked += workedMinutes(entry);
				existing.incidents += entry.status === 'incidencia' ? 1 : 0;
				grouped.set(key, existing);
			});

			grouped.forEach((item) => {
				item.incidents += incidents.filter(
					(incident) =>
						incident.employeeId === item.employee.id &&
						monthKey(incident.date) === item.month &&
						dateInRange(incident.date, timeFilters.from, timeFilters.to),
				).length;
			});

			return Array.from(grouped.values()).sort(
				(a, b) => b.month.localeCompare(a.month) || a.employee.name.localeCompare(b.employee.name),
			);
		}

