		function filterEmployeeAbsenceRequests(
			requests: VacationRequest[],
			filter: EmployeeAbsenceFilter,
		): VacationRequest[] {
			return requests
				.filter((request) => {
					if (filter === 'pending') return request.status === 'pendiente';
					if (filter === 'approved') return request.status === 'aprobada' && request.to >= todayIso();
					if (filter === 'history') {
						return (
							request.to < todayIso() ||
							request.status === 'denegada' ||
							request.status === 'cancelada'
						);
					}
					return true;
				})
				.sort((a, b) => {
					const rank = (request: VacationRequest) => {
						if (request.status === 'pendiente') return 0;
						if (request.status === 'aprobada' && request.to >= todayIso()) return 1;
						return 2;
					};
					const rankDiff = rank(a) - rank(b);
					if (rankDiff) return rankDiff;
					return b.createdAt.localeCompare(a.createdAt);
				});
		}

		function filterEmployeeVacationRequests(requests: VacationRequest[], filter: EmployeeVacationFilter) {
			return filterVacationRequests(
				requests,
				filter,
				todayIso(),
			);
		}

