			const roles: Role[] = ['empleado', 'validador_vacaciones', 'admin_global'];
			const currentIndex = roles.indexOf(user.role);
			user.role = roles[(currentIndex + 1) % roles.length];
			addAudit('Rol actualizado', `${user.name} ahora es ${roleLabel(user.role)}.`);
			saveAll();
			showToast(`Rol cambiado a ${roleLabel(user.role)}.`);
