					<form id="vacation-history-filter-form" class="form-grid admin-filters">
						<label class="field">
							<span>Empleado</span>
							<select name="employeeId">
								<option value="all" ${vacationHistoryFilters.employeeId === 'all' ? 'selected' : ''}>Todos</option>
								${EMPLOYEES.map((employee) => `<option value="${employee.id}" ${vacationHistoryFilters.employeeId === employee.id ? 'selected' : ''}>${employee.name}</option>`).join('')}
							</select>
						</label>
						<label class="field">
							<span>Departamento</span>
							<select name="department">
								<option value="all" ${vacationHistoryFilters.department === 'all' ? 'selected' : ''}>Todos</option>
								${departments.map((department) => `<option value="${department}" ${vacationHistoryFilters.department === department ? 'selected' : ''}>${department}</option>`).join('')}
							</select>
						</label>
						<label class="field">
							<span>Estado</span>
							<select name="status">
								<option value="all" ${vacationHistoryFilters.status === 'all' ? 'selected' : ''}>Todos</option>
								<option value="pendiente" ${vacationHistoryFilters.status === 'pendiente' ? 'selected' : ''}>Pendiente</option>
								<option value="aprobada" ${vacationHistoryFilters.status === 'aprobada' ? 'selected' : ''}>Aprobada</option>
								<option value="denegada" ${vacationHistoryFilters.status === 'denegada' ? 'selected' : ''}>Denegada</option>
							</select>
						</label>
						<button class="button button-secondary" type="submit">Filtrar</button>
					</form>
				</section>
				<section class="panel top-gap">
					<h2>Solicitudes</h2>
					${rows.length ? `
						<div class="table-wrap">
							<table>
								<thead>
									<tr>
										<th>Empleado</th>
										<th>Departamento</th>
										<th>Rango</th>
										<th>Días</th>
										<th>Estado</th>
										<th>Decisión</th>
									</tr>
								</thead>
								<tbody>
									${rows.map((request) => {
										const employee = employeeById(request.employeeId);
										return `
											<tr>
												<td><strong>${employeeName(request.employeeId)}</strong></td>
												<td>${escapeHtml(employee?.department || '')}</td>
												<td>${formatDate(request.from)} - ${formatDate(request.to)}</td>
												<td>${request.days}</td>
												<td>${pill(request.status)}</td>
												<td>${request.denialReason ? escapeHtml(request.denialReason) : request.decidedAt ? formatDateTime(request.decidedAt) : 'Pendiente'}</td>
											</tr>
										`;
									}).join('')}
								</tbody>
							</table>
						</div>
					` : emptyState('No hay solicitudes con esos filtros.')}
				</section>
			`;
		}

