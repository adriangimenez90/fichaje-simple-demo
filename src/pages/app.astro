		function adminTodayWorkSummary() {
			const today = todayIso();
			const statuses = EMPLOYEES.map((employee) => ({
				employee,
				entry: findEntry(employee.id, today),
			}));
			const count = (key: string) => statuses.filter(({ employee, entry }) => adminTodayStatus(employee, entry).key === key).length;
			return {
				statuses,
				working: count('trabajando'),
				paused: count('pausa'),
				finished: count('correcto'),
				missing: count('sin-fichar'),
				absent: count('vacaciones'),
				pendingIncidents: incidents.filter((incident) => incident.status === 'pendiente').length,
			};
		}

		function adminAttentionItems() {
			const today = todayIso();
			const pendingIncidents = incidents
				.filter((incident) => incident.status === 'pendiente')
				.slice(0, 3)
				.map((incident) => ({
					type: 'Incidencia',
					person: employeeName(incident.employeeId),
					detail: incident.type,
					date: incident.date,
					view: 'registros',
					actionLabel: 'Revisar',
				}));
			const pendingAbsences = vacations
				.filter((request) => request.status === 'pendiente')
				.slice(0, 3)
				.map((request) => ({
					type: 'Solicitud',
					person: employeeName(request.employeeId),
					detail: absenceTypeName(request),
					date: request.from,
					view: 'vacaciones-admin',
					actionLabel: 'Ver ausencia',
				}));
			const incompleteEntries = timeEntries
				.filter((entry) => entry.date < today && entry.start && !entry.end)
				.slice(0, 2)
				.map((entry) => ({
					type: 'Registro',
					person: employeeName(entry.employeeId),
					detail: 'Jornada sin salida registrada',
					date: entry.date,
					view: 'registros',
					actionLabel: 'Revisar',
				}));
			return [...pendingIncidents, ...pendingAbsences, ...incompleteEntries]
				.sort((first, second) => second.date.localeCompare(first.date))
				.slice(0, 5);
		}

		function adminUpcomingAbsences() {
			const today = todayIso();
			return vacations
				.filter((request) => request.status === 'aprobada' && request.to >= today)
				.slice()
				.sort((first, second) => first.from.localeCompare(second.from))
				.slice(0, 5);
		}

