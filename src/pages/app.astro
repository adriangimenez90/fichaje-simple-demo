		function resolveVacation(status: VacationStatus, id = '') {
			if (id) selectedVacationId = id;
			const request = vacations.find((item) => item.id === selectedVacationId);
			if (!request || request.status !== 'pendiente') return;

			if (status === 'denegada') {
				const selectedMarker = document.querySelector<HTMLElement>('[data-selected-vacation-id]');
				if (id && selectedMarker && id !== selectedMarker.dataset.selectedVacationId) {
					renderPage();
					showToast('Selecciona la solicitud e indica el motivo para denegar.');
					return;
				}
				const reason = document.querySelector<HTMLTextAreaElement>('#denial-reason')?.value.trim() || '';
				if (!reason) {
					showToast('El motivo es obligatorio para denegar una solicitud.');
					return;
				}
				request.denialReason = reason;
			}

			request.status = status;
			request.decidedAt = new Date().toISOString();
			const isVacation = resolveAbsenceTypeId(request) === DEFAULT_ABSENCE_TYPE_ID;
			const typeName = absenceTypeName(request);
			addAudit(
				status === 'aprobada'
					? (isVacation ? 'Vacaciones aprobadas' : 'Ausencia aprobada')
					: (isVacation ? 'Vacaciones denegadas' : 'Ausencia denegada'),
				`${employeeName(request.employeeId)} · ${typeName} · ${responsibleRequestDateLabel(request)}`,
			);
			saveAll();
			showToast(`${status === 'aprobada' ? 'Solicitud aprobada.' : 'Solicitud denegada.'} La solicitud se ha actualizado en la demo.`);
			renderPage();
		}

