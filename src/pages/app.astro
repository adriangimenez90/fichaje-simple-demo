		function responsibleConflictLine(request: VacationRequest) {
			const employee = employeeById(request.employeeId);
			const scope = employee ? departmentEmployees(employee.department) : EMPLOYEES;
			const details = vacationConflictDetails(request, scope);
			if (!details.length) return '<small>Sin solapes del departamento</small>';
			const preview = details.slice(0, 2).map((item) => (
				`${employeeName(item.request.employeeId)} ${formatDayHeader(item.from)}-${formatDayHeader(item.to)} · ${item.request.status === 'aprobada' ? 'Aprobada' : 'Pendiente'}`
			));
			const extra = details.length > preview.length ? ` · +${details.length - preview.length} más` : '';
			return `<small>${preview.map(escapeHtml).join('<br>')}${extra}</small>`;
		}

