							<span>Estado</span>
							<select name="status">
								<option value="all" ${vacationHistoryFilters.status === 'all' ? 'selected' : ''}>Todos</option>
								<option value="pendiente" ${vacationHistoryFilters.status === 'pendiente' ? 'selected' : ''}>Pendiente</option>
								<option value="aprobada" ${vacationHistoryFilters.status === 'aprobada' ? 'selected' : ''}>Aprobada</option>
								<option value="denegada" ${vacationHistoryFilters.status === 'denegada' ? 'selected' : ''}>Denegada</option>
							</select>
