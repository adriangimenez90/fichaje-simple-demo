				<section class="panel top-gap">
					<h2>Solicitudes</h2>
					${rows.length ? `
						<div class="table-wrap">
							<table>
								<thead>
									<tr>
										<th>Empleado</th>
										<th>Departamento</th>
										<th>Rango</th>
										<th>Días</th>
										<th>Estado</th>
