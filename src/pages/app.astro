		function saveManualAdjustment(form: HTMLFormElement) {
			const formData = new FormData(form);
			const employee = employeeById(String(formData.get('employeeId') || currentEmployee().id)) || currentEmployee();
			const date = String(formData.get('date') || todayIso());
			const source = String(formData.get('source') || 'punch');
			const start = String(formData.get('start') || '').trim();
			const end = String(formData.get('end') || '').trim();
			const reason = String(formData.get('reason') || '').trim();
			let entry = findEntry(employee.id, date);
			const isNewEntry = !entry;

			if (isNewEntry && date > todayIso()) {
				showManualFormMessage(form, 'No se pueden crear registros futuros en la demo.');
				return;
			}

			const originalBreaks = entry?.breaks || [];
			const openBreakIndex = originalBreaks.findIndex((item) => item.start && !item.end);
			const adjustedBreaks = originalBreaks.map((item, index) => ({
				...item,
				start: String(formData.get(`break-start-${index}`) || item.start).trim(),
				end: String(formData.get(`break-end-${index}`) || '').trim() || undefined,
			}));
			const newBreakStart = String(formData.get('new-break-start') || '').trim();
			const newBreakEnd = String(formData.get('new-break-end') || '').trim();

			if (newBreakStart || newBreakEnd) {
				adjustedBreaks.push({
					start: newBreakStart,
					end: newBreakEnd || undefined,
					kind: 'manual',
					label: 'Pausa manual',
				});
			}

			const validationMessage = validateManualTimeAdjustment(
				start,
				end,
				adjustedBreaks,
				Boolean(formData.get('endNextDay')),
				openBreakIndex,
			);

			if (validationMessage) {
				showManualFormMessage(form, validationMessage);
				return;
			}

			if (!entry) {
				entry = {
					id: uniqueId('entry'),
					employeeId: employee.id,
					date,
					breaks: [],
					status: 'correcto',
				};
				timeEntries.push(entry);
			}

			entry.start = start;
			entry.end = end || undefined;
			entry.breaks = adjustedBreaks;
			entry.status = recalculateTimeEntryStatus(entry);
			entry.notes = reason || 'Ajuste manual sin motivo indicado';

			refreshEntryIncident(entry);
			addAudit(
				isNewEntry ? 'Registro creado manualmente' : 'Ajuste manual',
				`${employee.name}: registro de ${formatDate(date)} ${isNewEntry ? 'creado' : 'actualizado'}. ${reason || 'Ajuste manual sin motivo indicado'}.`,
			);
			if (source === 'calendar') {
				selectedCalendarDay = date;
				calendarAdjustmentDate = '';
			}
			saveAll();
			showToast(isNewEntry ? 'Registro creado. Los tiempos se han calculado.' : 'Registro actualizado. Los tiempos se han recalculado.');
			renderPage();
		}

		function saveAbsenceRequest(form: HTMLFormElement) {
			const employee = currentEmployee();
			const formData = new FormData(form);
			const absenceTypeId = String(formData.get('absenceTypeId') || DEFAULT_ABSENCE_TYPE_ID);
			const draftRequest = {
				id: 'draft-absence',
				employeeId: employee.id,
				from: todayIso(),
				to: todayIso(),
				days: 0,
				status: 'pendiente',
				createdAt: '',
				absenceTypeId,
			} as VacationRequest;
			const type = findAbsenceType(draftRequest, ABSENCE_TYPES);

			if (!type || !type.active || type.id !== absenceTypeId) {
				showToast('Selecciona un tipo de ausencia válido.');
				return;
			}

			const comment = String(formData.get('comment') || '').trim();
			const attachmentInput = form.querySelector<HTMLInputElement>('input[name="attachment"]');
			const selectedAttachmentName = attachmentInput?.files?.[0]?.name || '';
			const attachmentName = type.documentRequirement === 'none' ? '' : selectedAttachmentName;

			if (type.documentRequirement === 'required' && !attachmentName) {
				showToast('Añade un justificante para este tipo de ausencia.');
				return;
			}

			const createdAt = new Date().toISOString();
			const request: VacationRequest = {
				id: uniqueId('absence'),
				employeeId: employee.id,
				from: '',
				to: '',
				days: 0,
				status: type.requiresApproval ? 'pendiente' : 'aprobada',
				comment,
				createdAt,
				absenceTypeId: type.id,
				attachmentName: attachmentName || undefined,
				decidedAt: type.requiresApproval ? undefined : createdAt,
			};

			if (type.unit === 'hours') {
				const date = String(formData.get('date') || '');
				const startTime = String(formData.get('startTime') || '');
				const endTime = String(formData.get('endTime') || '');

				if (!date) {
					showToast('Indica la fecha de la ausencia.');
					return;
				}

				if (!type.allowsPastRequests && date < todayIso()) {
					showToast('Este tipo de ausencia no permite solicitudes en fechas pasadas.');
					return;
				}

				if (!startTime || !endTime) {
					showToast('Indica hora de inicio y hora de fin.');
					return;
				}

				const startMinutes = timeToMinutes(startTime);
				const endMinutes = timeToMinutes(endTime);
				if (endMinutes <= startMinutes) {
					showToast('La hora de fin debe ser posterior a la hora de inicio.');
					return;
				}

				request.from = date;
				request.to = date;
				request.requestedHours = Number(((endMinutes - startMinutes) / 60).toFixed(2));
				request.startTime = startTime;
				request.endTime = endTime;
			} else {
				const from = String(formData.get('from') || '');
				const to = String(formData.get('to') || '');

				if (!from || !to || from > to) {
					showToast('Revisa las fechas de la solicitud.');
					return;
				}

				if (!type.allowsPastRequests && from < todayIso()) {
					showToast('Este tipo de ausencia no permite solicitudes en fechas pasadas.');
					return;
				}

				const days = businessDaysBetween(from, to);
				if (days <= 0) {
					showToast('El rango seleccionado no incluye días laborables.');
					return;
				}

				request.from = from;
				request.to = to;
				request.days = days;
			}

			vacations.push(request);
			addAudit(
				type.requiresApproval ? 'Solicitud de ausencia' : 'Ausencia registrada',
				`${employee.name}: ${type.name} ${absenceRequestDateLabel(request)}.`,
			);
			saveAll();
			employeeAbsenceFormOpen = false;
			showToast(type.requiresApproval ? 'Solicitud enviada. En producción se avisaría a la persona responsable.' : 'Ausencia registrada en la demo.');
			renderPage();
		}

