---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FichajeSimple">
	<main class="login-page">
		<section class="login-brand" aria-labelledby="login-title">
			<div class="brand-lockup">
				<img class="brand-logo" src="/brand/fichajesimple-logo.png" alt="FichajeSimple" />
				<div>
					<p class="eyebrow">Demo SaaS pública</p>
					<h1 id="login-title" class="sr-only">FichajeSimple</h1>
				</div>
			</div>
			<p class="login-subtitle">Registro horario sencillo para pequeñas empresas</p>
			<div class="demo-warning" role="note">
				Demo pública con datos ficticios. No válida como registro horario real.
			</div>
			<div class="login-snapshot" aria-label="Datos ficticios de la demo">
				<div>
					<span>Empresa</span>
					<strong>Empresa Demo</strong>
				</div>
				<div>
					<span>Centro</span>
					<strong>Centro Principal</strong>
				</div>
				<div>
					<span>Modo</span>
					<strong>Datos en navegador</strong>
				</div>
			</div>
			<div class="demo-try">
				<h2>Qué probar en esta demo</h2>
				<div class="demo-feature-grid">
					<article class="demo-feature-card">
						<span class="demo-feature-icon" aria-hidden="true">&#9201;</span>
						<div>
							<strong>Fichaje de entrada y salida</strong>
							<p>Registra una jornada completa desde el perfil empleado.</p>
						</div>
					</article>
					<article class="demo-feature-card">
						<span class="demo-feature-icon" aria-hidden="true">&#9208;</span>
						<div>
							<strong>Pausas y descansos</strong>
							<p>Inicia un descanso y reanuda el trabajo cuando corresponda.</p>
						</div>
					</article>
					<article class="demo-feature-card">
						<span class="demo-feature-icon" aria-hidden="true">&#9728;</span>
						<div>
							<strong>Solicitud de vacaciones</strong>
							<p>Solicita días libres y revisa el saldo disponible.</p>
						</div>
					</article>
					<article class="demo-feature-card">
						<span class="demo-feature-icon" aria-hidden="true">&#10003;</span>
						<div>
							<strong>Validación de vacaciones</strong>
							<p>Aprueba o deniega solicitudes con contexto del equipo.</p>
						</div>
					</article>
					<article class="demo-feature-card">
						<span class="demo-feature-icon" aria-hidden="true">&#9638;</span>
						<div>
							<strong>Planning del equipo</strong>
							<p>Revisa coincidencias en calendario y tabla tipo Excel.</p>
						</div>
					</article>
					<article class="demo-feature-card">
						<span class="demo-feature-icon" aria-hidden="true">&#8595;</span>
						<div>
							<strong>Informes y exportaciones</strong>
							<p>Consulta resúmenes y descargas desde administración.</p>
						</div>
					</article>
				</div>
			</div>
		</section>

		<section class="login-panel" aria-label="Acceso a la demo">
			<div class="profile-login">
				<div class="form-heading">
					<p class="eyebrow">Acceso rápido</p>
					<h2>Elige un perfil para probar la demo</h2>
				</div>
				<div class="profile-grid" aria-label="Perfiles de prueba">
					<button class="profile-card" type="button" data-login="admin_global">
						<span>Administración</span>
						<strong>Entrar como administrador</strong>
					</button>
					<button class="profile-card" type="button" data-login="validador_vacaciones">
						<span>Vacaciones</span>
						<strong>Entrar como validador de vacaciones</strong>
					</button>
					<button class="profile-card" type="button" data-login="ana">
						<span>Empleado</span>
						<strong>Entrar como empleado</strong>
					</button>
				</div>
			</div>

			<details class="manual-login">
				<summary>Acceso manual de demo</summary>
				<form id="login-form" class="login-form">
					<label>
						<span>Email</span>
						<input
							id="email"
							name="email"
							type="email"
							autocomplete="username"
							placeholder="Email de demo"
							required
						/>
					</label>

					<label>
						<span>Contraseña</span>
						<input
							id="password"
							name="password"
							type="password"
							autocomplete="current-password"
							placeholder="Contraseña de demo"
							required
						/>
					</label>

					<p id="login-error" class="form-error" role="alert" hidden>
						Revisa el email y la contraseña de la demo.
					</p>

					<button class="button button-secondary" type="submit">Entrar manualmente</button>
				</form>
			</details>

			<p class="demo-notice">
				Demo pública con datos ficticios. No válida como registro horario real. Los cambios se guardan únicamente en tu navegador.
			</p>

			<div class="feedback-box">
				<h2>Enviar feedback</h2>
				<p>Si algo no encaja o echas de menos alguna función, anótalo y háznoslo llegar.</p>
				<a class="button button-secondary" href="mailto:agimenezch@icloud.com?subject=Feedback%20FichajeSimple&body=Hola%2C%20he%20probado%20la%20demo%20de%20FichajeSimple%20y%20quer%C3%ADa%20comentar...">
					Enviar feedback
				</a>
			</div>
		</section>
	</main>

	<script>
		type DemoUser = {
			id: string;
			email: string;
			password: string;
			name: string;
			role: 'admin_global' | 'validador_vacaciones' | 'empleado';
			department?: string;
			employeeId?: string;
		};

		const SESSION_KEY = 'fs_session';
		const USERS: DemoUser[] = [
			{
				id: 'admin_global',
				email: 'admin.demo@fichajesimple.es',
				password: '1234',
				name: 'Administrador demo',
				role: 'admin_global',
			},
			{
				id: 'validador_vacaciones',
				email: 'vacaciones.demo@fichajesimple.es',
				password: '1234',
				name: 'Validador vacaciones',
				role: 'validador_vacaciones',
				department: 'Administración',
			},
			{
				id: 'ana',
				email: 'ana.demo@fichajesimple.es',
				password: '1234',
				name: 'Ana Martínez',
				role: 'empleado',
				department: 'Administración',
				employeeId: 'ana',
			},
			{
				id: 'miguel',
				email: 'miguel.demo@fichajesimple.es',
				password: '1234',
				name: 'Miguel Torres',
				role: 'empleado',
				department: 'Almacén',
				employeeId: 'miguel',
			},
		];

		function startSession(user: DemoUser) {
			localStorage.setItem(
				SESSION_KEY,
				JSON.stringify({
					id: user.id,
					email: user.email,
					name: user.name,
					role: user.role,
					department: user.department,
					employeeId: user.employeeId,
				}),
			);
			window.location.href = '/app';
		}

		const form = document.querySelector<HTMLFormElement>('#login-form');
		const error = document.querySelector<HTMLElement>('#login-error');

		form?.addEventListener('submit', (event) => {
			event.preventDefault();
			const formData = new FormData(form);
			const email = String(formData.get('email') || '').trim().toLowerCase();
			const password = String(formData.get('password') || '');
			const user = USERS.find((candidate) => candidate.email === email && candidate.password === password);

			if (!user) {
				if (error) error.hidden = false;
				return;
			}

			startSession(user);
		});

		document.querySelectorAll<HTMLButtonElement>('[data-login]').forEach((button) => {
			button.addEventListener('click', () => {
				const user = USERS.find((candidate) => candidate.id === button.dataset.login);
				if (user) startSession(user);
			});
		});
	</script>
</Layout>
