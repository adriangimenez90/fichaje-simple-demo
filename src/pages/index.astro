---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FichajeSimple">
	<main class="login-page">
		<section class="login-brand" aria-labelledby="login-title">
			<div class="brand-lockup">
				<img class="brand-logo" src="/brand/fichajesimple-logo.png" alt="FichajeSimple" />
				<div>
					<p class="eyebrow">Demo SaaS pública</p>
					<h1 id="login-title" class="sr-only">FichajeSimple</h1>
				</div>
			</div>
			<p class="login-subtitle">Registro horario sencillo para pequeñas empresas</p>
			<div class="demo-warning" role="note">
				Demo pública con datos ficticios. No válida como registro horario real.
			</div>
			<div class="login-snapshot" aria-label="Datos ficticios de la demo">
				<div>
					<span>Empresa</span>
					<strong>Sourcing Demo S.L.</strong>
				</div>
				<div>
					<span>Centro</span>
					<strong>Valencia</strong>
				</div>
				<div>
					<span>Modo</span>
					<strong>Sin backend</strong>
				</div>
			</div>
			<div class="demo-try">
				<h2>Qué probar en esta demo</h2>
				<ul>
					<li>Fichar entrada/salida.</li>
					<li>Iniciar y reanudar descansos.</li>
					<li>Solicitar vacaciones.</li>
					<li>Validar vacaciones.</li>
					<li>Revisar planning tipo Excel.</li>
					<li>Consultar informes/exportaciones como administrador.</li>
				</ul>
			</div>
		</section>

		<section class="login-panel" aria-label="Acceso a la demo">
			<form id="login-form" class="login-form">
				<div class="form-heading">
					<p class="eyebrow">Acceso de prueba</p>
					<h2>Entrar en la demo</h2>
				</div>

				<label>
					<span>Email</span>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="username"
						placeholder="admin.demo@fichajesimple.es"
						required
					/>
				</label>

				<label>
					<span>Contraseña</span>
					<input
						id="password"
						name="password"
						type="password"
						autocomplete="current-password"
						placeholder="1234"
						required
					/>
				</label>

				<p id="login-error" class="form-error" role="alert" hidden>
					Revisa el email y la contraseña de la demo.
				</p>

				<button class="button button-primary" type="submit">Entrar</button>
			</form>

			<div class="quick-login" aria-label="Accesos rápidos">
				<button class="button button-secondary" type="button" data-login="admin_global">
					Entrar como administrador global
				</button>
				<button class="button button-secondary" type="button" data-login="validador_vacaciones">
					Entrar como validador de vacaciones
				</button>
				<button class="button button-secondary" type="button" data-login="ana">
					Entrar como empleado
				</button>
			</div>

			<div class="trial-users" aria-label="Usuarios de prueba">
				<h2>Usuarios de prueba</h2>
				<div class="trial-user-list">
					<div>
						<span>Administrador global</span>
						<strong>admin.demo@fichajesimple.es / 1234</strong>
					</div>
					<div>
						<span>Validador vacaciones</span>
						<strong>vacaciones.demo@fichajesimple.es / 1234</strong>
					</div>
					<div>
						<span>Empleado</span>
						<strong>ana.demo@fichajesimple.es / 1234</strong>
					</div>
				</div>
			</div>

			<p class="demo-notice">
				Demo pública con datos ficticios. No válida como registro horario real. Los cambios se guardan únicamente en tu navegador.
			</p>

			<div class="feedback-box">
				<h2>Enviar feedback</h2>
				<p>Si algo no encaja o echas de menos alguna función, anótalo y háznoslo llegar.</p>
				<a class="button button-secondary" href="mailto:hola@fichajesimple.es?subject=Feedback%20demo%20FichajeSimple">
					Enviar feedback
				</a>
			</div>
		</section>
	</main>

	<script>
		type DemoUser = {
			id: string;
			email: string;
			password: string;
			name: string;
			role: 'admin_global' | 'validador_vacaciones' | 'empleado';
			department?: string;
			employeeId?: string;
		};

		const SESSION_KEY = 'fs_session';
		const USERS: DemoUser[] = [
			{
				id: 'admin_global',
				email: 'admin.demo@fichajesimple.es',
				password: '1234',
				name: 'Administrador demo',
				role: 'admin_global',
			},
			{
				id: 'validador_vacaciones',
				email: 'vacaciones.demo@fichajesimple.es',
				password: '1234',
				name: 'Validador vacaciones',
				role: 'validador_vacaciones',
				department: 'Administración',
			},
			{
				id: 'ana',
				email: 'ana.demo@fichajesimple.es',
				password: '1234',
				name: 'Ana Martínez',
				role: 'empleado',
				department: 'Administración',
				employeeId: 'ana',
			},
			{
				id: 'miguel',
				email: 'miguel.demo@fichajesimple.es',
				password: '1234',
				name: 'Miguel Torres',
				role: 'empleado',
				department: 'Almacén',
				employeeId: 'miguel',
			},
		];

		function startSession(user: DemoUser) {
			localStorage.setItem(
				SESSION_KEY,
				JSON.stringify({
					id: user.id,
					email: user.email,
					name: user.name,
					role: user.role,
					department: user.department,
					employeeId: user.employeeId,
				}),
			);
			window.location.href = '/app';
		}

		const form = document.querySelector<HTMLFormElement>('#login-form');
		const error = document.querySelector<HTMLElement>('#login-error');

		form?.addEventListener('submit', (event) => {
			event.preventDefault();
			const formData = new FormData(form);
			const email = String(formData.get('email') || '').trim().toLowerCase();
			const password = String(formData.get('password') || '');
			const user = USERS.find((candidate) => candidate.email === email && candidate.password === password);

			if (!user) {
				if (error) error.hidden = false;
				return;
			}

			startSession(user);
		});

		document.querySelectorAll<HTMLButtonElement>('[data-login]').forEach((button) => {
			button.addEventListener('click', () => {
				const user = USERS.find((candidate) => candidate.id === button.dataset.login);
				if (user) startSession(user);
			});
		});
	</script>
</Layout>
